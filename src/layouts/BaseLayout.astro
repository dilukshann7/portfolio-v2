---
import { Font } from "astro:assets";
import "../styles/global.css";
import { SITE } from "../lib/site";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  noindex?: boolean;
  keywords?: string[];
  pageType?: "website" | "article";
  publishedTime?: string | Date;
  modifiedTime?: string | Date;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
  themeColor?: string;
  colorScheme?: "light" | "dark";
}

const {
  title = SITE.title,
  description = SITE.description,
  image = SITE.socialImage,
  imageAlt = `${SITE.name} portfolio preview`,
  noindex = false,
  keywords = [],
  pageType = "website",
  publishedTime,
  modifiedTime,
  structuredData,
  themeColor = SITE.themeColor,
  colorScheme = "dark",
} = Astro.props;

const publicOrigin = Astro.site?.origin ?? Astro.url.origin;
const canonicalUrl = new URL(Astro.url.pathname, publicOrigin);
const socialImageUrl = new URL(image, publicOrigin);
const keywordList = [...new Set([...SITE.keywords, ...keywords])];
const normalizeDate = (value?: string | Date) =>
  value ? new Date(value).toISOString() : undefined;
const publishedTimeValue = normalizeDate(publishedTime);
const modifiedTimeValue = normalizeDate(modifiedTime);
const robots = noindex
  ? "noindex, nofollow"
  : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1";
const structuredDataItems = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE.name,
    url: publicOrigin,
    description: SITE.description,
    inLanguage: "en",
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: SITE.author,
    url: publicOrigin,
    jobTitle: "Fullstack Developer & AI Engineer",
    sameAs: SITE.sameAs,
  },
  ...(Array.isArray(structuredData)
    ? structuredData
    : structuredData
      ? [structuredData]
      : []),
].map((item) => JSON.stringify(item));
---

<!doctype html>
<html lang="en">
  <head>
    <Font cssVariable="--font-melodrame" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE.author} />
    <meta name="keywords" content={keywordList.join(", ")} />
    <meta name="theme-color" content={themeColor} />
    <meta name="color-scheme" content={colorScheme} />
    <meta name="robots" content={robots} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta
      name="format-detection"
      content="telephone=no, address=no, email=no"
    />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin="anonymous"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Space+Grotesk:wght@300;400;500;600;700&family=Stack+Sans+Notch:wght@200..700&display=swap"
      rel="stylesheet"
    />

    <meta property="og:type" content={pageType} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={SITE.locale} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:alt" content={imageAlt} />
    {
      publishedTimeValue && (
        <meta property="article:published_time" content={publishedTimeValue} />
      )
    }
    {
      modifiedTimeValue && (
        <meta property="article:modified_time" content={modifiedTimeValue} />
      )
    }
    {
      pageType === "article" &&
        keywordList.map((keyword) => (
          <meta property="article:tag" content={keyword} />
        ))
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <meta name="twitter:creator" content={SITE.twitterHandle} />
    <meta name="twitter:site" content={SITE.twitterHandle} />
    {
      structuredDataItems.map((item) => (
        <script is:inline type="application/ld+json" set:html={item} />
      ))
    }

    <slot name="head" />

    <style is:global>
      html,
      body {
        margin: 0;
        padding: 0;
        overflow-x: hidden;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
