---
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import { SITE } from "../lib/site";
import Navigation from "@/components/Navigation.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  canonical?: string;
  noindex?: boolean;
  keywords?: string[];
  pageType?: "website" | "article" | "profile";
  schemaType?: string;
  publishedTime?: string | Date;
  modifiedTime?: string | Date;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
  themeColor?: string;
  colorScheme?: "light" | "dark";
  articleSection?: string;
}

const {
  title = SITE.title,
  description = SITE.description,
  image = SITE.socialImage,
  imageAlt = SITE.socialImageAlt,
  canonical,
  noindex = false,
  keywords = [],
  pageType = "website",
  schemaType = pageType === "article" ? "Article" : "WebPage",
  publishedTime,
  modifiedTime,
  structuredData,
  themeColor = SITE.themeColor,
  colorScheme = "dark",
  articleSection,
} = Astro.props;

const publicOrigin = Astro.site?.origin ?? SITE.url ?? Astro.url.origin;
const canonicalUrl = new URL(canonical ?? Astro.url.pathname, publicOrigin);
const socialImageUrl = new URL(image, publicOrigin);
const keywordList = [...new Set([...SITE.keywords, ...keywords])];
const [profileFirstName = SITE.author, ...profileNameParts] = SITE.author.split(" ");
const profileLastName = profileNameParts.at(-1) ?? "";
const normalizeDate = (value?: string | Date) =>
  value ? new Date(value).toISOString() : undefined;
const publishedTimeValue = normalizeDate(publishedTime);
const modifiedTimeValue = normalizeDate(modifiedTime);
const ogImageType = socialImageUrl.pathname.endsWith(".png")
  ? "image/png"
  : socialImageUrl.pathname.endsWith(".svg")
    ? "image/svg+xml"
    : "image/jpeg";
const robots = noindex
  ? "noindex, nofollow"
  : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1";
const structuredDataItems = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${publicOrigin}/#website`,
    name: SITE.name,
    url: publicOrigin,
    description: SITE.description,
    inLanguage: SITE.language,
    publisher: {
      "@id": `${publicOrigin}/#person`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": `${publicOrigin}/#person`,
    name: SITE.author,
    url: publicOrigin,
    image: new URL(SITE.socialImage, publicOrigin).toString(),
    description: SITE.description,
    jobTitle: SITE.profession,
    email: `mailto:${SITE.email}`,
    homeLocation: SITE.location,
    knowsAbout: keywordList,
    sameAs: SITE.sameAs,
  },
  {
    "@context": "https://schema.org",
    "@type": schemaType,
    "@id": `${canonicalUrl.toString()}#webpage`,
    url: canonicalUrl.toString(),
    name: title,
    description,
    inLanguage: SITE.language,
    isPartOf: {
      "@id": `${publicOrigin}/#website`,
    },
    about: {
      "@id": `${publicOrigin}/#person`,
    },
    primaryImageOfPage: {
      "@type": "ImageObject",
      url: socialImageUrl.toString(),
      caption: imageAlt,
    },
    datePublished: publishedTimeValue,
    dateModified: modifiedTimeValue,
  },
  ...(Array.isArray(structuredData)
    ? structuredData
    : structuredData
      ? [structuredData]
      : []),
].map((item) => JSON.stringify(item));
---

<!doctype html>
<html lang={SITE.language}>
  <head>
    <ClientRouter />
    <Font cssVariable="--font-melodrame" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE.author} />
    <meta name="application-name" content={SITE.name} />
    <meta name="keywords" content={keywordList.join(", ")} />
    <meta name="theme-color" content={themeColor} />
    <meta name="color-scheme" content={colorScheme} />
    <meta name="robots" content={robots} />
    <meta name="googlebot" content={robots} />
    <meta name="bingbot" content={robots} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta
      name="format-detection"
      content="telephone=no, address=no, email=no"
    />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <link rel="canonical" href={canonicalUrl.toString()} />
    <link rel="alternate" hreflang={SITE.language} href={canonicalUrl.toString()} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl.toString()} />
    <link rel="sitemap" href="/sitemap.xml" type="application/xml" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="apple-mobile-web-app-title" content={SITE.name} />
    {SITE.sameAs.map((profile) => <link rel="me" href={profile} />)}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin="anonymous"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Space+Grotesk:wght@300;400;500;600;700&family=Stack+Sans+Notch:wght@200..700&display=swap"
      rel="stylesheet"
    />

    <meta property="og:type" content={pageType} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta property="og:locale" content={SITE.locale} />
    <meta property="og:image" content={socialImageUrl.toString()} />
    <meta property="og:image:url" content={socialImageUrl.toString()} />
    <meta property="og:image:secure_url" content={socialImageUrl.toString()} />
    <meta property="og:image:type" content={ogImageType} />
    <meta property="og:image:alt" content={imageAlt} />
    {modifiedTimeValue && <meta property="og:updated_time" content={modifiedTimeValue} />}
    {
      publishedTimeValue && (
        <meta property="article:published_time" content={publishedTimeValue} />
      )
    }
    {
      modifiedTimeValue && (
        <meta property="article:modified_time" content={modifiedTimeValue} />
      )
    }
    {
      articleSection && (
        <meta property="article:section" content={articleSection} />
      )
    }
    {pageType === "article" && <meta property="article:author" content={SITE.author} />}
    {
      pageType === "article" &&
        keywordList.map((keyword) => (
          <meta property="article:tag" content={keyword} />
        ))
    }
    {
      pageType === "profile" && (
        <>
          <meta property="profile:first_name" content={profileFirstName} />
          {profileLastName && (
            <meta property="profile:last_name" content={profileLastName} />
          )}
        </>
      )
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:url" content={canonicalUrl.toString()} />
    <meta name="twitter:image" content={socialImageUrl.toString()} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <meta name="twitter:creator" content={SITE.twitterHandle} />
    <meta name="twitter:site" content={SITE.twitterHandle} />
    {
      structuredDataItems.map((item) => (
        <script is:inline type="application/ld+json" set:html={item} />
      ))
    }

    <slot name="head" />

    <style is:global>
      html,
      body {
        margin: 0;
        padding: 0;
        overflow-x: hidden;
      }

      .skip-link {
        position: fixed;
        top: 1rem;
        left: 1rem;
        z-index: 10000;
        transform: translateY(-160%);
        padding: 0.75rem 1rem;
        border-radius: 999px;
        background: #fff8ef;
        color: #0a0a0a;
        font-family: "Space Grotesk", sans-serif;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        text-decoration: none;
        transition: transform 180ms ease;
      }

      .skip-link:focus-visible {
        transform: translateY(0);
        outline: 2px solid #0a0a0a;
        outline-offset: 3px;
      }
    </style>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <div class="revealerMain"></div>
    <Navigation />
    <slot />
  </body><script>
    import gsap from "gsap";
    import CustomEase from "gsap/CustomEase";
    import { initGlobalMotionSystem } from "../lib/client/motion";

    gsap.registerPlugin(CustomEase);
    CustomEase.create("hop", "0.9, 0, 0.1, 1");

    initGlobalMotionSystem();
    document.addEventListener("astro:page-load", () => {
      initGlobalMotionSystem();
      gsap.fromTo(
        ".revealerMain",
        { scaleY: 1, transformOrigin: "center top" },
        { scaleY: 0, duration: 1.25, delay: 0.5, ease: "hop" },
      );
    });
  </script>
</html>
