---
import { technologies } from "../data/technologies";
---

<section class="tech-section">
  <h2 class="section-title">The Tech Stack</h2>
  <div class="grid-wrapper">
    <div class="grid">
      <div class="grid-row">
        {
          technologies.slice(0, 3).map((tech) => (
            <div class="grid-item" data-color={tech.color}>
              <img src={tech.icon} alt={tech.name} class="tech-icon" />
              <span class="tech-name">{tech.name}</span>
            </div>
          ))
        }
      </div>
      <div class="grid-row">
        {
          technologies.slice(3, 8).map((tech) => (
            <div class="grid-item" data-color={tech.color}>
              <img src={tech.icon} alt={tech.name} class="tech-icon" />
              <span class="tech-name">{tech.name}</span>
            </div>
          ))
        }
      </div>
      <div class="grid-row">
        {
          technologies.slice(8).map((tech) => (
            <div class="grid-item" data-color={tech.color}>
              <img src={tech.icon} alt={tech.name} class="tech-icon" />
              <span class="tech-name">{tech.name}</span>
            </div>
          ))
        }
      </div>
      <div class="highlight"></div>
    </div>
  </div>
</section>

<style is:global>
  .tech-section {
    background-color: #1a1a1a;
  }
</style>

<style>
  .tech-section {
    position: relative;
    width: 100%;
    min-height: 60vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding-top: 6rem;
    padding-bottom: 8rem;
  }

  .section-title {
    color: #fff;
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 2rem;
    text-align: center;
    text-transform: uppercase;
    width: 100%;
  }

  .grid-wrapper {
    width: 100%;
    max-width: 1200px;
  }

  .grid {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .grid-row {
    display: flex;
    flex: 1;
  }

  .grid-item {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 3rem 1rem;
    border-right: 1px solid rgba(255, 255, 255, 0.2);
    cursor: pointer;
    position: relative;
    z-index: 2;
    background: transparent;
  }

  .grid-item:last-child {
    border-right: none;
  }

  .grid-row:not(:last-child) .grid-item {
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  }

  .tech-icon,
  .tech-name {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .tech-icon {
    width: 48px;
    height: 48px;
    object-fit: contain;
    filter: invert(1);
    transition:
      filter 0.25s ease,
      opacity 0.25s ease;
    opacity: 1;
  }

  .grid-item:hover .tech-icon {
    filter: invert(0);
    opacity: 0;
  }

  .tech-name {
    margin-top: 0;
    text-transform: uppercase;
    color: #fff;
    font-size: 16px;
    font-weight: 800;
    letter-spacing: 1px;
    transition:
      color 0.25s ease,
      opacity 0.25s ease;
    opacity: 0;
  }

  .grid-item:hover .tech-name {
    opacity: 1;
  }

  .highlight {
    position: absolute;
    top: 0;
    left: 0;
    background: white;
    pointer-events: none;
    transition:
      transform 0.25s ease,
      width 0.25s ease,
      height 0.25s ease,
      background-color 0.25s ease;
    opacity: 1;
    z-index: 1;
  }

  @media (max-width: 768px) {
    .tech-section {
      padding-top: 4rem;
      padding-bottom: 5rem;
    }

    .section-title {
      font-size: 2rem;
      margin-bottom: 1.5rem;
    }

    .grid-row {
      flex-wrap: wrap;
    }

    .grid-item {
      flex: 1 1 45%;
      min-width: 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.2);
      padding: 2rem 1rem;
    }

    .grid-item:last-child {
      border-right: none;
    }

    .highlight {
      display: none;
    }
  }

  @media (hover: none) and (pointer: coarse) {
    .tech-icon {
      opacity: 0;
    }

    .tech-name {
      opacity: 1;
    }
  }
</style>

<script>
  import { runPageScript } from "../lib/client/spa";

  const initTechGrid = () =>
    runPageScript("tech-grid", ({ signal }) => {
      const grid = document.querySelector(".tech-section .grid");
      const highlight = document.querySelector<HTMLElement>(
        ".tech-section .highlight",
      );
      const firstItem = document.querySelector(".tech-section .grid-item");

      if (!grid || !highlight || !firstItem) return;

      const isTouchDevice =
        window.matchMedia("(pointer: coarse)").matches ||
        "ontouchstart" in window;

      // On touch devices, show tech names directly (no hover)
      if (isTouchDevice) {
        highlight.style.display = "none";
        grid
          .querySelectorAll<HTMLElement>(".tech-section .tech-name")
          .forEach((name) => {
            name.style.opacity = "1";
          });
        grid
          .querySelectorAll<HTMLElement>(".tech-section .tech-icon")
          .forEach((icon) => {
            icon.style.opacity = "0";
          });
        return;
      }

      const moveToElement = (element: Element) => {
        if (element && highlight && grid) {
          const rect = element.getBoundingClientRect();
          const gridRect = grid.getBoundingClientRect();

          highlight.style.transform = `translate(${
            rect.left - gridRect.left
          }px, ${rect.top - gridRect.top}px)`;
          highlight.style.width = `${rect.width}px`;
          highlight.style.height = `${rect.height}px`;
          highlight.style.backgroundColor =
            (element as HTMLElement).dataset.color || "white";
        }
      };

      moveToElement(firstItem);

      grid.addEventListener(
        "mousemove",
        (e: Event) => {
          const mouseEvent = e as MouseEvent;
          const hoveredElement =
            (mouseEvent.target as Element | null)?.closest(".grid-item") ??
            null;
          if (hoveredElement) {
            moveToElement(hoveredElement);
          }
        },
        { passive: true, signal },
      );
    });

  document.addEventListener("astro:page-load", initTechGrid);
</script>
