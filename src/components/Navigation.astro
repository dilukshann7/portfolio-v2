---
import GlassSurface from "./ui/GlassSurface.tsx";
---

<section class="navigation-container">
  <button
    class="menu-toggle closed"
    type="button"
    aria-controls="site-menu"
    aria-expanded="false"
    aria-label="Open navigation menu"
  >
    <GlassSurface
      client:load
      className="menu-toggle-surface"
      width="100%"
      height="100%"
      borderRadius={999}
      borderWidth={0.08}
      displace={0.5}
      distortionScale={-180}
      redOffset={0}
      greenOffset={10}
      blueOffset={20}
      brightness={50}
      opacity={0.93}
      mixBlendMode="screen"
    >
      <div class="menu-toggle-icon">
        <div class="hamburger">
          <div class="menu-bar" data-position="top"></div>
          <div class="menu-bar" data-position="bottom"></div>
        </div>
      </div>
    </GlassSurface>
    <div class="menu-copy">
      <p>Menu</p>
    </div>
  </button>

  <div class="menu" id="site-menu">
    <div class="col col-1">
      <div class="links">
        <div class="link">
          <a href="#expertise" data-nav-target="expertise">Expertise</a>
        </div>
        <div class="link">
          <a href="#projects" data-nav-target="projects">Projects</a>
        </div>
        <div class="link">
          <a href="#certifications" data-nav-target="certifications"
            >Certifications</a
          >
        </div>
        <div class="link">
          <a href="/blog/">Blog</a>
        </div>
        <div class="link">
          <a href="/contact/">Contact</a>
        </div>
      </div>
      <div class="socials socials-left">
        <div class="sub-col">
          <p>
            <a
              href="https://instagram.com/silknye"
              target="_blank"
              rel="noreferrer"
            >
              Instagram</a
            >
          </p>
          <p>
            <a
              href="https://linkedin.com/in/dilukshann7"
              target="_blank"
              rel="noreferrer"
            >
              LinkedIn</a
            >
          </p>
          <p>
            <a href="https://x.com/silknye" target="_blank" rel="noreferrer"
              >X / Twitter</a
            >
          </p>
          <p>
            <a
              href="https://github.com/dilukshann7"
              target="_blank"
              rel="noreferrer"
            >
              GitHub
            </a>
          </p>
        </div>
      </div>
    </div>
    <div class="col col-2">
      <div class="socials">
        <div class="sub-col">
          <p>Dilukshan Niranjan</p>
          <p>Fullstack Developer & AI Engineer</p>
          <p>Based in Sri Lanka</p>
          <br />
          <p>
            <a style="color: white;" href="mailto:info@dilukshan.dev"
              >info@dilukshan.dev</a
            >
          </p>
        </div>
      </div>

      <div class="header">
        <h1>Hello</h1>
      </div>
    </div>
  </div>
</section>

<style>
  .navigation-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    pointer-events: none;
  }

  .navigation-container > :global(*) {
    pointer-events: auto;
  }

  /* ── Logo ── */
  .logo,
  .menu-logo {
    position: absolute;
    top: 1.75rem;
    left: 2rem;
    z-index: 110;
  }

  .logo a,
  .menu-logo a {
    text-decoration: none;
    color: #1a1a1e;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .menu-logo a {
    color: rgba(255, 255, 255, 0.88);
  }

  /* ── Menu toggle ── */
  :global(.menu-toggle) {
    --menu-toggle-width: 110px;
    --menu-toggle-height: 38px;
    --menu-toggle-open-width: 38px;
    --menu-toggle-icon-size: 38px;
    position: fixed;
    width: var(--menu-toggle-width);
    height: var(--menu-toggle-height);
    border-radius: 999px;
    top: 1.1rem;
    right: 1.5rem;
    padding: 0;
    border: 0;
    background: transparent;
    font: inherit;
    transition:
      width 0.45s cubic-bezier(0.075, 0.82, 0.165, 1),
      transform 350ms cubic-bezier(0.25, 1, 0.5, 1);
    transform-origin: right;
    cursor: pointer;
    z-index: 120;
  }

  :global(.menu-toggle.opened) {
    --menu-toggle-width: var(--menu-toggle-open-width);
  }

  :global(.menu-toggle-surface) {
    width: 100%;
    height: 100%;
    border-radius: 999px;
    transition: filter 400ms cubic-bezier(0.25, 1, 0.5, 1);
  }

  :global(.menu-toggle .glass-surface__content) {
    padding: 0;
  }

  :global(.menu-toggle:hover) {
    transform: scale(0.972) translateY(-1px);
  }

  :global(.menu-toggle:hover .menu-toggle-surface) {
    filter: drop-shadow(0 0.5em 1.1em rgba(0, 0, 0, 0.12));
  }

  :global(.menu-toggle:active) {
    transform: scale(0.958);
  }

  :global(.menu-toggle .menu-copy) {
    position: absolute;
    top: 50%;
    left: 30px;
    transform: translateY(-50%);
    transition: left 0.5s cubic-bezier(0.075, 0.82, 0.165, 1);
    z-index: 20;
    pointer-events: none;
  }

  :global(.menu-toggle .menu-copy p) {
    text-transform: uppercase;
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.2em;
    margin: 0;
    padding: 0;
    color: rgba(255, 255, 255, 0.96);
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.18);
    transition:
      color 180ms ease,
      text-shadow 180ms ease;
  }

  :global(.menu-toggle.menu-toggle--dark-copy .menu-copy p) {
    color: rgba(12, 12, 12, 0.92);
    text-shadow: 0 1px 10px rgba(255, 255, 255, 0.2);
  }

  :global(.menu-toggle:focus-visible) {
    outline: 2px solid rgba(20, 20, 20, 0.85);
    outline-offset: 4px;
  }

  :global(.menu-toggle:hover .menu-copy) {
    left: 20px;
  }

  :global(.menu-toggle.opened .menu-copy) {
    opacity: 0;
  }

  :global(.menu-toggle .menu-toggle-icon) {
    position: absolute;
    right: 0;
    width: var(--menu-toggle-icon-size);
    height: var(--menu-toggle-icon-size);
    border-radius: 100%;
    background: rgba(255, 245, 232, 0.72);
    backdrop-filter: blur(10px) saturate(140%);
    -webkit-backdrop-filter: blur(10px) saturate(140%);
    border: 1px solid rgba(255, 255, 255, 0.28);
    transition: transform 0.5s cubic-bezier(0.075, 0.82, 0.165, 1);
    z-index: 10;
    overflow: hidden;
    transform: scale(0.2);
    transform-origin: center;
    backface-visibility: hidden;
    will-change: transform;
    box-shadow:
      inset 0 0.08em 0.16em rgba(255, 255, 255, 0.45),
      inset 0 -0.08em 0.12em rgba(0, 0, 0, 0.1);
  }

  :global(.menu-toggle:hover .menu-toggle-icon) {
    transform: scale(0.7);
  }

  :global(.menu-toggle.opened .menu-toggle-icon) {
    transform: scale(1.125);
  }

  :global(.menu-toggle .hamburger) {
    position: absolute;
    top: 60%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 30px;
    height: 30px;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: all 1s cubic-bezier(0.075, 0.82, 0.165, 1);
    opacity: 0;
  }

  :global(.menu-toggle:hover .hamburger),
  :global(.menu-toggle.opened .hamburger) {
    top: 50%;
    opacity: 1;
  }

  :global(.menu-toggle .menu-bar) {
    position: absolute;
    width: 15px;
    height: 1.5px;
    background: rgba(20, 20, 20, 0.9);
    transition-property: transform;
    transition: all 250ms ease-out;
  }

  :global(.menu-toggle .menu-bar[data-position="top"]) {
    transform: translateY(-3px);
  }

  :global(.menu-toggle .menu-bar[data-position="bottom"]) {
    transform: translateY(3px);
  }

  :global(.menu-toggle.opened .menu-bar[data-position="top"]) {
    transform: translateY(0) rotate(45deg) scaleX(1.05);
  }

  :global(.menu-toggle.opened .menu-bar[data-position="bottom"]) {
    transform: translateY(0) rotate(-45deg) scaleX(1.05);
  }

  /* menu */
  .menu {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    display: flex;
    background-color: #0f0f0f;
    z-index: 115;
    clip-path: polygon(0% 100%, 100% 100%, 100% 100%, 0% 100%);
    pointer-events: none;
    transform-style: preserve-3d;
    perspective: 1000px;
  }

  .col-1 {
    flex: 1;
  }

  .col-2 {
    flex: 2;
  }

  .col {
    position: relative;
    height: 100%;
    padding: 10em 2em 2em 2em;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: flex-end;
  }

  .link {
    position: relative;
    transform: translateY(30px);
    opacity: 0;
  }

  .link a {
    text-decoration: none;
    color: #fff;
    font-size: 48px;
    font-weight: 300;
    letter-spacing: -1.5px;
    line-height: 125%;
  }

  .socials {
    width: 50%;
    display: flex;
    gap: 2em;
  }

  .socials-left {
    width: 100%;
    justify-content: flex-start;
  }

  .socials .sub-col {
    flex: 1;
  }

  .socials .sub-col a {
    color: inherit;
    text-decoration: none;
  }

  .socials .sub-col p {
    position: relative;
    color: #fff;
    transform: translateY(30px);
    opacity: 0;
    font-family: var(--font-melodrame);
    font-size: 28px;
    font-weight: 400;
    letter-spacing: 0.02em;
    line-height: 1.05;
  }

  .header h1 {
    color: #fff;
    text-transform: uppercase;
    font-family: var(--font-melodrame);
    font-size: 500px;
    font-weight: lighter;
    line-height: 100%;
    height: 400px;
  }

  .header h1 span {
    position: relative;
    display: inline-block;
    transform: scale(0.75) translateY(500px) rotateY(90deg);
    transform-origin: bottom;
  }

  @media (max-width: 900px) {
    :global(.menu-toggle) {
      --menu-toggle-width: 98px;
      --menu-toggle-height: 54px;
      --menu-toggle-open-width: 54px;
      --menu-toggle-icon-size: 54px;
      top: 1em;
      right: 1em;
    }

    :global(.menu-toggle .menu-copy) {
      left: 16px;
    }

    :global(.menu-toggle .menu-copy p) {
      font-size: 10.5px;
      letter-spacing: 0.12em;
    }

    :global(.menu-toggle:hover .menu-copy) {
      left: 14px;
    }

    :global(.menu-toggle .hamburger) {
      width: 22px;
      height: 22px;
    }

    :global(.menu-toggle .menu-bar) {
      width: 12px;
      height: 1.5px;
    }

    .menu {
      flex-direction: column;
      overflow-y: auto;
    }

    .col {
      padding: 7em 1.25em 1.5em 1.25em;
      align-items: flex-start;
    }

    .col-1 {
      padding-bottom: 0;
    }

    .col-2 {
      justify-content: flex-start;
      padding-top: 1.5em;
      padding-bottom: 2.5em;
    }

    .menu-logo {
      top: 1em;
      left: 1em;
    }

    .menu-logo a {
      font-size: 60px;
      line-height: 0.9;
    }

    .links {
      display: flex;
      flex-direction: column;
      gap: 0.4em;
    }

    .link {
      transform: translateY(16px);
    }

    .link a {
      font-size: 2.45rem;
      letter-spacing: -0.5px;
      line-height: 1.08;
    }

    .socials-left {
      display: none;
    }

    .socials {
      width: 100%;
      gap: 0.75em;
    }

    .socials .sub-col p {
      font-size: 16px;
      line-height: 1.6;
      transform: translateY(16px);
    }

    .col-2 .socials .sub-col p:first-child {
      font-size: 2.4rem;
      line-height: 0.98;
      letter-spacing: 0.01em;
    }

    .col-2 .socials .sub-col p:not(:first-child) {
      font-size: 1.35rem;
      line-height: 1.38;
    }

    .socials .sub-col p br {
      display: none;
    }

    .header h1 {
      font-size: 18vw;
      height: auto;
      min-height: 70px;
      margin-top: 0.25em;
    }

    .header {
      margin-top: 0.5em;
      align-self: flex-start;
    }
  }

  @media (hover: none) and (pointer: coarse) {
    :global(.menu-toggle:hover) {
      transform: none;
    }

    :global(.menu-toggle .hamburger) {
      top: 50%;
      opacity: 1;
    }

    :global(.menu-toggle .menu-toggle-icon) {
      transform: scale(0.56);
    }

    :global(.menu-toggle.opened .menu-toggle-icon) {
      transform: scale(1.125);
    }
  }

  @media (max-width: 480px) {
    :global(.menu-toggle) {
      --menu-toggle-width: 104px;
      --menu-toggle-height: 52px;
      --menu-toggle-open-width: 52px;
      --menu-toggle-icon-size: 52px;
      top: 0.75em;
      right: 0.75em;
    }

    :global(.menu-toggle .menu-copy) {
      left: 16px;
    }

    :global(.menu-toggle .menu-copy p) {
      font-size: 10.5px;
      letter-spacing: 0.11em;
    }

    .col {
      padding: 8em 1rem 1.25em 1rem;
    }

    .menu-logo {
      top: 0.75em;
      left: 0.75em;
    }

    .menu-logo a {
      font-size: 52px;
      line-height: 0.9;
    }

    .link a {
      font-size: 2.15rem;
    }

    .links {
      gap: 0.6em;
    }

    .socials .sub-col p {
      font-size: 15px;
    }

    .col-2 .socials .sub-col p:first-child {
      font-size: 2rem;
    }

    .col-2 .socials .sub-col p:not(:first-child) {
      font-size: 1.2rem;
      line-height: 1.36;
    }

    .col-2 {
      padding-top: 1.25em;
      padding-bottom: 2em;
    }

    .header {
      margin-top: 0;
    }

    .header h1 {
      font-size: 22vw;
      min-height: 60px;
    }
  }
</style>

<script>
  import gsap from "gsap";
  import CustomEase from "gsap/dist/CustomEase";
  import { runPageScript } from "../lib/client/spa";

  const initNavigation = () =>
    runPageScript("navigation", ({ signal }) => {
      gsap.registerPlugin(CustomEase);
      CustomEase.create(
        "hop",
        "M0,0 C0.354,0 0.464,0.133 0.498,0.502 0.532,0.872 0.651,1 1,1",
      );

      const menuToggle = document.querySelector<HTMLElement>(".menu-toggle");
      const menu = document.querySelector<HTMLElement>(".menu");
      const links = document.querySelectorAll<HTMLElement>(".link");
      const socialLinks =
        document.querySelectorAll<HTMLParagraphElement>(".socials p");
      const navLinks =
        document.querySelectorAll<HTMLElement>("[data-nav-target]");
      let isAnimating = false;
      let contrastFrame = 0;
      const contrastTimeouts: number[] = [];

      if (!menuToggle || !menu) return;

      const parseColor = (value: string) => {
        if (!value || value === "transparent") {
          return { r: 0, g: 0, b: 0, a: 0 };
        }

        const match = value.match(/rgba?\(([^)]+)\)/i);
        if (!match) return null;

        const [r = "0", g = "0", b = "0", a = "1"] = match[1]
          .split(",")
          .map((part) => part.trim());

        return {
          r: Number.parseFloat(r),
          g: Number.parseFloat(g),
          b: Number.parseFloat(b),
          a: Number.parseFloat(a),
        };
      };

      const compositeColors = (
        foreground: { r: number; g: number; b: number; a: number },
        background: { r: number; g: number; b: number; a: number },
      ) => {
        const alpha = foreground.a + background.a * (1 - foreground.a);

        if (alpha <= 0) {
          return { r: 255, g: 255, b: 255, a: 0 };
        }

        return {
          r:
            (foreground.r * foreground.a +
              background.r * background.a * (1 - foreground.a)) /
            alpha,
          g:
            (foreground.g * foreground.a +
              background.g * background.a * (1 - foreground.a)) /
            alpha,
          b:
            (foreground.b * foreground.a +
              background.b * background.a * (1 - foreground.a)) /
            alpha,
          a: alpha,
        };
      };

      const resolveBackdropColor = (element: Element | null) => {
        const bodyColor = parseColor(
          window.getComputedStyle(document.body).backgroundColor,
        ) ?? { r: 255, g: 255, b: 255, a: 1 };

        let current = element;
        let resolvedColor =
          bodyColor.a > 0 ? bodyColor : { r: 255, g: 255, b: 255, a: 1 };

        while (current) {
          const backgroundColor = parseColor(
            window.getComputedStyle(current).backgroundColor,
          );

          if (backgroundColor && backgroundColor.a > 0) {
            resolvedColor = compositeColors(backgroundColor, resolvedColor);

            if (resolvedColor.a >= 0.98) {
              break;
            }
          }

          current = current.parentElement;
        }

        return resolvedColor;
      };

      const getRelativeLuminance = ({
        r,
        g,
        b,
      }: {
        r: number;
        g: number;
        b: number;
      }) => {
        const toLinear = (channel: number) => {
          const normalized = channel / 255;
          return normalized <= 0.03928
            ? normalized / 12.92
            : ((normalized + 0.055) / 1.055) ** 2.4;
        };

        const red = toLinear(r);
        const green = toLinear(g);
        const blue = toLinear(b);

        return 0.2126 * red + 0.7152 * green + 0.0722 * blue;
      };

      const updateMenuCopyContrast = () => {
        if (menuToggle.classList.contains("opened")) {
          menuToggle.classList.remove("menu-toggle--dark-copy");
          return;
        }

        const rect = menuToggle.getBoundingClientRect();
        if (!rect.width || !rect.height) return;

        const sampleX = Math.min(
          Math.max(rect.left + rect.width * 0.35, 1),
          window.innerWidth - 1,
        );
        const sampleY = Math.min(
          Math.max(rect.top + rect.height * 0.5, 1),
          window.innerHeight - 1,
        );

        const previousVisibility = menuToggle.style.visibility;
        menuToggle.style.visibility = "hidden";
        const underlyingElement = document.elementFromPoint(sampleX, sampleY);
        menuToggle.style.visibility = previousVisibility;

        const contrastHint = underlyingElement?.closest<HTMLElement>(
          "[data-nav-contrast]",
        );

        if (contrastHint) {
          menuToggle.classList.toggle(
            "menu-toggle--dark-copy",
            contrastHint.dataset.navContrast === "light",
          );
          return;
        }

        const backdropColor = resolveBackdropColor(underlyingElement);
        const isLightBackdrop = getRelativeLuminance(backdropColor) > 0.42;

        menuToggle.classList.toggle("menu-toggle--dark-copy", isLightBackdrop);
      };

      const scheduleMenuCopyContrast = () => {
        if (contrastFrame) return;

        contrastFrame = window.requestAnimationFrame(() => {
          contrastFrame = 0;
          updateMenuCopyContrast();
        });
      };

      const splitTextIntoSpans = (selector: string) => {
        const elements = document.querySelectorAll<HTMLElement>(selector);
        elements.forEach((element) => {
          const text = element.innerText;
          const splitText = text
            .split("")
            .map((char: string) => {
              return `<span>${char === " " ? "&nbsp;&nbsp;" : char}</span>`;
            })
            .join("");
          element.innerHTML = splitText;
        });
      };
      splitTextIntoSpans(".header h1");

      menuToggle.setAttribute("aria-haspopup", "true");
      menuToggle.setAttribute("aria-expanded", "false");
      menuToggle.setAttribute("aria-label", "Open navigation menu");
      scheduleMenuCopyContrast();
      contrastTimeouts.push(window.setTimeout(scheduleMenuCopyContrast, 240));
      contrastTimeouts.push(window.setTimeout(scheduleMenuCopyContrast, 1800));

      window.addEventListener("scroll", scheduleMenuCopyContrast, {
        passive: true,
        signal,
      });
      window.addEventListener("resize", scheduleMenuCopyContrast, {
        passive: true,
        signal,
      });
      signal.addEventListener(
        "abort",
        () => {
          if (contrastFrame) {
            window.cancelAnimationFrame(contrastFrame);
            contrastFrame = 0;
          }

          contrastTimeouts.forEach((timeoutId) => {
            window.clearTimeout(timeoutId);
          });
        },
        { once: true },
      );

      const openMenu = () => {
        if (isAnimating) return;

        if (menuToggle.classList.contains("closed")) {
          menuToggle.classList.remove("closed");
          menuToggle.classList.add("opened");
          menuToggle.setAttribute("aria-expanded", "true");
          menuToggle.setAttribute("aria-label", "Close navigation menu");

          isAnimating = true;

          gsap.to(menu, {
            clipPath: "polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%)",
            ease: "hop",
            duration: 1.5,
            onStart: () => {
              menu.style.pointerEvents = "all";
            },
            onComplete: () => {
              isAnimating = false;
              scheduleMenuCopyContrast();
            },
          });

          gsap.to(links, {
            y: 0,
            opacity: 1,
            stagger: 0.1,
            delay: 0.85,
            duration: 1,
            ease: "power3.out",
          });

          gsap.to(socialLinks, {
            y: 0,
            opacity: 1,
            stagger: 0.05,
            delay: 0.85,
            duration: 1,
            ease: "power3.out",
          });

          gsap.to(".video-wrapper", {
            clipPath: "polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%)",
            ease: "hop",
            duration: 1.5,
            delay: 0.5,
          });

          gsap.to(".header h1 span", {
            rotateY: 0,
            stagger: 0.05,
            delay: 0.75,
            duration: 1.5,
            ease: "power4.out",
          });

          gsap.to(".header h1 span", {
            y: 0,
            scale: 1,
            stagger: 0.05,
            delay: 0.5,
            duration: 1.5,
            ease: "power4.out",
          });
        }
      };

      const closeMenu = (onComplete?: () => void) => {
        if (isAnimating || menuToggle.classList.contains("closed")) return;

        menuToggle.classList.remove("opened");
        menuToggle.classList.add("closed");
        menuToggle.setAttribute("aria-expanded", "false");
        menuToggle.setAttribute("aria-label", "Open navigation menu");

        isAnimating = true;

        gsap.to(menu, {
          clipPath: "polygon(0% 0%, 100% 0%, 100% 0%, 0% 0%)",
          ease: "hop",
          duration: 1.5,
          onComplete: () => {
            menu.style.pointerEvents = "none";
            gsap.set(menu, {
              clipPath: "polygon(0% 100%, 100% 100%, 100% 100%, 0% 100%)",
            });

            gsap.set(links, { y: 30, opacity: 0 });
            gsap.set(socialLinks, { y: 30, opacity: 0 });
            gsap.set(".video-wrapper", {
              clipPath: "polygon(0% 100%, 100% 100%, 100% 100%, 0% 100%)",
            });
            gsap.set(".header h1 span", {
              y: 500,
              rotateY: 90,
              scale: 0.75,
            });

            isAnimating = false;
            scheduleMenuCopyContrast();
            onComplete?.();
          },
        });
      };

      menuToggle.addEventListener(
        "click",
        () => {
          if (isAnimating) return;
          if (menuToggle.classList.contains("closed")) {
            openMenu();
          } else {
            closeMenu();
          }
        },
        { signal },
      );

      menuToggle.addEventListener(
        "touchstart",
        (e) => {
          if (isAnimating) return;
          e.preventDefault();
          if (menuToggle.classList.contains("closed")) {
            openMenu();
          } else {
            closeMenu();
          }
        },
        { passive: false, signal },
      );

      menuToggle.addEventListener(
        "keydown",
        (event) => {
          if (event.key !== "Enter" && event.key !== " ") return;
          event.preventDefault();

          if (isAnimating) return;

          if (menuToggle.classList.contains("closed")) {
            openMenu();
          } else {
            closeMenu();
          }
        },
        { signal },
      );

      document.addEventListener(
        "keydown",
        (event) => {
          if (
            event.key === "Escape" &&
            menuToggle.classList.contains("opened")
          ) {
            closeMenu();
          }
        },
        { signal },
      );

      navLinks.forEach((link) => {
        link.addEventListener(
          "click",
          (event) => {
            const targetId = link.getAttribute("data-nav-target");
            if (!targetId) return;

            const targetElement = document.getElementById(targetId);
            if (!targetElement) return;

            event.preventDefault();

            const scrollToTarget = () => {
              targetElement.scrollIntoView({
                behavior: "smooth",
                block: "start",
              });
            };

            if (menuToggle.classList.contains("opened")) {
              closeMenu(scrollToTarget);
            } else {
              scrollToTarget();
            }
          },
          { signal },
        );
      });
    });

  document.addEventListener("astro:page-load", initNavigation);
</script>
