  /* menu toggle btn */
  .menu-toggle {
    --menu-hover-time: 400ms;
    --menu-hover-ease: cubic-bezier(0.25, 1, 0.5, 1);
    position: fixed;
    top: 2em;
    right: 2em;
    width: 120px;
    height: 60px;
    border-radius: 8em;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.2),
      rgba(255, 255, 255, 0.08) 35%,
      rgba(255, 255, 255, 0.04) 65%,
      rgba(255, 255, 255, 0.16)
    );
    background-size: 140% 140%;
    background-position: 50% 50%;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.38),
      inset 0 -1px 0 rgba(255, 255, 255, 0.08),
      inset 0 0.125em 0.5em rgba(255, 255, 255, 0.18),
      0 0.6em 1.4em rgba(0, 0, 0, 0.14),
      0 0 0.9em rgba(117, 214, 255, 0.12),
      0 0 1.4em rgba(255, 196, 128, 0.08);
    backdrop-filter: blur(10px) saturate(155%);
    -webkit-backdrop-filter: blur(10px) saturate(155%);
    transition:
      width 0.5s cubic-bezier(0.075, 0.82, 0.165, 1),
      transform var(--menu-hover-time) var(--menu-hover-ease),
      box-shadow var(--menu-hover-time) var(--menu-hover-ease),
      backdrop-filter var(--menu-hover-time) var(--menu-hover-ease),
      background-position var(--menu-hover-time) var(--menu-hover-ease);
    transform-origin: right;
    cursor: pointer;
    z-index: 120;
    overflow: visible;
  }

  .menu-toggle.opened {
    width: 60px;
    background-position: 72% 50%;
  }

  .menu-toggle::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: var(--menu-border-width);
    background:
      conic-gradient(
        from var(--menu-angle-1) at 50% 50%,
        rgba(255, 255, 255, 0.45),
        rgba(255, 255, 255, 0.02) 10% 38%,
        rgba(111, 219, 255, 0.34) 50%,
        rgba(255, 255, 255, 0.02) 62% 88%,
        rgba(255, 204, 143, 0.4)
      ),
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.62),
        rgba(255, 255, 255, 0.16)
      );
    mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    mask-composite: exclude;
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    box-shadow: inset 0 0 0 calc(var(--menu-border-width) / 2)
      rgba(255, 255, 255, 0.3);
    opacity: 0.95;
    pointer-events: none;
    transition:
      --menu-angle-1 500ms ease,
      opacity var(--menu-hover-time) var(--menu-hover-ease);
  }

  .menu-toggle::after {
    content: "";
    position: absolute;
    inset: calc(var(--menu-border-width) / 2);
    border-radius: inherit;
    background:
      linear-gradient(
        var(--menu-angle-2),
        rgba(255, 255, 255, 0) 4%,
        rgba(255, 255, 255, 0.42) 28%,
        rgba(255, 255, 255, 0.14) 45%,
        rgba(255, 255, 255, 0) 62%
      ),
      radial-gradient(
        circle at 24% 18%,
        rgba(255, 255, 255, 0.36),
        transparent 28%
      );
    mix-blend-mode: screen;
    background-size: 200% 200%;
    background-position: 0% 50%;
    background-repeat: no-repeat;
    pointer-events: none;
    opacity: 0.95;
    transition:
      background-position calc(var(--menu-hover-time) * 1.25)
        var(--menu-hover-ease),
      --menu-angle-2 calc(var(--menu-hover-time) * 1.25) var(--menu-hover-ease),
      opacity var(--menu-hover-time) var(--menu-hover-ease);
  }

  .menu-toggle:hover {
    transform: scale(0.972) translateY(-1px);
    background-position: 42% 50%;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.48),
      inset 0 -1px 0 rgba(255, 255, 255, 0.12),
      inset 0 0.125em 0.7em rgba(255, 255, 255, 0.22),
      0 0.5em 1.1em rgba(0, 0, 0, 0.16),
      0 0 1.1em rgba(117, 214, 255, 0.16),
      0 0 1.7em rgba(255, 196, 128, 0.14);
    backdrop-filter: blur(24px) saturate(170%);
    -webkit-backdrop-filter: blur(24px) saturate(170%);
  }

  .menu-toggle:hover::before {
    --menu-angle-1: -125deg;
    opacity: 1;
  }

  .menu-toggle:hover::after {
    background-position: 24% 50%;
    opacity: 1;
  }

  .menu-toggle:active {
    transform: scale(0.958);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.38),
      inset 0 -1px 0 rgba(255, 255, 255, 0.08),
      inset 0 0.125em 0.45em rgba(255, 255, 255, 0.18),
      0 0.35em 0.8em rgba(0, 0, 0, 0.16),
      0 0 0.9em rgba(117, 214, 255, 0.14),
      0 0 1.2em rgba(255, 196, 128, 0.12);
  }

  .menu-toggle:active::after {
    background-position: 50% 20%;
    --menu-angle-2: -15deg;
  }

  .menu-copy {
    position: absolute;
    top: 50%;
    left: 30px;
    transform: translateY(-50%);
    color: #fff;
    transition: left 0.5s cubic-bezier(0.075, 0.82, 0.165, 1);
