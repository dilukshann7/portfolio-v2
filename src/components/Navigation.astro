---
import GlassSurface from "./ui/GlassSurface.tsx";
---

<section class="navigation-container">
  <GlassSurface
    client:load
    className="menu-toggle closed"
    width="var(--menu-toggle-width, 120px)"
    height="60px"
    borderRadius={999}
    borderWidth={0.08}
    displace={0.5}
    distortionScale={-180}
    redOffset={0}
    greenOffset={10}
    blueOffset={20}
    brightness={50}
    opacity={0.93}
    mixBlendMode="screen"
  >
    <div class="menu-toggle-icon">
      <div class="hamburger">
        <div class="menu-bar" data-position="top"></div>
        <div class="menu-bar" data-position="bottom"></div>
      </div>
    </div>
    <div class="menu-copy">
      <p>Menu</p>
    </div>
  </GlassSurface>

  <div class="menu">
    <div class="col col-1">
      <div class="menu-logo">
        <a href="#home" data-nav-target="home">Dilukshan</a>
      </div>
      <div class="links">
        <div class="link"><a href="#home" data-nav-target="home">Home</a></div>
        <div class="link">
          <a href="#expertise" data-nav-target="expertise">Expertise</a>
        </div>
        <div class="link">
          <a href="#projects" data-nav-target="projects">Projects</a>
        </div>
        <div class="link">
          <a href="#certifications" data-nav-target="certifications"
            >Certifications</a
          >
        </div>
      </div>
      <div class="socials socials-left">
        <div class="sub-col">
          <p>
            <a
              href="https://instagram.com/dilukshann7"
              target="_blank"
              rel="noreferrer"
            >
              >Instagram</a
            >
          </p>
          <p>
            <a
              href="https://linkedin.com/in/dilukshann7"
              target="_blank"
              rel="noreferrer"
            >
              >LinkedIn</a
            >
          </p>
          <p>
            <a href="https://x.com/dilukshann7" target="_blank" rel="noreferrer"
              >X / Twitter</a
            >
          </p>
          <p>
            <a
              href="https://github.com/dilukshann7"
              target="_blank"
              rel="noreferrer"
            >
              GitHub
            </a>
          </p>
        </div>
      </div>
    </div>
    <div class="col col-2">
      <div class="socials">
        <div class="sub-col">
          <p>Dilukshan N</p>
          <p>Fullstack Developer & AI Engineer</p>
          <p>Based in Sri Lanka</p>
          <br />
          <p>
            <a style="color: white;" href="mailto:dilukshann7@gmail.com"
              >dilukshann7@gmail.com</a
            >
          </p>
        </div>
      </div>

      <div class="header">
        <h1>Hello</h1>
      </div>
    </div>
  </div>
</section>

<style>
  .navigation-container {
    position: relative;
    z-index: 100;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  /* logos */
  .logo,
  .menu-logo {
    position: absolute;
    top: 2em;
    left: 2em;
    z-index: 110;
  }

  .logo a,
  .menu-logo a {
    text-decoration: none;
    color: #000;
    font-family: var(--font-melodrame);
    font-size: 60px;
    font-weight: lighter;
  }

  .menu-logo a {
    color: #fff;
  }

  /* menu toggle btn */
  :global(.menu-toggle) {
    --menu-toggle-width: 120px;
    position: fixed;
    top: 1.2em;
    right: 1.5em;
    transition:
      width 0.5s cubic-bezier(0.075, 0.82, 0.165, 1),
      transform 400ms cubic-bezier(0.25, 1, 0.5, 1),
      box-shadow 400ms cubic-bezier(0.25, 1, 0.5, 1);
    transform-origin: right;
    cursor: pointer;
    z-index: 120;
  }

  :global(.menu-toggle.opened) {
    --menu-toggle-width: 60px;
  }

  :global(.menu-toggle .glass-surface__content) {
    padding: 0;
  }

  :global(.menu-toggle:hover) {
    transform: scale(0.972) translateY(-1px);
    box-shadow: 0 0.5em 1.1em rgba(0, 0, 0, 0.12);
  }

  :global(.menu-toggle:active) {
    transform: scale(0.958);
  }

  :global(.menu-toggle .menu-copy) {
    position: absolute;
    top: 50%;
    left: 30px;
    transform: translateY(-50%);
    color: #fff;
    transition: left 0.5s cubic-bezier(0.075, 0.82, 0.165, 1);
    z-index: 1;
  }

  :global(.menu-toggle .menu-copy p) {
    text-transform: uppercase;
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.2em;
    margin: 0;
    padding: 0;
    color: rgba(255, 255, 255, 0.96);
    text-shadow:
      0 0.2em 0.35em rgba(0, 0, 0, 0.18),
      0 0 0.8em rgba(255, 255, 255, 0.12);
  }

  :global(.menu-toggle:hover .menu-copy) {
    left: 20px;
  }

  :global(.menu-toggle.opened .menu-copy) {
    opacity: 0;
  }

  :global(.menu-toggle .menu-toggle-icon) {
    position: absolute;
    right: 0;
    width: 60px;
    height: 60px;
    border-radius: 100%;
    clip-path: circle(10% at 50% 50%);
    background: rgba(255, 245, 232, 0.72);
    backdrop-filter: blur(10px) saturate(140%);
    -webkit-backdrop-filter: blur(10px) saturate(140%);
    border: 1px solid rgba(255, 255, 255, 0.28);
    transition: all 0.5s cubic-bezier(0.075, 0.82, 0.165, 1);
    z-index: 10;
    overflow: hidden;
    box-shadow:
      inset 0 0.08em 0.16em rgba(255, 255, 255, 0.45),
      inset 0 -0.08em 0.12em rgba(0, 0, 0, 0.1);
  }

  :global(.menu-toggle:hover .menu-toggle-icon) {
    clip-path: circle(35% at 50% 50%);
  }

  :global(.menu-toggle.opened .menu-toggle-icon) {
    clip-path: circle(50% at 50% 50%);
    transform: scale(1.125);
  }

  :global(.menu-toggle .hamburger) {
    position: absolute;
    top: 60%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 30px;
    height: 30px;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: all 1s cubic-bezier(0.075, 0.82, 0.165, 1);
    opacity: 0;
  }

  :global(.menu-toggle:hover .hamburger),
  :global(.menu-toggle.opened .hamburger) {
    top: 50%;
    opacity: 1;
  }

  :global(.menu-toggle .menu-bar) {
    position: absolute;
    width: 15px;
    height: 1.5px;
    background: rgba(20, 20, 20, 0.9);
    transition-property: transform;
    transition: all 250ms ease-out;
  }

  :global(.menu-toggle .menu-bar[data-position="top"]) {
    transform: translateY(-3px);
  }

  :global(.menu-toggle .menu-bar[data-position="bottom"]) {
    transform: translateY(3px);
  }

  :global(.menu-toggle.opened .menu-bar[data-position="top"]) {
    transform: translateY(0) rotate(45deg) scaleX(1.05);
  }

  :global(.menu-toggle.opened .menu-bar[data-position="bottom"]) {
    transform: translateY(0) rotate(-45deg) scaleX(1.05);
  }

  /* menu */
  .menu {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    display: flex;
    background-color: #0f0f0f;
    z-index: 115;
    clip-path: polygon(0% 100%, 100% 100%, 100% 100%, 0% 100%);
    pointer-events: none;
    transform-style: preserve-3d;
    perspective: 1000px;
  }

  .col-1 {
    flex: 1;
  }

  .col-2 {
    flex: 2;
  }

  .col {
    position: relative;
    height: 100%;
    padding: 10em 2em 2em 2em;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: flex-end;
  }

  .link {
    position: relative;
    transform: translateY(30px);
    opacity: 0;
  }

  .link a {
    text-decoration: none;
    color: #fff;
    font-size: 48px;
    font-weight: 300;
    letter-spacing: -1.5px;
    line-height: 125%;
  }

  .video-wrapper {
    width: 100%;
    flex-shrink: 0;
    min-height: 220px;
    max-height: 320px;
    background-color: #1d1d1d;
    clip-path: polygon(0% 100%, 100% 100%, 100% 100%, 0% 100%);
    overflow: hidden;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .video-wrapper img {
    display: block;
    width: 100%;
    height: auto;
    max-height: 100%;
    object-fit: contain;
  }

  .socials {
    width: 50%;
    display: flex;
    gap: 2em;
  }

  .socials-left {
    width: 100%;
    justify-content: flex-start;
  }

  .socials .sub-col {
    flex: 1;
  }

  .socials .sub-col a {
    color: inherit;
    text-decoration: none;
  }

  .socials .sub-col p {
    position: relative;
    color: #fff;
    transform: translateY(30px);
    opacity: 0;
    font-family: var(--font-melodrame);
    font-size: 28px;
    font-weight: 400;
    letter-spacing: 0.02em;
    line-height: 1.05;
  }

  .header h1 {
    color: #fff;
    text-transform: uppercase;
    font-family: var(--font-melodrame);
    font-size: 500px;
    font-weight: lighter;
    line-height: 100%;
    height: 400px;
  }

  .header h1 span {
    position: relative;
    display: inline-block;
    transform: scale(0.75) translateY(500px) rotateY(90deg);
    transform-origin: bottom;
  }

  @media (max-width: 900px) {
    :global(.menu-toggle) {
      --menu-toggle-width: 100px;
      top: 1em;
      right: 1em;
    }

    :global(.menu-toggle .menu-copy) {
      left: 20px;
    }

    :global(.menu-toggle .menu-copy p) {
      font-size: 11px;
      letter-spacing: 0.15em;
    }

    :global(.menu-toggle:hover .menu-copy) {
      left: 16px;
    }

    :global(.menu-toggle .menu-toggle-icon) {
      width: 50px;
      height: 50px;
    }

    :global(.menu-toggle .hamburger) {
      width: 24px;
      height: 24px;
    }

    :global(.menu-toggle .menu-bar) {
      width: 13px;
      height: 1.5px;
    }

    .menu {
      flex-direction: column;
      overflow-y: auto;
    }

    .col {
      padding: 6em 1.5em 2em 1.5em;
      align-items: flex-start;
    }

    .col-1 {
      padding-bottom: 0;
    }

    .col-2 {
      justify-content: flex-start;
      padding-top: 2em;
      padding-bottom: 3em;
    }

    .menu-logo {
      top: 1em;
      left: 1em;
    }

    .menu-logo a {
      font-size: 32px;
    }

    .links {
      display: flex;
      flex-direction: column;
      gap: 0.5em;
    }

    .link {
      transform: translateY(20px);
    }

    .link a {
      font-size: 42px;
      letter-spacing: -1px;
      line-height: 110%;
    }

    .socials-left {
      display: none;
    }

    .socials {
      width: 100%;
      gap: 1em;
    }

    .socials .sub-col p {
      font-size: 16px;
      line-height: 1.5;
      transform: translateY(20px);
    }

    .socials .sub-col p br {
      display: none;
    }

    .header h1 {
      font-size: 20vw;
      height: auto;
      min-height: 80px;
      margin-top: 0.5em;
    }

    .header {
      margin-top: 1em;
      align-self: flex-start;
    }
  }

  @media (hover: none) and (pointer: coarse) {
    :global(.menu-toggle:hover) {
      transform: none;
    }

    :global(.menu-toggle .hamburger) {
      top: 50%;
      opacity: 1;
    }

    :global(.menu-toggle .menu-toggle-icon) {
      clip-path: circle(28% at 50% 50%);
    }

    :global(.menu-toggle.opened .menu-toggle-icon) {
      clip-path: circle(50% at 50% 50%);
    }
  }

  @media (max-width: 480px) {
    :global(.menu-toggle) {
      --menu-toggle-width: 90px;
      height: 50px;
      top: 0.75em;
      right: 0.75em;
    }

    :global(.menu-toggle .menu-toggle-icon) {
      width: 44px;
      height: 44px;
    }

    :global(.menu-toggle .menu-copy) {
      left: 16px;
    }

    :global(.menu-toggle .menu-copy p) {
      font-size: 10px;
    }

    .col {
      padding: 9em 1.25em 1.5em 1.25em;
    }

    .menu-logo a {
      font-size: 5em;
    }

    .link a {
      font-size: 3em;
    }

    .links {
      gap: 0.8em;
    }

    .socials .sub-col p {
      font-size: 2em;
    }

    .col-2 {
      padding-top: 1.5em;
      padding-bottom: 2em;
    }

    .header {
      margin-top: 0em;
    }

    .header h1 {
      font-size: 36vw;
    }
  }
</style>

<script>
  import gsap from "gsap";
  import CustomEase from "gsap/dist/CustomEase";

  document.addEventListener("DOMContentLoaded", () => {
    gsap.registerPlugin(CustomEase);
    CustomEase.create(
      "hop",
      "M0,0 C0.354,0 0.464,0.133 0.498,0.502 0.532,0.872 0.651,1 1,1",
    );

    const menuToggle = document.querySelector(".menu-toggle");
    const menu = document.querySelector(".menu");
    const links = document.querySelectorAll(".link");
    const socialLinks = document.querySelectorAll(".socials p");
    const navLinks = document.querySelectorAll("[data-nav-target]");
    let isAnimating = false;

    const splitTextIntoSpans = (selector) => {
      let elements = document.querySelectorAll(selector);
      elements.forEach((element) => {
        let text = element.innerText;
        let splitText = text
          .split("")
          .map(function (char) {
            return `<span>${char === " " ? "&nbsp;&nbsp;" : char}</span>`;
          })
          .join("");
        element.innerHTML = splitText;
      });
    };
    splitTextIntoSpans(".header h1");

    const openMenu = () => {
      if (isAnimating) return;

      if (menuToggle.classList.contains("closed")) {
        menuToggle.classList.remove("closed");
        menuToggle.classList.add("opened");

        isAnimating = true;

        gsap.to(menu, {
          clipPath: "polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%)",
          ease: "hop",
          duration: 1.5,
          onStart: () => {
            menu.style.pointerEvents = "all";
          },
          onComplete: () => {
            isAnimating = false;
          },
        });

        gsap.to(links, {
          y: 0,
          opacity: 1,
          stagger: 0.1,
          delay: 0.85,
          duration: 1,
          ease: "power3.out",
        });

        gsap.to(socialLinks, {
          y: 0,
          opacity: 1,
          stagger: 0.05,
          delay: 0.85,
          duration: 1,
          ease: "power3.out",
        });

        gsap.to(".video-wrapper", {
          clipPath: "polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%)",
          ease: "hop",
          duration: 1.5,
          delay: 0.5,
        });

        gsap.to(".header h1 span", {
          rotateY: 0,
          stagger: 0.05,
          delay: 0.75,
          duration: 1.5,
          ease: "power4.out",
        });

        gsap.to(".header h1 span", {
          y: 0,
          scale: 1,
          stagger: 0.05,
          delay: 0.5,
          duration: 1.5,
          ease: "power4.out",
        });
      }
    };

    const closeMenu = (onComplete) => {
      if (isAnimating || menuToggle.classList.contains("closed")) return;

      menuToggle.classList.remove("opened");
      menuToggle.classList.add("closed");

      isAnimating = true;

      gsap.to(menu, {
        clipPath: "polygon(0% 0%, 100% 0%, 100% 0%, 0% 0%)",
        ease: "hop",
        duration: 1.5,
        onComplete: () => {
          menu.style.pointerEvents = "none";
          gsap.set(menu, {
            clipPath: "polygon(0% 100%, 100% 100%, 100% 100%, 0% 100%)",
          });

          gsap.set(links, { y: 30, opacity: 0 });
          gsap.set(socialLinks, { y: 30, opacity: 0 });
          gsap.set(".video-wrapper", {
            clipPath: "polygon(0% 100%, 100% 100%, 100% 100%, 0% 100%)",
          });
          gsap.set(".header h1 span", {
            y: 500,
            rotateY: 90,
            scale: 0.75,
          });

          isAnimating = false;
          if (onComplete) onComplete();
        },
      });
    };

    const isTouchDevice = window.matchMedia(
      "(hover: none) and (pointer: coarse)",
    ).matches;

    menuToggle.addEventListener("click", () => {
      if (isAnimating) return;
      if (menuToggle.classList.contains("closed")) {
        openMenu();
      } else {
        closeMenu();
      }
    });

    menuToggle.addEventListener(
      "touchstart",
      (e) => {
        if (isAnimating) return;
        e.preventDefault();
        if (menuToggle.classList.contains("closed")) {
          openMenu();
        } else {
          closeMenu();
        }
      },
      { passive: false },
    );

    navLinks.forEach((link) => {
      link.addEventListener("click", (event) => {
        const targetId = link.getAttribute("data-nav-target");
        if (!targetId) return;

        const targetElement = document.getElementById(targetId);
        if (!targetElement) return;

        event.preventDefault();

        const scrollToTarget = () => {
          targetElement.scrollIntoView({
            behavior: "smooth",
            block: "start",
          });
        };

        if (menuToggle.classList.contains("opened")) {
          closeMenu(scrollToTarget);
        } else {
          scrollToTarget();
        }
      });
    });
  });
</script>
