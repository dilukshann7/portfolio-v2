  }

  .header h1 span {
    position: relative;
    display: inline-block;
    transform: scale(0.75) translateY(500px) rotateY(90deg);
    transform-origin: bottom;
  }

  @media (max-width: 900px) {
    .col-1 {
      flex: 2;
      align-items: flex-start;
    }

    .link a {
      font-size: 30px;
    }

    .video-wrapper {
      min-height: 160px;
      max-height: 220px;
    }

    .socials {
      width: 100%;
      flex-direction: column;
      gap: 4em;
