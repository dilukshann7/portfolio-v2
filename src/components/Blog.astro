---
import BlogScrollArc from "./BlogScrollArc.astro";
import {
  formatBlogDate,
  getAllBlogPosts,
  getPostUrl,
  getReadingTime,
} from "../lib/blog";

const imagePool = [
  "/blog/card-1.jpg",
  "/blog/card-2.jpg",
  "/blog/card-3.jpg",
  "/blog/card-4.jpg",
  "/blog/card-5.jpg",
];

const posts = (await getAllBlogPosts()).slice(0, 5);

const cards = posts.map((post, index) => ({
  title: post.data.title,
  description: post.data.description,
  category: post.data.category,
  href: getPostUrl(post.id),
  image: post.data.heroImage ?? imagePool[index % imagePool.length],
  imageAlt: post.data.heroImageAlt ?? post.data.title,
  meta: `${formatBlogDate(post.data.publishDate)} • ${getReadingTime(post.body)} min read`,
})).map((card, index) => ({
  ...card,
  indexLabel: String(index + 1).padStart(2, "0"),
}));
---

<BlogScrollArc cards={cards} />
