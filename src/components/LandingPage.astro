---
import ColorBends from "./ui/ColorBends";
---

<div class="landing-page" id="home">
  <div class="hero-img">
    <ColorBends
      client:load
      colors={[]}
      rotation={0}
      speed={0.2}
      scale={1}
      frequency={1}
      warpStrength={1}
      mouseInfluence={1}
      parallax={0.5}
      noise={0.1}
      transparent
      autoRotate={0}
      globalPointer
    />
  </div>
  <div class="container">
    <div class="cols">
      <div class="col col-left">
        <div class="left-glass">
          <div class="copy">
            <div class="header">Dilukshan<br />Niranjan</div>
            <div class="sub-header">CS & SE Undergrad from Sri Lanka</div>
            <div class="info">
              Fullstack Developer & AI Engineer passionate about building
              scalable web applications and intelligent systems.
            </div>
          </div>
        </div>
      </div>
      <div class="col col-right">
        <div class="right-copy">
          <div class="header">
            Building
            <br />
            scalable
            <br />
            AI systems
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .landing-page {
    --hero-nav-offset: 5.75rem;
    position: relative;
    width: 100%;
    min-height: 100vh;
    min-height: -webkit-fill-available;
    min-height: 100svh;
    overflow: hidden;
    background-color: #000;
  }

  .landing-page .container {
    position: relative;
    width: 100%;
    min-height: 100vh;
    min-height: -webkit-fill-available;
    min-height: 100svh;
    display: flex;
    overflow: hidden;
  }

  .landing-page .hero-img {
    position: absolute;
    width: 100%;
    min-height: 100vh;
    min-height: 100lvh;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .landing-page .hero-img :global(.color-bends-container) {
    width: 100%;
    height: 100%;
  }

  .landing-page .cols {
    width: 100%;
    display: flex;
    min-height: inherit;
  }

  .landing-page .col {
    width: 50%;
    min-height: 100vh;
    min-height: 100svh;
  }

  .landing-page .col-right {
    position: relative;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    text-align: left;
    color: #f7f1e8;
    border: none;
    padding: 4.5em 4vw 3em 4vw;
  }

  .landing-page .col-right .right-copy {
    position: relative;
    width: min(34rem, 100%);
    min-height: clamp(15rem, 30vw, 24rem);
    margin-left: auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 1rem;
    will-change: transform, opacity, filter;
  }

  .landing-page .col-right .header {
    width: min(8ch, 100%);
    font-family: var(--font-melodrame);
    font-size: clamp(5rem, 8.3vw, 9rem);
    font-weight: 400;
    line-height: 0.82;
    letter-spacing: 0.012em;
    text-transform: none;
    text-wrap: balance;
    color: rgba(255, 246, 238, 0.98);
    min-height: 2.45em;
    text-shadow:
      0 0.04em 0.12em rgba(0, 0, 0, 0.22),
      0 0 1rem rgba(255, 255, 255, 0.04);
  }

  .landing-page .col-left {
    position: relative;
    left: 0%;
    padding: 0;
    overflow: hidden;
    will-change: transform;
  }

  :global(.left-glass) {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 4.5em 3.5vw 3em 3.5vw;
    background:
      linear-gradient(180deg, rgba(37, 37, 37, 0.14), rgba(0, 0, 0, 0.08)),
      radial-gradient(circle at top left, rgba(0, 0, 0, 0.18), transparent 32%);
    backdrop-filter: blur(18px) saturate(135%);
    -webkit-backdrop-filter: blur(18px) saturate(135%);
    border-right: 1px solid rgba(255, 255, 255, 0.14);
    box-shadow:
      inset -1px 0 0 rgba(255, 255, 255, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.22),
      0 1.5rem 4rem rgba(0, 0, 0, 0.12);
  }

  :global(.left-glass .copy) {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    width: min(100%, 34rem);
    gap: 1.2rem;
    padding-left: 1.5rem;
    will-change: transform, opacity, filter;
  }

  :global(.left-glass .copy::before) {
    content: "";
    position: absolute;
    top: 0.45rem;
    left: 0;
    width: 1px;
    height: min(19rem, 100%);
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.85) 0%,
      rgba(170, 170, 170, 0.24) 45%,
      rgba(77, 77, 77, 0) 100%
    );
  }

  :global(.left-glass .copy > *) {
    position: relative;
  }

  :global(.left-glass .header) {
    font-family: var(--font-melodrame);
    font-size: clamp(3rem, 4.8vw, 5.2rem);
    line-height: 0.88;
    letter-spacing: 0.015em;
    text-transform: none;
    color: rgba(255, 248, 239, 0.96);
    padding: 0;
    margin: 0;
    border: none;
    max-width: 8ch;
    min-height: 1.95em;
    text-shadow: 0 0.04em 0.16em rgba(0, 0, 0, 0.18);
  }

  :global(.left-glass .sub-header) {
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    text-align: left;
    color: rgba(255, 255, 255, 0.68);
    min-height: 1.3em;
  }

  :global(.left-glass .info) {
    max-width: 30ch;
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(1rem, 1.05vw, 1.12rem);
    font-weight: 400;
    line-height: 1.55;
    text-align: left;
    color: rgba(255, 255, 255, 0.8);
    margin-top: 0.35rem;
    min-height: 4.8em;
  }

  /* 900px Breakpoint */
  @media (max-width: 900px) {
    .landing-page {
      overflow: clip;
      --hero-nav-offset: 5rem;
    }

    .landing-page .container {
      overflow: visible;
      display: block;
    }

    .landing-page .container::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(
        180deg,
        rgba(7, 7, 7, 0.18) 0%,
        rgba(7, 7, 7, 0.42) 54%,
        rgba(7, 7, 7, 0.74) 100%
      );
      pointer-events: none;
    }

    .landing-page .hero-img {
      min-height: 100%;
      opacity: 0.9;
    }

    .landing-page .cols {
      position: relative;
      z-index: 1;
      width: min(100%, 42rem);
      margin-inline: auto;
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      align-content: end;
      justify-content: stretch;
      gap: 1.5rem;
      min-height: 100vh;
      min-height: 100svh; /* Locks mobile height */
      padding: calc(env(safe-area-inset-top, 0px) + var(--hero-nav-offset))
        1.25rem calc(env(safe-area-inset-bottom, 0px) + 1.5rem);
    }

    .landing-page .col {
      width: 100%;
      min-height: auto;
    }

    .landing-page .col-left,
    .landing-page .col-right {
      padding: 0;
    }

    .landing-page .col-left {
      display: flex;
      align-items: flex-start;
      width: 100%;
    }

    :global(.left-glass) {
      width: min(100%, 34rem);
      justify-content: flex-start;
      align-items: stretch;
      padding: 1.8rem 1.5rem;
      min-height: clamp(14rem, 34svh, 20rem);
      background: linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.08) 0%,
        rgba(255, 255, 255, 0.02) 100%
      );
      backdrop-filter: blur(12px) saturate(140%);
      -webkit-backdrop-filter: blur(12px) saturate(140%);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-top: 1px solid rgba(255, 255, 255, 0.25);
      border-left: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 1.75rem;
      box-shadow:
        inset 0 1px 1px rgba(255, 255, 255, 0.15),
        0 1rem 3rem rgba(0, 0, 0, 0.35);
    }

    :global(.left-glass .copy) {
      width: 100%;
      align-items: flex-start;
      padding-left: 1.25rem;
      gap: 0.8rem;
    }

    :global(.left-glass .copy::before) {
      top: 0.35rem;
      height: calc(100% - 0.35rem);
    }

    :global(.left-glass .header) {
      font-size: clamp(2.4rem, 11vw, 3.8rem);
      line-height: 0.95;
      letter-spacing: 0.04em;
      text-wrap: balance;
    }

    :global(.left-glass .sub-header) {
      font-size: 0.8rem;
      letter-spacing: 0.14em;
    }

    :global(.left-glass .info) {
      max-width: 30ch;
      font-size: 1.05rem;
      line-height: 1.55;
    }

    .landing-page .col-right {
      display: flex;
      align-items: center;
      justify-content: flex-start;
      padding: 1rem 0 0.5rem;
      text-align: left;
    }

    .landing-page .col-right .right-copy {
      position: relative;
      width: min(24rem, 100%);
      min-height: clamp(10rem, 22svh, 14rem);
      margin-inline: 0;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      justify-content: flex-end;
      gap: 0.8rem;
    }

    .landing-page .col-right .header {
      width: 100%;
      font-size: clamp(3.8rem, 15vw, 6rem);
      line-height: 0.85;
      letter-spacing: -0.01em;
      text-wrap: balance;
      min-height: 2.7em;
      text-align: left;
      text-shadow:
        0 0.1em 0.25em rgba(0, 0, 0, 0.4),
        0 0 2rem rgba(255, 255, 255, 0.1);
    }
  }

  .landing-page .block {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    min-height: 100vh;
    min-height: 100svh;
    pointer-events: none;
  }

  .landing-page .loader-text-wrapper,
  .landing-page .revealer,
  .landing-page .pre-loader {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    min-height: 100vh;
    min-height: 100svh;
    will-change: transform, opacity;
  }

  .landing-page .loader-text-wrapper {
    background: #000;
  }

  .landing-page .revealer {
    background: #ffffff;
  }

  .landing-page .pre-loader {
    background: #fff;
  }

  @media (max-width: 1000px) {
    .header,
    .footer {
      position: relative;
      width: 100%;
      height: 4rem;
      text-align: left;
    }
  }

  .landing-page .loader-text {
    font-family: var(--font-melodrame);
    font-size: 50px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: #fff;
    text-align: center;
    padding: 0 1rem;
  }

  .landing-page .loader-text .letter {
    display: inline-block;
    line-height: 1em;
    will-change: transform, opacity;
  }

  .landing-page .loader-wrapper {
    position: relative;
    width: 10px;
    height: 140px;
    background: rgb(240, 240, 240);
    border-radius: 4px;
    overflow: hidden;
    transform: rotate(45deg);
    will-change: transform;
  }

  .landing-page .loader {
    position: absolute;
    top: 0;
    width: 100%;
    height: 100%;
    background: rgb(251, 0, 255);
    background: linear-gradient(
      180deg,
      rgba(251, 0, 255, 1) 0%,
      rgba(253, 29, 29, 1) 100%
    );
    will-change: top;
  }
  @media (max-width: 640px) {
    .landing-page .cols {
      gap: 1rem;
      padding: calc(env(safe-area-inset-top, 0px) + 4.5rem) 1rem
        calc(env(safe-area-inset-bottom, 0px) + 2rem);
    }

    .landing-page .col-right {
      justify-content: flex-start;
    }

    .landing-page .col-right .right-copy {
      align-items: center;
      margin-inline: 0;
      width: 100%;
      min-height: 9.5rem;
    }

    .landing-page .col-right .header {
      text-align: center;
      font-size: clamp(6rem, 7vw, 6rem);
      line-height: 0.85;
      width: auto;
      max-width: 100%;
      min-height: 2.75em;
    }

    :global(.left-glass) {
      min-height: clamp(13.5rem, 34svh, 20rem);
      border-radius: 1.5rem;
      padding: 1.5rem;
    }

    :global(.left-glass .header) {
      font-size: clamp(2.2rem, 12vw, 3.8rem); /* Prevent clipping */
      min-height: 2.1em;
      margin-bottom: 0.5rem;
    }

    :global(.left-glass .info) {
      max-width: 100%;
      font-size: 0.95rem;
      line-height: 1.5;
      min-height: 4.6em;
    }

    .landing-page .loader-text {
      font-size: clamp(1.2rem, 6vw, 2.4rem);
      letter-spacing: 0.09em;
      word-break: break-word;
    }

    .landing-page .loader-wrapper {
      height: 90px;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { runPageScript } from "../lib/client/spa";

  const initLandingPage = () =>
    runPageScript("landing-page", ({ onCleanup }) => {
      const isMobile = window.matchMedia("(max-width: 900px)").matches;
      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;
      const heroScope = document.querySelector(".landing-page");
      const heroTextTargets = Array.from(
        document.querySelectorAll<HTMLElement>(
          [
            ".landing-page .left-glass .header",
            ".landing-page .left-glass .sub-header",
            ".landing-page .left-glass .info",
            ".landing-page .col-right .header",
          ].join(", "),
        ),
      );
      const textWrapper = document.querySelector(".landing-page .loader-text");
      let revealCleanup: (() => void) | undefined;
      const waitForStableHero = async () => {
        const fontReady =
          "fonts" in document
            ? document.fonts.ready.catch(() => undefined)
            : Promise.resolve();

        const settleDelay = new Promise((resolve) =>
          window.setTimeout(
            resolve,
            prefersReducedMotion ? 80 : isMobile ? 420 : 560,
          ),
        );

        await Promise.race([
          Promise.all([fontReady, settleDelay]),
          new Promise((resolve) =>
            window.setTimeout(
              resolve,
              prefersReducedMotion ? 180 : isMobile ? 950 : 1400,
            ),
          ),
        ]);
      };

      const runHeroTextReveal = async () => {
        if (!heroScope) return;

        const { initTextReveal } = await import("../lib/client/textReveal");
        revealCleanup = await initTextReveal(heroScope, [
          {
            selector: ".left-glass .header",
            mode: "lines",
            scroll: false,
            duration: isMobile ? 0.92 : 1.08,
            stagger: isMobile ? 0.1 : 0.12,
          },
          {
            selector: ".left-glass .sub-header",
            mode: "fade",
            scroll: false,
            delay: isMobile ? 0.1 : 0.14,
            duration: isMobile ? 0.7 : 0.8,
            y: 18,
          },
          {
            selector: ".left-glass .info",
            mode: "fade",
            scroll: false,
            delay: isMobile ? 0.2 : 0.26,
            duration: isMobile ? 0.82 : 0.95,
            y: 22,
          },
          {
            selector: ".col-right .header",
            mode: "lines",
            scroll: false,
            delay: isMobile ? 0.16 : 0.2,
            duration: isMobile ? 0.96 : 1.14,
            stagger: isMobile ? 0.1 : 0.12,
          },
        ]);
      };

      if (!prefersReducedMotion) {
        heroTextTargets.forEach((element) => {
          element.style.visibility = "hidden";
        });
      }

      if (textWrapper) {
        textWrapper.innerHTML =
          textWrapper.textContent?.replace(
            /\S/g,
            "<span class='letter'>$&</span>",
          ) || "";

        if (!prefersReducedMotion) {
          gsap.fromTo(
            ".landing-page .loader-text .letter",
            {
              x: isMobile ? 20 : 40,
              opacity: 0,
            },
            {
              x: 0,
              opacity: 1,
              ease: "expo.out",
              duration: isMobile ? 0.7 : 1.2,
              delay: isMobile ? 0.6 : 2.4,
              stagger: 0.024,
              overwrite: "auto",
            },
          );
        } else {
          gsap.set(".landing-page .loader-text .letter", {
            x: 0,
            opacity: 1,
          });
        }
      }

      gsap.from(".landing-page .loader-wrapper", {
        scale: 0.8,
        ease: "power1.inOut",
        duration: prefersReducedMotion ? 0.2 : isMobile ? 1 : 2,
      });

      gsap.from(".landing-page .loader", {
        top: "100%",
        ease: "power2.inOut",
        duration: prefersReducedMotion ? 0.2 : isMobile ? 1.2 : 2,
      });

      void (async () => {
        await waitForStableHero();

        const loaderDelay = prefersReducedMotion ? 0.05 : isMobile ? 0.12 : 0.2;
        const revealDelay = prefersReducedMotion
          ? 0.14
          : isMobile
            ? 0.28
            : 0.45;
        const contentDelay = prefersReducedMotion
          ? 0.24
          : isMobile
            ? 0.54
            : 0.8;

        gsap.to(".landing-page .loader-wrapper, .landing-page .pre-loader", {
          scale: 1.5,
          opacity: 0,
          display: "none",
          ease: "power2.inOut",
          delay: loaderDelay,
          duration: prefersReducedMotion ? 0.15 : isMobile ? 0.45 : 0.7,
        });

        gsap.from(".landing-page .revealer", {
          width: "0%",
          ease: "power2.inOut",
          delay: revealDelay,
          duration: prefersReducedMotion ? 0.15 : isMobile ? 0.42 : 0.72,
        });

        gsap.to(".landing-page .revealer", {
          left: "100%",
          ease: "power2.inOut",
          delay: revealDelay + (isMobile ? 0.38 : 0.65),
          duration: prefersReducedMotion ? 0.15 : isMobile ? 0.38 : 0.56,
        });

        gsap.to(".landing-page .loader-text-wrapper", {
          opacity: 0,
          display: "none",
          ease: "power3.inOut",
          delay: revealDelay + (isMobile ? 0.26 : 0.5),
          duration: 0.2,
        });

        gsap.from(".landing-page .col-left", {
          left: "-110%",
          ease: "power2.inOut",
          delay: contentDelay,
          duration: prefersReducedMotion ? 0.2 : isMobile ? 0.6 : 0.82,
        });

        gsap.from(".landing-page .left-glass .copy", {
          x: "-28",
          opacity: 0,
          filter: "blur(8px)",
          ease: "power3.out",
          delay: contentDelay + 0.08,
          duration: prefersReducedMotion ? 0.24 : isMobile ? 0.56 : 0.82,
        });

        gsap.from(".landing-page .col-right .right-copy", {
          x: "24",
          opacity: 0,
          filter: "blur(8px)",
          ease: "power3.out",
          delay: contentDelay + 0.12,
          duration: prefersReducedMotion ? 0.24 : isMobile ? 0.6 : 0.9,
        });

        if (prefersReducedMotion) {
          heroTextTargets.forEach((element) => {
            element.style.visibility = "visible";
          });
          return;
        }

        const delayedReveal = gsap.delayedCall(contentDelay + 0.14, () => {
          void runHeroTextReveal();
        });

        onCleanup(() => delayedReveal.kill());
      })();

      onCleanup(() => {
        revealCleanup?.();
        gsap.killTweensOf(".landing-page *");
      });
    });

  let hasBootedLandingPage = false;
  let hasSeenInitialAstroPageLoad = false;

  const bootLandingPage = () => {
    hasBootedLandingPage = true;
    void initLandingPage();
  };

  document.addEventListener("astro:page-load", () => {
    if (!hasSeenInitialAstroPageLoad) {
      hasSeenInitialAstroPageLoad = true;

      if (hasBootedLandingPage) return;
    }

    bootLandingPage();
  });

  if (document.readyState === "loading") {
    document.addEventListener(
      "DOMContentLoaded",
      () => {
        if (!hasBootedLandingPage) {
          bootLandingPage();
        }
      },
      { once: true },
    );
  } else {
    bootLandingPage();
  }
</script>
