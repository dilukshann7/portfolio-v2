---
import Navigation from "./Navigation.astro";
import ColorBends from "./ui/ColorBends";
---

<div class="landing-page" id="home">
  <Navigation />
  <div class="hero-img">
    <ColorBends
      client:load
      colors={[]}
      rotation={0}
      speed={0.2}
      scale={1}
      frequency={1}
      warpStrength={1}
      mouseInfluence={1}
      parallax={0.5}
      noise={0.1}
      transparent
      autoRotate={0}
      globalPointer
    />
  </div>
  <div class="container">
    <div class="cols">
      <div class="col col-left">
        <div class="left-glass">
          <div class="copy">
            <div class="header">Dilukshan Niranjan</div>
            <div class="sub-header">CS & SE Undergrad from Sri Lanka</div>
            <div class="info">
              Fullstack Developer & AI Engineer passionate about building
              scalable web applications and intelligent systems.
            </div>
          </div>
        </div>
      </div>
      <div class="col col-right">
        <div class="right-copy">
          <div class="header">
            Building
            <br />
            scalable
            <br />
            AI systems
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="loader-text-wrapper block">
    <h1 class="loader-text">Welcome to Dilukshan's Portfolio</h1>
  </div>
  <div class="revealer"></div>
  <div class="pre-loader block">
    <div class="loader-wrapper">
      <div class="loader"></div>
    </div>
  </div>
</div>

<style>
  .landing-page {
    position: relative;
    width: 100%;
    min-height: 100vh;
    min-height: 100svh;
    min-height: 100dvh;
    overflow: hidden;
    background-color: #000;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  .landing-page .container {
    position: relative;
    width: 100%;
    min-height: 100vh;
    min-height: 100svh;
    min-height: 100dvh;
    overflow: hidden;
  }

  .landing-page .hero-img {
    position: absolute;
    width: 100%;
    min-height: 100vh;
    min-height: 100svh;
    min-height: 100dvh;
    inset: 0;
    overflow: hidden;
  }

  .landing-page .hero-img :global(.color-bends-container) {
    width: 100%;
    height: 100%;
  }

  .landing-page .cols {
    width: 100%;
    display: flex;
  }

  .landing-page .col {
    width: 50%;
    min-height: 100vh;
    min-height: 100svh;
    min-height: 100dvh;
  }

  .landing-page .col-right {
    position: relative;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    text-align: left;
    color: #f7f1e8;
    border: none;
    padding: 4.5em 4vw 3em 4vw;
  }

  .landing-page .col-right .right-copy {
    position: relative;
    width: min(34rem, 100%);
    margin-left: auto;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }

  .landing-page .col-right .header {
    width: min(8ch, 100%);
    font-family: var(--font-melodrame);
    font-size: clamp(5rem, 8.3vw, 9rem);
    font-weight: 400;
    line-height: 0.82;
    letter-spacing: 0.012em;
    text-transform: none;
    text-wrap: balance;
    color: rgba(255, 246, 238, 0.98);
    text-shadow:
      0 0.04em 0.12em rgba(0, 0, 0, 0.22),
      0 0 1rem rgba(255, 255, 255, 0.04);
  }

  .landing-page .col-left {
    position: relative;
    left: 0%;
    padding: 0;
    overflow: hidden;
  }

  :global(.left-glass) {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 4.5em 3.5vw 3em 3.5vw;
    background:
      linear-gradient(180deg, rgba(37, 37, 37, 0.14), rgba(0, 0, 0, 0.08)),
      radial-gradient(circle at top left, rgba(0, 0, 0, 0.18), transparent 32%);
    backdrop-filter: blur(18px) saturate(135%);
    -webkit-backdrop-filter: blur(18px) saturate(135%);
    border-right: 1px solid rgba(255, 255, 255, 0.14);
    box-shadow:
      inset -1px 0 0 rgba(255, 255, 255, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.22),
      0 1.5rem 4rem rgba(0, 0, 0, 0.12);
  }

  :global(.left-glass .copy) {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    width: min(100%, 34rem);
    gap: 1.2rem;
    padding-left: 1.5rem;
  }

  :global(.left-glass .copy::before) {
    content: "";
    position: absolute;
    top: 0.45rem;
    left: 0;
    width: 1px;
    height: min(19rem, 100%);
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.85) 0%,
      rgba(170, 170, 170, 0.24) 45%,
      rgba(77, 77, 77, 0) 100%
    );
  }

  :global(.left-glass .copy > *) {
    position: relative;
  }

  :global(.left-glass .header) {
    font-family: var(--font-melodrame);
    font-size: clamp(3rem, 4.8vw, 5.2rem);
    line-height: 0.88;
    letter-spacing: 0.015em;
    text-transform: none;
    color: rgba(255, 248, 239, 0.96);
    padding: 0;
    margin: 0;
    border: none;
    max-width: 8ch;
    text-shadow: 0 0.04em 0.16em rgba(0, 0, 0, 0.18);
  }

  :global(.left-glass .sub-header) {
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    text-align: left;
    color: rgba(255, 255, 255, 0.68);
  }

  :global(.left-glass .info) {
    max-width: 30ch;
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(1rem, 1.05vw, 1.12rem);
    font-weight: 400;
    line-height: 1.55;
    text-align: left;
    color: rgba(255, 255, 255, 0.8);
    margin-top: 0.35rem;
  }

  @media (max-width: 900px) {
    .landing-page {
      min-height: 100vh;
      min-height: 100svh;
      min-height: 100dvh;
      overflow: clip;
    }

    .landing-page .container {
      min-height: 100vh;
      min-height: 100svh;
      min-height: 100dvh;
      overflow: visible;
    }

    .landing-page .container::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(
        180deg,
        rgba(7, 7, 7, 0.18) 0%,
        rgba(7, 7, 7, 0.42) 54%,
        rgba(7, 7, 7, 0.74) 100%
      );
      pointer-events: none;
    }

    .landing-page .hero-img {
      min-height: 100%;
      opacity: 0.9;
    }

    .landing-page .cols {
      position: relative;
      z-index: 1;
      flex-direction: column;
      justify-content: flex-start;
      gap: 1.25rem;
      min-height: 100vh;
      min-height: 100svh;
      min-height: 100dvh;
      padding: calc(env(safe-area-inset-top, 0px) + 6.5rem) 1.25rem
        calc(env(safe-area-inset-bottom, 0px) + 1.5rem);
    }

    .landing-page .col {
      width: 100%;
      min-height: auto;
    }

    .landing-page .col-left,
    .landing-page .col-right {
      min-height: auto;
      padding: 0;
    }

    .landing-page .col-left {
      display: flex;
      align-items: flex-start;
    }

    :global(.left-glass) {
      width: min(100%, 34rem);
      min-height: clamp(18rem, 44vh, 28rem);
      justify-content: flex-start;
      align-items: stretch;
      padding: 1.4rem 1.25rem 1.25rem;
      background:
        linear-gradient(180deg, rgba(18, 18, 18, 0.22), rgba(0, 0, 0, 0.1)),
        radial-gradient(circle at top left, rgba(0, 0, 0, 0.2), transparent 38%);
      backdrop-filter: blur(12px) saturate(120%);
      -webkit-backdrop-filter: blur(12px) saturate(120%);
      border: 1px solid rgba(255, 255, 255, 0.14);
      border-radius: 1.75rem;
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.12),
        0 1.5rem 3rem rgba(0, 0, 0, 0.2);
    }

    :global(.left-glass .copy) {
      width: 100%;
      align-items: flex-start;
      padding-left: 1.1rem;
      gap: 0.8rem;
    }

    :global(.left-glass .copy::before) {
      top: 0.35rem;
      height: calc(100% - 0.35rem);
    }

    :global(.left-glass .header) {
      font-size: clamp(3.15rem, 13vw, 4.8rem);
      line-height: 0.92;
      max-width: 10ch;
      text-wrap: balance;
    }

    :global(.left-glass .sub-header) {
      font-size: 0.8rem;
      letter-spacing: 0.14em;
    }

    :global(.left-glass .info) {
      max-width: 30ch;
      font-size: 1.05rem;
      line-height: 1.55;
    }

    .landing-page .col-right {
      align-items: center;
      justify-content: flex-end;
      padding-top: 0;
    }

    .landing-page .col-right .right-copy {
      width: min(22rem, 100%);
      margin-inline: auto;
      align-items: center;
      gap: 0.75rem;
    }

    .landing-page .col-right .header {
      width: min(8ch, 100%);
      font-size: clamp(3.2rem, 14vw, 5.1rem);
      line-height: 0.9;
      text-wrap: balance;
      text-align: center;
    }
  }

  .landing-page .block {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    min-height: 100vh;
    min-height: 100svh;
    min-height: 100dvh;
  }

  .landing-page .loader-text-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    background: #000;
  }

  .landing-page .loader-text {
    font-family: var(--font-melodrame);
    font-size: 50px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: #fff;
  }

  .landing-page .loader-text .letter {
    display: inline-block;
    line-height: 1em;
  }

  .landing-page .revealer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    min-height: 100vh;
    min-height: 100svh;
    min-height: 100dvh;
    background: #ffffff;
  }

  .landing-page .pre-loader {
    position: absolute;
    top: 0;
    left: 0;
    background: #fff;
  }

  .landing-page .loader-wrapper {
    position: relative;
    width: 10px;
    height: 140px;
    background: rgb(240, 240, 240);
    border-radius: 4px;
    overflow: hidden;
    transform: rotate(45deg);
  }

  .landing-page .loader {
    position: absolute;
    top: 0;
    width: 100%;
    height: 100%;
    background: rgb(251, 0, 255);
    background: linear-gradient(
      180deg,
      rgba(251, 0, 255, 1) 0%,
      rgba(253, 29, 29, 1) 100%
    );
  }

  @media (max-width: 640px) {
    .landing-page .cols {
      gap: 1rem;
      padding: calc(env(safe-area-inset-top, 0px) + 6rem) 1rem
        calc(env(safe-area-inset-bottom, 0px) + 1.25rem);
    }

    .landing-page .col-right {
      height: 20svh;
    }

    :global(.left-glass) {
      min-height: clamp(17rem, 42vh, 22rem);
      border-radius: 1.4rem;
    }

    :global(.left-glass .copy) {
      padding-left: 1rem;
      gap: 0.72rem;
    }

    :global(.left-glass .header) {
      font-size: clamp(2.8rem, 14vw, 4.1rem);
      max-width: 0ch;
      margin-bottom: 15px;
    }

    :global(.left-glass .sub-header) {
      font-size: 0.76rem;
      letter-spacing: 0.12em;
    }

    :global(.left-glass .info) {
      max-width: 26ch;
      font-size: 1rem;
    }

    .landing-page .col-right .header {
      width: min(7.5ch, 100%);
      font-size: clamp(5rem, 20vw, 5.6rem);
    }

    .landing-page .loader-text {
      font-size: clamp(2rem, 9vw, 2.8rem);
      letter-spacing: 0.14em;
      text-align: center;
      padding-inline: 1rem;
    }

    .landing-page .loader-wrapper {
      height: 108px;
    }
  }
</style>

<script>
  import { gsap } from "gsap";

  const isMobile = window.matchMedia("(max-width: 900px)").matches;
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;
  const heroScope = document.querySelector(".landing-page");
  const heroTextTargets = Array.from(
    document.querySelectorAll<HTMLElement>(
      [
        ".landing-page .left-glass .header",
        ".landing-page .left-glass .sub-header",
        ".landing-page .left-glass .info",
        ".landing-page .col-right .header",
      ].join(", "),
    ),
  );
  const textWrapper = document.querySelector(".landing-page .loader-text");

  const runHeroTextReveal = async () => {
    if (!heroScope) return;

    const { initTextReveal } = await import("../lib/client/textReveal");

    await initTextReveal(heroScope, [
      {
        selector: ".left-glass .header",
        mode: "lines",
        scroll: false,
        duration: isMobile ? 0.92 : 1.08,
        stagger: isMobile ? 0.1 : 0.12,
      },
      {
        selector: ".left-glass .sub-header",
        mode: "fade",
        scroll: false,
        delay: isMobile ? 0.1 : 0.14,
        duration: isMobile ? 0.7 : 0.8,
        y: 18,
      },
      {
        selector: ".left-glass .info",
        mode: "fade",
        scroll: false,
        delay: isMobile ? 0.2 : 0.26,
        duration: isMobile ? 0.82 : 0.95,
        y: 22,
      },
      {
        selector: ".col-right .header",
        mode: "lines",
        scroll: false,
        delay: isMobile ? 0.16 : 0.2,
        duration: isMobile ? 0.96 : 1.14,
        stagger: isMobile ? 0.1 : 0.12,
      },
    ]);
  };

  if (!prefersReducedMotion) {
    heroTextTargets.forEach((element) => {
      element.style.visibility = "hidden";
    });
  }

  if (textWrapper) {
    textWrapper.innerHTML =
      textWrapper.textContent?.replace(
        /\S/g,
        "<span class='letter'>$&</span>",
      ) || "";

    if (!prefersReducedMotion) {
      gsap.fromTo(
        ".landing-page .loader-text .letter",
        {
          x: isMobile ? 20 : 40,
          opacity: 0,
        },
        {
          x: 0,
          opacity: 1,
          ease: "expo.out",
          duration: isMobile ? 0.7 : 1.2,
          delay: isMobile ? 0.9 : 2.4,
          stagger: 0.024,
          overwrite: "auto",
        },
      );
    } else {
      gsap.set(".landing-page .loader-text .letter", {
        x: 0,
        opacity: 1,
      });
    }
  }

  const loaderDelay = prefersReducedMotion ? 0.15 : isMobile ? 1 : 2;
  const revealDelay = prefersReducedMotion ? 0.3 : isMobile ? 1.35 : 3;
  const contentDelay = prefersReducedMotion ? 0.45 : isMobile ? 1.85 : 4.5;

  gsap.from(".landing-page .loader-wrapper", {
    scale: 0.8,
    ease: "power1.inOut",
    duration: prefersReducedMotion ? 0.2 : isMobile ? 1 : 2,
  });

  gsap.from(".landing-page .loader", {
    top: "100%",
    ease: "power3.inOut",
    duration: prefersReducedMotion ? 0.2 : isMobile ? 1 : 2,
  });

  gsap.to(".landing-page .loader-wrapper, .landing-page .pre-loader", {
    scale: 1.5,
    opacity: 0,
    display: "none",
    ease: "power3.inOut",
    delay: loaderDelay,
    duration: prefersReducedMotion ? 0.15 : isMobile ? 0.5 : 1,
  });

  gsap.from(".landing-page .revealer", {
    width: "0%",
    ease: "power3.inOut",
    delay: revealDelay,
    duration: prefersReducedMotion ? 0.15 : isMobile ? 0.5 : 1,
  });

  gsap.to(".landing-page .revealer", {
    left: "100%",
    ease: "power3.inOut",
    delay: revealDelay + (isMobile ? 0.45 : 1),
    duration: prefersReducedMotion ? 0.15 : isMobile ? 0.45 : 0.8,
  });

  gsap.to(".landing-page .loader-text-wrapper", {
    opacity: 0,
    display: "none",
    ease: "power3.inOut",
    delay: revealDelay + (isMobile ? 0.4 : 1),
    duration: 0.2,
  });

  gsap.from(".landing-page .col-left", {
    left: "-110%",
    ease: "power3.inOut",
    delay: contentDelay,
    duration: prefersReducedMotion ? 0.2 : isMobile ? 0.7 : 1,
  });

  gsap.from(".landing-page .col-left .copy > div", {
    x: "-40",
    opacity: 0,
    ease: "power3.inOut",
    delay: contentDelay + 0.2,
    duration: prefersReducedMotion ? 0.2 : isMobile ? 0.8 : 1.5,
    stagger: {
      amount: isMobile ? 0.18 : 0.3,
    },
  });

  gsap.from(".landing-page .col-right .header", {
    x: "-20",
    opacity: 0,
    ease: "power3.inOut",
    delay: contentDelay + 0.45,
    duration: prefersReducedMotion ? 0.2 : isMobile ? 0.7 : 1,
  });
</script>
