---
import LightRays from "./ui/LightRays";

const techStack = [
  "Next.js",
  "Astro",
  "SvelteKit",
  "TypeScript",
  "Python",
  "C/C++",
];
const socialLinks = [
  {
    label: "GitHub",
    href: "https://github.com/dilukshann7",
  },
  {
    label: "LinkedIn",
    href: "https://linkedin.com/in/dilukshann7",
  },
  {
    label: "X / Twitter",
    href: "https://x.com/silknye",
  },
];
---

<div class="landing-page" id="home">
  <div class="hero-img">
    <LightRays
      client:load
      raysOrigin="top-center"
      raysColor="#ffffff"
      raysSpeed={1}
      lightSpread={0.5}
      rayLength={3}
      followMouse={true}
      mouseInfluence={0.1}
      noiseAmount={0}
      distortion={0}
      className="custom-rays"
      pulsating={false}
      fadeDistance={1}
      saturation={1}
    />
  </div>

  <div class="container">
    <div class="central-layout">
      <div class="central-glass">
        <div class="copy">
          <h1 class="header hero-copy">Dilukshan N</h1>
          <div class="sub-header hero-copy">
            Fullstack Developer & AI Engineer
          </div>
          <div class="info hero-copy">
            Building scalable web applications, grounded AI systems, and
            polished interfaces meant to feel intuitive on first use.
          </div>
        </div>

        <div class="hero-actions">
          <a href="#projects" class="hero-link hero-link-primary">
            Explore Projects
          </a>
          <a href="/contact/" class="hero-link hero-link-secondary">
            Start a Project
          </a>
        </div>

        <div class="hero-socials" aria-label="Social links">
          {
            socialLinks.map((link) => (
              <a href={link.href} target="_blank" rel="noreferrer">
                {link.label}
              </a>
            ))
          }
        </div>

        <div class="divider"></div>

        <div class="bottom-stats-container">
          <div class="stack-tags">
            {techStack.map((t) => <span class="tag">{t}</span>)}
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="scroll-hint">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</div>

<style>
  .landing-page {
    position: relative;
    width: 100%;
    height: 100dvh;
    max-height: 100dvh;
    overflow: hidden;
    background-color: #000;
  }

  .landing-page .container {
    position: absolute;
    inset: 0;
    padding: 0;
    margin: 0;
    box-sizing: border-box;
    z-index: 10;
  }

  .landing-page .hero-img {
    position: absolute;
    width: 100%;
    height: 100%;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 1;
  }

  .landing-page .hero-img :global(.color-bends-container) {
    width: 100%;
    height: 100%;
  }

  .central-layout {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    min-width: 100vw;
    padding: 1.5rem;
    box-sizing: border-box;
    will-change: transform, opacity;
  }

  :global(.central-glass) {
    position: relative;
    width: 100%;
    max-width: min(calc(100vw - 3rem), 52rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 3rem 2.5rem;
    border-radius: 2rem;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.04) 0%,
      rgba(255, 255, 255, 0.01) 100%
    );
    backdrop-filter: blur(16px) saturate(140%);
    -webkit-backdrop-filter: blur(16px) saturate(140%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow:
      inset 0 1px 1px rgba(255, 255, 255, 0.15),
      0 2rem 5rem rgba(0, 0, 0, 0.4);
    will-change: transform, opacity, filter;
  }

  :global(.central-glass .copy) {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    max-width: 42rem;
  }

  :global(.central-glass .header) {
    font-family: var(--font-melodrame);
    font-size: clamp(3.5rem, 6.5vw, 6rem);
    line-height: 0.9;
    letter-spacing: 0.015em;
    text-transform: none;
    color: rgba(255, 248, 239, 0.96);
    padding: 0;
    margin: 0;
    text-shadow: 0 0.04em 0.16em rgba(0, 0, 0, 0.18);
  }

  :global(.central-glass .sub-header) {
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.68);
  }

  :global(.central-glass .info) {
    max-width: 46ch;
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(1.05rem, 1.35vw, 1.25rem);
    font-weight: 400;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.8);
    margin-top: 0.2rem;
  }

  .landing-page.landing-copy-pending .hero-copy {
    opacity: 0;
  }

  :global(.central-glass .hero-actions) {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    margin-top: 2rem;
  }

  :global(.central-glass .hero-link) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0.8rem 1.6rem;
    border-radius: 999px;
    text-decoration: none;
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition:
      transform 220ms ease,
      background-color 220ms ease,
      border-color 220ms ease,
      color 220ms ease;
  }

  :global(.central-glass .hero-link:hover) {
    transform: translateY(-2px);
  }

  :global(.central-glass .hero-link-primary) {
    background: rgba(255, 247, 238, 0.94);
    color: #111;
    box-shadow: 0 0.75rem 2rem rgba(0, 0, 0, 0.15);
  }

  :global(.central-glass .hero-link-secondary) {
    color: rgba(255, 248, 239, 0.94);
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.06);
  }

  .hero-socials {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.7rem 1rem;
    margin-top: 1.5rem;
  }

  .hero-socials a {
    color: rgba(255, 255, 255, 0.68);
    text-decoration: none;
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition:
      color 220ms ease,
      transform 220ms ease;
  }

  .hero-socials a:hover {
    color: rgba(255, 248, 239, 0.94);
    transform: translateY(-1px);
  }

  .divider {
    width: 100%;
    max-width: 80%;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.1),
      transparent
    );
    margin: 1rem 0;
  }

  .bottom-stats-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    width: 100%;
  }

  .stack-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.4rem;
    max-width: 36rem;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.7rem;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.6);
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: background 200ms ease;
  }

  .tag:hover {
    background: rgba(255, 255, 255, 0.08);
  }

  .scroll-hint {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    color: rgba(255, 255, 255, 0.3);
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    z-index: 20;
    pointer-events: none;
  }

  .scroll-line {
    width: 1px;
    height: 2rem;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.45) 0%,
      rgba(255, 255, 255, 0) 100%
    );
    transform-origin: top;
    animation: scrollDrop 2s ease-in-out infinite;
  }

  @keyframes scrollDrop {
    0% {
      transform: scaleY(0);
      opacity: 1;
    }
    50% {
      transform: scaleY(1);
      opacity: 1;
    }
    100% {
      transform: scaleY(1);
      transform-origin: bottom;
      opacity: 0;
    }
  }

  @media (max-width: 900px) {
    .central-layout {
      padding: 1rem;
    }

    :global(.central-glass) {
      padding: 2.5rem 1.5rem;
      border-radius: 1.5rem;
    }

    :global(.central-glass .header) {
      font-size: clamp(3rem, 10vw, 4.4rem);
    }
  }

  @media (max-width: 640px) {
    :global(.central-glass .hero-actions) {
      flex-direction: column;
      width: 100%;
    }

    :global(.central-glass .hero-link) {
      width: 100%;
    }

    .hero-socials {
      gap: 0.6rem 0.9rem;
    }

    .divider {
      margin: 1.5rem 0;
      max-width: 100%;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { runPageScript } from "../lib/client/spa";

  const initLandingPage = () =>
    runPageScript("landing-page", ({ onCleanup }) => {
      const isMobile = window.matchMedia("(max-width: 900px)").matches;
      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;
      const heroScope = document.querySelector(".landing-page");
      const textWrapper = document.querySelector(".landing-page .loader-text");
      let revealCleanup: (() => void) | undefined;

      const waitForStableHero = async () => {
        const fontReady =
          "fonts" in document
            ? document.fonts.ready.catch(() => undefined)
            : Promise.resolve();
        const settleDelay = new Promise((resolve) =>
          window.setTimeout(
            resolve,
            prefersReducedMotion ? 80 : isMobile ? 420 : 560,
          ),
        );
        await Promise.race([
          Promise.all([fontReady, settleDelay]),
          new Promise((resolve) =>
            window.setTimeout(
              resolve,
              prefersReducedMotion ? 180 : isMobile ? 950 : 1400,
            ),
          ),
        ]);
      };

      const runHeroTextReveal = async () => {
        if (!heroScope) return;

        try {
          const { initTextReveal } = await import("../lib/client/textReveal");

          revealCleanup = await initTextReveal(heroScope, [
            {
              selector: ".central-glass .header",
              mode: "lines",
              scroll: false,
              duration: isMobile ? 0.92 : 1.08,
              stagger: isMobile ? 0.1 : 0.12,
            },
            {
              selector: ".central-glass .sub-header",
              mode: "fade",
              scroll: false,
              delay: isMobile ? 0.1 : 0.14,
              duration: isMobile ? 0.7 : 0.8,
              y: 18,
            },
            {
              selector: ".central-glass .info",
              mode: "fade",
              scroll: false,
              delay: isMobile ? 0.2 : 0.26,
              duration: isMobile ? 0.82 : 0.95,
              y: 22,
            },
          ]);
        } finally {
          heroScope.classList.remove("landing-copy-pending");
        }
      };

      if (!prefersReducedMotion) {
        heroScope?.classList.add("landing-copy-pending");
        gsap.set(".central-glass", { visibility: "hidden" });
      }

      if (textWrapper) {
        textWrapper.innerHTML =
          textWrapper.textContent?.replace(
            /\S/g,
            "<span class='letter'>$&</span>",
          ) || "";
        if (!prefersReducedMotion) {
          gsap.fromTo(
            ".landing-page .loader-text .letter",
            { x: isMobile ? 20 : 40, opacity: 0 },
            {
              x: 0,
              opacity: 1,
              ease: "expo.out",
              duration: isMobile ? 0.7 : 1.2,
              delay: isMobile ? 0.6 : 2.4,
              stagger: 0.024,
              overwrite: "auto",
            },
          );
        } else {
          gsap.set(".landing-page .loader-text .letter", { x: 0, opacity: 1 });
        }
      }

      gsap.from(".landing-page .loader-wrapper", {
        scale: 0.8,
        ease: "power1.inOut",
        duration: prefersReducedMotion ? 0.2 : isMobile ? 1 : 2,
      });
      gsap.from(".landing-page .loader", {
        top: "100%",
        ease: "power2.inOut",
        duration: prefersReducedMotion ? 0.2 : isMobile ? 1.2 : 2,
      });

      void (async () => {
        await waitForStableHero();

        const loaderDelay = prefersReducedMotion ? 0.05 : isMobile ? 0.12 : 0.2;
        const revealDelay = prefersReducedMotion
          ? 0.14
          : isMobile
            ? 0.28
            : 0.45;
        const contentDelay = prefersReducedMotion
          ? 0.24
          : isMobile
            ? 0.54
            : 0.8;

        gsap.to(".landing-page .loader-wrapper, .landing-page .pre-loader", {
          scale: 1.5,
          opacity: 0,
          display: "none",
          ease: "power2.inOut",
          delay: loaderDelay,
          duration: prefersReducedMotion ? 0.15 : isMobile ? 0.45 : 0.7,
        });

        gsap.from(".landing-page .revealer", {
          width: "0%",
          ease: "power2.inOut",
          delay: revealDelay,
          duration: prefersReducedMotion ? 0.15 : isMobile ? 0.42 : 0.72,
        });
        gsap.to(".landing-page .revealer", {
          left: "100%",
          ease: "power2.inOut",
          delay: revealDelay + (isMobile ? 0.38 : 0.65),
          duration: prefersReducedMotion ? 0.15 : isMobile ? 0.38 : 0.56,
        });
        gsap.to(".landing-page .loader-text-wrapper", {
          opacity: 0,
          display: "none",
          ease: "power3.inOut",
          delay: revealDelay + (isMobile ? 0.26 : 0.5),
          duration: 0.2,
        });

        gsap.set(".central-glass", { visibility: "visible" });
        gsap.from(".central-layout", {
          y: 40,
          scale: 0.95,
          opacity: 0,
          ease: "power3.out",
          delay: contentDelay,
          duration: prefersReducedMotion ? 0.2 : isMobile ? 0.6 : 1,
        });

        gsap.from(".central-glass > *:not(.copy)", {
          y: 20,
          opacity: 0,
          filter: "blur(8px)",
          ease: "power3.out",
          stagger: 0.1,
          delay: contentDelay + 0.2,
          duration: prefersReducedMotion ? 0.24 : isMobile ? 0.56 : 0.82,
        });

        gsap.from(".landing-page .scroll-hint", {
          opacity: 0,
          y: 12,
          ease: "power2.out",
          delay: contentDelay + 0.6,
          duration: 0.6,
        });

        if (prefersReducedMotion) return;

        const delayedReveal = gsap.delayedCall(contentDelay + 0.14, () => {
          void runHeroTextReveal();
        });

        onCleanup(() => delayedReveal.kill());
      })();

      onCleanup(() => {
        heroScope?.classList.remove("landing-copy-pending");
        revealCleanup?.();
        gsap.killTweensOf(".landing-page *");
      });
    });

  let hasBootedLandingPage = false;
  let hasSeenInitialAstroPageLoad = false;

  const bootLandingPage = () => {
    hasBootedLandingPage = true;
    void initLandingPage();
  };

  document.addEventListener("astro:page-load", () => {
    if (!hasSeenInitialAstroPageLoad) {
      hasSeenInitialAstroPageLoad = true;
      if (hasBootedLandingPage) return;
    }
    bootLandingPage();
  });

  if (document.readyState === "loading") {
    document.addEventListener(
      "DOMContentLoaded",
      () => {
        if (!hasBootedLandingPage) bootLandingPage();
      },
      { once: true },
    );
  } else {
    bootLandingPage();
  }
</script>
