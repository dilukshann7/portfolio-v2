---
import Navigation from "./Navigation.astro";
import ColorBends from "./ui/ColorBends";
---

<div class="landing-page" id="home">
  <Navigation />
  <div class="hero-img">
    <ColorBends
      client:load
      colors={[]}
      rotation={0}
      speed={0.2}
      scale={1}
      frequency={1}
      warpStrength={1}
      mouseInfluence={1}
      parallax={0.5}
      noise={0.1}
      transparent
      autoRotate={0}
      globalPointer
    />
  </div>
  <div class="container">
    <div class="cols">
      <div class="col col-left">
        <div class="left-glass">
          <div class="copy">
            <div class="header">Dilukshan Niranjan</div>
            <div class="sub-header">CS & SE Undergrad from Sri Lanka</div>
            <div class="info">
              Fullstack Developer & AI Engineer passionate about building
              scalable web applications and intelligent systems.
            </div>
          </div>
        </div>
      </div>
      <div class="col col-right">
        <div class="right-copy">
          <div class="header">
            Building
            <br />
            scalable
            <br />
            AI systems
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="loader-text-wrapper block">
    <h1 class="loader-text">Welcome to Dilukshan's Portfolio</h1>
  </div>
  <div class="revealer"></div>
  <div class="pre-loader block">
    <div class="loader-wrapper">
      <div class="loader"></div>
    </div>
  </div>
</div>

<style>
  .landing-page {
    position: relative;
    width: 100%;
    min-height: 100vh;
    min-height: 100svh;
    min-height: 100dvh;
    overflow: hidden;
    background-color: #000;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  .landing-page .container {
    position: relative;
    width: 100%;
    min-height: 100vh;
    min-height: 100svh;
    min-height: 100dvh;
    overflow: hidden;
  }

  .landing-page .hero-img {
    position: absolute;
    width: 100%;
    min-height: 100vh;
    min-height: 100svh;
    min-height: 100dvh;
    inset: 0;
    overflow: hidden;
  }

  .landing-page .hero-img :global(.color-bends-container) {
    width: 100%;
    height: 100%;
  }

  .landing-page .cols {
    width: 100%;
    display: flex;
  }

  .landing-page .col {
    width: 50%;
    min-height: 100vh;
    min-height: 100svh;
    min-height: 100dvh;
  }

  .landing-page .col-right {
    position: relative;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    text-align: left;
    color: #f7f1e8;
    border: none;
    padding: 4.5em 4vw 3em 4vw;
  }

  .landing-page .col-right .right-copy {
    position: relative;
    width: min(34rem, 100%);
    margin-left: auto;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }

  .landing-page .col-right .header {
    width: min(8ch, 100%);
    font-family: var(--font-melodrame);
    font-size: clamp(5rem, 8.3vw, 9rem);
    font-weight: 400;
    line-height: 0.82;
    letter-spacing: 0.012em;
    text-transform: none;
    text-wrap: balance;
    color: rgba(255, 246, 238, 0.98);
    text-shadow:
      0 0.04em 0.12em rgba(0, 0, 0, 0.22),
      0 0 1rem rgba(255, 255, 255, 0.04);
  }

  .landing-page .col-left {
    position: relative;
    left: 0%;
    padding: 0;
    overflow: hidden;
  }

  :global(.left-glass) {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 4.5em 3.5vw 3em 3.5vw;
    background:
      linear-gradient(180deg, rgba(37, 37, 37, 0.14), rgba(0, 0, 0, 0.08)),
      radial-gradient(circle at top left, rgba(0, 0, 0, 0.18), transparent 32%);
    backdrop-filter: blur(18px) saturate(135%);
    -webkit-backdrop-filter: blur(18px) saturate(135%);
    border-right: 1px solid rgba(255, 255, 255, 0.14);
    box-shadow:
      inset -1px 0 0 rgba(255, 255, 255, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.22),
      0 1.5rem 4rem rgba(0, 0, 0, 0.12);
  }

  :global(.left-glass .copy) {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    width: min(100%, 34rem);
    gap: 1.2rem;
    padding-left: 1.5rem;
  }

  :global(.left-glass .copy::before) {
    content: "";
    position: absolute;
    top: 0.45rem;
    left: 0;
    width: 1px;
    height: min(19rem, 100%);
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.85) 0%,
      rgba(170, 170, 170, 0.24) 45%,
      rgba(77, 77, 77, 0) 100%
    );
  }

  :global(.left-glass .copy > *) {
    position: relative;
  }

  :global(.left-glass .header) {
    font-family: var(--font-melodrame);
    font-size: clamp(3rem, 4.8vw, 5.2rem);
    line-height: 0.88;
    letter-spacing: 0.015em;
    text-transform: none;
    color: rgba(255, 248, 239, 0.96);
    padding: 0;
    margin: 0;
    border: none;
    max-width: 8ch;
    text-shadow: 0 0.04em 0.16em rgba(0, 0, 0, 0.18);
  }

  :global(.left-glass .sub-header) {
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    text-align: left;
    color: rgba(255, 255, 255, 0.68);
  }

  :global(.left-glass .info) {
    max-width: 30ch;
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(1rem, 1.05vw, 1.12rem);
    font-weight: 400;
    line-height: 1.55;
    text-align: left;
    color: rgba(255, 255, 255, 0.8);
    margin-top: 0.35rem;
  }

  :global(.left-glass .meta-row) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.55rem;
  }

  :global(.left-glass .meta-row span) {
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.84);
    padding: 0.65rem 0.85rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.16);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .landing-page .footer {
    display: flex;
  }

  .landing-page .footer-item {
    padding: 0 1em;
    font-size: 14px;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .landing-page {
      height: 100%;
      overflow: auto;
    }

    .landing-page .container {
      height: 100%;
      overflow: auto;
    }

    .landing-page .hero-img {
      top: 100dvh;
      opacity: 0.82;
    }

    .landing-page .cols {
      flex-direction: column;
    }

    .landing-page .col {
      width: 100%;
    }

    .landing-page .col-left,
    .landing-page .col-right {
      min-height: 100svh;
      min-height: 100dvh;
      padding:
        calc(env(safe-area-inset-top, 0px) + 5.75rem)
        1.25rem
        calc(env(safe-area-inset-bottom, 0px) + 1.5rem)
        1.25rem;
    }

    :global(.left-glass) {
      padding: 0;
      background:
        linear-gradient(180deg, rgba(18, 18, 18, 0.22), rgba(0, 0, 0, 0.1)),
        radial-gradient(circle at top left, rgba(0, 0, 0, 0.2), transparent 38%);
      backdrop-filter: blur(12px) saturate(120%);
      -webkit-backdrop-filter: blur(12px) saturate(120%);
    }

    :global(.left-glass .copy) {
      width: 100%;
      align-items: flex-start;
      padding-left: 0.9rem;
      gap: 1rem;
    }

    :global(.left-glass .copy::before) {
      height: min(16rem, 100%);
    }

    :global(.left-glass .header) {
      font-size: clamp(2.6rem, 12vw, 4.4rem);
      max-width: 9ch;
    }

    :global(.left-glass .sub-header) {
      font-size: 0.72rem;
      letter-spacing: 0.18em;
    }

    :global(.left-glass .info) {
      max-width: 28ch;
      font-size: 0.98rem;
      line-height: 1.5;
    }

    .landing-page .col-right {
      justify-content: flex-end;
    }

    .landing-page .col-right .right-copy {
      width: 100%;
      gap: 0.9rem;
    }

    .landing-page .col-right .header {
      width: 100%;
      font-size: clamp(3.2rem, 14vw, 5.2rem);
      line-height: 0.9;
    }

    .landing-page .col-right .caption {
      max-width: 22ch;
    }
  }

  .landing-page .block {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    min-height: 100vh;
    min-height: 100svh;
    min-height: 100dvh;
  }

  .landing-page .loader-text-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    background: #000;
  }

  .landing-page .loader-text {
    font-family: var(--font-melodrame);
    font-size: 50px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: #fff;
  }

  .landing-page .loader-text .letter {
    display: inline-block;
    line-height: 1em;
  }

  .landing-page .revealer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    min-height: 100vh;
    min-height: 100svh;
    min-height: 100dvh;
    background: #988871;
  }

  .landing-page .pre-loader {
    position: absolute;
    top: 0;
    left: 0;
    background: #fff;
  }

  .landing-page .loader-wrapper {
    position: relative;
    width: 10px;
    height: 140px;
    background: rgb(240, 240, 240);
    border-radius: 4px;
    overflow: hidden;
    transform: rotate(45deg);
  }

  .landing-page .loader {
    position: absolute;
    top: 0;
    width: 100%;
    height: 100%;
    background: rgb(251, 0, 255);
    background: linear-gradient(
      180deg,
      rgba(251, 0, 255, 1) 0%,
      rgba(253, 29, 29, 1) 100%
    );
  }

  @media (max-width: 640px) {
    .landing-page .loader-text {
      font-size: clamp(1.75rem, 8vw, 2.5rem);
      letter-spacing: 0.14em;
      text-align: center;
      padding-inline: 1rem;
    }

    .landing-page .loader-wrapper {
      height: 108px;
    }
  }
</style>

<script>
  // @ts-ignore
  import anime from "animejs";
  // @ts-ignore
  import { gsap } from "gsap";

  const isMobile = window.matchMedia("(max-width: 900px)").matches;
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;
  const textWrapper = document.querySelector(".landing-page .loader-text");
  if (textWrapper) {
    textWrapper.innerHTML =
      textWrapper.textContent?.replace(
        /\S/g,
        "<span class='letter'>$&</span>",
      ) || "";

    if (!prefersReducedMotion) {
      anime.timeline().add({
        targets: ".landing-page .loader-text .letter",
        translateX: [isMobile ? 20 : 40, 0],
        translateZ: 0,
        opacity: [0, 1],
        easing: "easeOutExpo",
        duration: isMobile ? 700 : 1200,
        delay: (i: number) => (isMobile ? 900 : 2400) + 24 * i,
      });
    }
  }

  const loaderDelay = prefersReducedMotion ? 0.15 : isMobile ? 1 : 2;
  const revealDelay = prefersReducedMotion ? 0.3 : isMobile ? 1.35 : 3;
  const contentDelay = prefersReducedMotion ? 0.45 : isMobile ? 1.85 : 4.5;

  gsap.from(".landing-page .loader-wrapper", {
    scale: 0.8,
    ease: "power1.inOut",
    duration: prefersReducedMotion ? 0.2 : isMobile ? 1 : 2,
  });

  gsap.from(".landing-page .loader", {
    top: "100%",
    ease: "power3.inOut",
    duration: prefersReducedMotion ? 0.2 : isMobile ? 1 : 2,
  });

  gsap.to(".landing-page .loader-wrapper, .landing-page .pre-loader", {
    scale: 1.5,
    opacity: 0,
    display: "none",
    ease: "power3.inOut",
    delay: loaderDelay,
    duration: prefersReducedMotion ? 0.15 : isMobile ? 0.5 : 1,
  });

  gsap.from(".landing-page .revealer", {
    width: "0%",
    ease: "power3.inOut",
    delay: revealDelay,
    duration: prefersReducedMotion ? 0.15 : isMobile ? 0.5 : 1,
  });

  gsap.to(".landing-page .revealer", {
    left: "100%",
    ease: "power3.inOut",
    delay: revealDelay + (isMobile ? 0.45 : 1),
    duration: prefersReducedMotion ? 0.15 : isMobile ? 0.45 : 0.8,
  });

  gsap.to(".landing-page .loader-text-wrapper", {
    opacity: 0,
    display: "none",
    ease: "power3.inOut",
    delay: revealDelay + (isMobile ? 0.4 : 1),
    duration: 0.2,
  });

  gsap.from(".landing-page .col-left", {
    left: "-100%",
    ease: "power3.inOut",
    delay: contentDelay,
    duration: prefersReducedMotion ? 0.2 : isMobile ? 0.7 : 1,
  });

  gsap.from(".landing-page .col-left .copy > div", {
    x: "-40",
    opacity: 0,
    ease: "power3.inOut",
    delay: contentDelay + 0.2,
    duration: prefersReducedMotion ? 0.2 : isMobile ? 0.8 : 1.5,
    stagger: {
      amount: isMobile ? 0.18 : 0.3,
    },
  });

  gsap.from(".landing-page .col-right .header", {
    x: "-20",
    opacity: 0,
    ease: "power3.inOut",
    delay: contentDelay + 0.45,
    duration: prefersReducedMotion ? 0.2 : isMobile ? 0.7 : 1,
  });
</script>
