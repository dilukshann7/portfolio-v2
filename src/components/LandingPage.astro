  <div class="container">
    <div class="cols">
      <div class="col col-left">
        <div class="copy">
          <div class="header">Dilukshan N</div>
          <div class="sub-header">CS & SE Undergrad from Sri Lanka</div>
          <div class="info">
            Fullstack Developer & AI Engineer passionate about building scalable
            web applications and intelligent systems.
          </div>
        </div>
      </div>
      <div class="col col-right">
        <div class="header">
          Building <br />
          the <br />
          future <br />
          with code
        </div>
      </div>
    </div>
    <nav>
      <div class="nav-items">
        <div class="nav-item">
          <a href="#">about</a>
        </div>
        <div class="nav-item">
          <a href="#">projects</a>
        </div>
      </div>
      <div class="nav-items">
        <div class="nav-item">
          <a href="#" id="logo">Dilukshan N &copy;</a>
        </div>
      </div>
      <div class="nav-items">
        <div class="nav-item">
          <a href="#">skills</a>
        </div>
        <div class="nav-item">
