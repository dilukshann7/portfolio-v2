---

---

<section class="intro" id="expertise">
  <h2
    style="font-family: var(--font-melodrame); font-weight: 400;"
    class="header"
  >
    Experienced In
  </h2>
</section>

<section class="cards">
  <div class="card" id="card-1">
    <div class="card-inner">
      <div class="card-content">
        <h3>Full-Stack Development</h3>
        <p>
          I specialize in crafting seamless web applications that blend
          functionality with captivating design, delivering engaging user
          experiences.
        </p>
      </div>
      <div class="grid-wrapper">
        <div class="grid">
          <div class="grid-row">
            <div
              class="grid-item"
              data-color="#000000"
              data-text-color="#ffffff"
            >
              <img
                src="/full-stack/nextdotjs.svg"
                alt="Next.js"
                class="tech-icon"
              />
              <span class="tech-name">NEXT.JS</span>
            </div>
            <div class="grid-item" data-color="#ff5d01">
              <img src="/full-stack/astro.svg" alt="Astro" class="tech-icon" />
              <span class="tech-name">ASTRO</span>
            </div>
          </div>
          <div class="grid-row">
            <div class="grid-item" data-color="#ff3e00">
              <img
                src="/full-stack/svelte.svg"
                alt="Svelte"
                class="tech-icon"
              />
              <span class="tech-name">SVELTE</span>
            </div>
            <div class="grid-item" data-color="#ff4154">
              <img
                src="/full-stack/tanstack.svg"
                alt="TanStack"
                class="tech-icon"
              />
              <span class="tech-name">TANSTACK</span>
            </div>
          </div>
          <div class="highlight"></div>
        </div>
      </div>
    </div>
  </div>
  <div class="card" id="card-2">
    <div class="card-inner">
      <div class="card-content">
        <h3>Graphic Design & Animation</h3>
        <p>
          I create visually stunning graphics and animations that bring ideas to
          life, combining creativity with technical expertise to deliver
          captivating visual experiences.
        </p>
      </div>
      <div class="grid-wrapper">
        <div class="grid">
          <div class="grid-row">
            <div class="grid-item" data-color="#ff0000">
              <img
                src="/graphic-design/adobe.svg"
                alt="Adobe"
                class="tech-icon"
              />
              <span class="tech-name">ADOBE Creative Cloud</span>
            </div>
            <div class="grid-item" data-color="#000000">
              <img
                src="/graphic-design/threedotjs.svg"
                alt="Three.js"
                class="tech-icon"
              />
              <span class="tech-name">THREE.JS</span>
            </div>
          </div>
          <div class="grid-row">
            <div class="grid-item" data-color="#88ce02">
              <img
                src="/graphic-design/gsap.svg"
                alt="GSAP"
                class="tech-icon"
              />
              <span class="tech-name">GSAP</span>
            </div>
            <div class="grid-item" data-color="#f24e1e">
              <img
                src="/graphic-design/figma.svg"
                alt="Figma"
                class="tech-icon"
              />
              <span class="tech-name">FIGMA</span>
            </div>
          </div>
          <div class="highlight"></div>
        </div>
      </div>
    </div>
  </div>
  <div class="card" id="card-3">
    <div class="card-inner">
      <div class="card-content">
        <h3>Generative AI</h3>
        <p>
          I leverage the power of generative AI to create innovative solutions
          that push the boundaries of creativity and technology.
        </p>
      </div>
      <div class="grid-wrapper">
        <div class="grid">
          <div class="grid-row">
            <div class="grid-item" data-color="#4285f4">
              <img
                src="/gen-ai/googlegemini.svg"
                alt="Gemini"
                class="tech-icon"
              />
              <span class="tech-name">GEMINI</span>
            </div>
            <div class="grid-item" data-color="#d97757">
              <img src="/gen-ai/claude.svg" alt="Claude" class="tech-icon" />
              <span class="tech-name">CLAUDE</span>
            </div>
          </div>
          <div class="grid-row">
            <div
              class="grid-item"
              data-color="#000000"
              data-text-color="#ffffff"
            >
              <img src="/gen-ai/kimi.svg" alt="Kimi" class="tech-icon" />
              <span class="tech-name">KIMI</span>
            </div>
            <div class="grid-item" data-color="#f14262">
              <img src="/gen-ai/minimax.svg" alt="Minimax" class="tech-icon" />
              <span class="tech-name">MINIMAX</span>
            </div>
          </div>
          <div class="highlight"></div>
        </div>
      </div>
    </div>
  </div>
  <div class="card" id="card-4">
    <div class="card-inner">
      <div class="card-content">
        <h3>Data Engineering</h3>
        <p>
          I design and build robust data pipelines and systems that enable
          efficient data processing and insightful analytics.
        </p>
      </div>
      <div class="grid-wrapper">
        <div class="grid">
          <div class="grid-row">
            <div class="grid-item" data-color="#3776ab">
              <img
                src="/data-engineering/python.svg"
                alt="Python"
                class="tech-icon"
              />
              <span class="tech-name">PYTHON</span>
            </div>
            <div class="grid-item" data-color="#4169e1">
              <img
                src="/data-engineering/postgresql.svg"
                alt="PostgreSQL"
                class="tech-icon"
              />
              <span class="tech-name">POSTGRES</span>
            </div>
          </div>
          <div class="grid-row">
            <div class="grid-item" data-color="#ff4438">
              <img
                src="/data-engineering/redis.svg"
                alt="Redis"
                class="tech-icon"
              />
              <span class="tech-name">REDIS</span>
            </div>
            <div class="grid-item" data-color="#4285f4">
              <img
                src="/data-engineering/googlecloud.svg"
                alt="Google Cloud"
                class="tech-icon"
              />
              <span class="tech-name">Google Cloud</span>
            </div>
          </div>
          <div class="highlight"></div>
        </div>
      </div>
    </div>
  </div>
  <div class="card" id="card-5">
    <div class="card-inner">
      <div class="card-content">
        <h3>General Purpose Programming</h3>
        <p>
          I have a strong command of general-purpose programming languages,
          enabling me to develop efficient and scalable software solutions
          across various domains.
        </p>
      </div>
      <div class="grid-wrapper">
        <div class="grid">
          <div class="grid-row">
            <div class="grid-item" data-color="#ce422b">
              <img src="/low-level/rust.svg" alt="Rust" class="tech-icon" />
              <span class="tech-name">RUST</span>
            </div>
            <div class="grid-item" data-color="#00599c">
              <img src="/low-level/cplusplus.svg" alt="C++" class="tech-icon" />
              <span class="tech-name">C++</span>
            </div>
          </div>
          <div class="grid-row">
            <div class="grid-item" data-color="#7355dd">
              <img src="/low-level/csharp.svg" alt="C#" class="tech-icon" />
              <span class="tech-name">C#</span>
            </div>
            <div class="grid-item" data-color="#3D1C02">
              <img src="/low-level/java.svg" alt="Java" class="tech-icon" />
              <span class="tech-name">JAVA</span>
            </div>
          </div>
          <div class="highlight"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="outro">
  <h2
    style="font-family: var(--font-melodrame); font-weight: 400;"
    class="header"
  >
    Featured Work
  </h2>
</section>

<style>
  .card-content h3 {
    font-size: 4rem;
    font-weight: 600;
    line-height: 1;
    margin-bottom: 2.5em;
  }

  .header {
    font-size: clamp(3.5rem, 5vw, 4.5rem);
    letter-spacing: -0.5px;
  }

  p {
    font-size: 1.25rem;
    font-weight: 500;
  }

  .hero,
  .intro,
  .outro {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 100%;
    height: 70vh;
    padding-top: 4rem;
    padding-left: 2rem;
  }

  .hero {
    padding: 0;
  }

  .intro,
  .outro {
    background-color: #fff;
  }

  .intro h2,
  .outro h2 {
    margin-bottom: 0;
  }

  .outro {
    height: 20vh;
    position: relative;
    z-index: 5;
  }

  .card {
    position: relative;
  }

  .cards {
    position: relative;
    z-index: 1;
  }

  .card-inner {
    position: relative;
    will-change: transform;
    width: 100%;
    height: 100%;
    padding: 2em;
    display: flex;
    gap: 4em;
  }

  .card-content {
    flex: 3;
  }

  .grid-wrapper {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .grid {
    position: relative;
    width: 100%;
    max-width: 500px;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(0, 0, 0, 0.2);
  }

  .grid-row {
    display: flex;
    flex: 1;
  }

  .grid-item {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 4rem 0.5rem;
    border-right: 1px solid rgba(0, 0, 0, 0.2);
    cursor: pointer;
    position: relative;
    z-index: 2;
    background: transparent;
    overflow: hidden;
  }

  .grid-item:last-child {
    border-right: none;
  }

  .grid-row:first-child .grid-item {
    border-bottom: 1px solid rgba(0, 0, 0, 0.2);
  }

  .tech-icon,
  .tech-name {
    position: absolute;
    top: 50%;
    left: 50%;
  }

  .tech-icon {
    width: 52px;
    height: 52px;
    object-fit: contain;
    transform: translate(-50%, -50%);
    transition:
      filter 0.25s ease,
      opacity 0.25s ease;
    opacity: 1;
  }

  .grid-item:hover .tech-icon,
  .grid-item:active .tech-icon {
    opacity: 0;
  }

  .tech-name {
    margin-top: 0;
    text-transform: uppercase;
    color: #000;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 1px;
    transform: translate(-50%, -50%);
    transition:
      color 0.25s ease,
      opacity 0.25s ease;
    opacity: 0;
    white-space: nowrap;
    text-shadow: 0 0 10px rgba(0, 0, 0, 0.12);
  }

  .grid-item:hover .tech-name,
  .grid-item:active .tech-name {
    color: var(--text-color, var(--item-color, #000));
    opacity: 1;
  }

  .dark-card .tech-icon {
    filter: invert(1) brightness(1.1);
  }

  .highlight {
    position: absolute;
    top: 0;
    left: 0;
    background: white;
    pointer-events: none;
    transition:
      transform 0.25s ease,
      width 0.25s ease,
      height 0.25s ease,
      background-color 0.25s ease;
    opacity: 0.25;
    z-index: 1;
  }

  #card-1 .card-inner {
    background-color: #0f0f0f;
    color: #fff;
  }
  #card-2 .card-inner {
    background-color: #f0ece3;
  }
  #card-3 .card-inner {
    background-color: #1a1a2e;
    color: #fff;
  }
  #card-4 .card-inner {
    background-color: #0d1117;
    color: #58a6ff;
  }
  #card-5 .card-inner {
    background-color: #1e1b18;
    color: #d4c5a9;
  }

  @media (max-width: 900px) {
    .header {
      font-size: 4rem;
    }

    .card-content h3 {
      font-size: 2rem;
      margin-bottom: 1rem;
    }

    p {
      font-size: 1rem;
    }

    .intro,
    .outro {
      padding-top: 3rem;
      padding-left: 1rem;
      padding-right: 1rem;
      height: 50vh;
    }

    .outro {
      height: 18vh;
    }

    .card-inner {
      flex-direction: column;
      gap: 1.5rem;
      padding: 1.5rem;
    }

    .grid-wrapper {
      max-width: 100%;
      width: 100%;
      margin-top: 0;
    }

    .grid {
      max-width: 100%;
      width: 100%;
    }

    .grid-item {
      padding: 2.5rem 0.5rem;
    }

    .tech-icon {
      width: 36px;
      height: 36px;
    }
  }
</style>

<script>
  import { runPageScript } from "../lib/client/spa";

  const initAboutCardsMotion = () =>
    runPageScript("about-cards-motion", ({ onCleanup }) => {
      const intro = document.querySelector(".intro");
      const cardInners =
        document.querySelectorAll<HTMLElement>(".cards .card-inner");

      if (!intro) return;

      cardInners.forEach((element) => {
        element.style.visibility = "hidden";
      });

      const observer = new IntersectionObserver(
        (entries) => {
          if (entries.some((entry) => entry.isIntersecting)) {
            observer.disconnect();
            void boot();
          }
        },
        { rootMargin: "250px 0px" },
      );

      const boot = async () => {
        const [{ getMotionSystem }, { initTextReveal }] = await Promise.all([
          import("../lib/client/motion"),
          import("../lib/client/textReveal"),
        ]);
        const { gsap, ScrollTrigger, reducedMotion } = await getMotionSystem();
        const cards = gsap.utils.toArray<HTMLElement>(".card");
        const triggers: Array<ReturnType<typeof ScrollTrigger.create>> = [];
        const tweens: Array<ReturnType<typeof gsap.to>> = [];
        const registerTrigger = (
          trigger: ReturnType<typeof ScrollTrigger.create>,
        ) => {
          triggers.push(trigger);
          return trigger;
        };
        const registerTween = (tween: ReturnType<typeof gsap.to>) => {
          tweens.push(tween);
          return tween;
        };
        const textRevealCleanup = await initTextReveal(document, [
          {
            selector: ".intro .header",
            mode: "lines",
            scroll: true,
          },
          {
            selector: ".card-content h3",
            mode: "lines",
            scroll: true,
          },
          {
            selector: ".card-content p",
            mode: "fade",
            scroll: true,
            y: 18,
          },
          {
            selector: ".outro .header",
            mode: "lines",
            scroll: true,
          },
        ]);

        onCleanup(() => {
          textRevealCleanup?.();
          tweens.forEach((tween) => tween.kill());
          triggers.forEach((trigger) => trigger.kill());
        });

        cardInners.forEach((element) => {
          element.style.visibility = "visible";
        });

        if (cards.length === 0) return;

        if (reducedMotion) {
          document
            .querySelectorAll<HTMLElement>(".cards .tech-icon")
            .forEach((element) => {
              element.style.transform = "translate(-50%, -50%)";
            });
          document
            .querySelectorAll<HTMLElement>(".cards .grid-item")
            .forEach((element) => {
              element.style.opacity = "1";
            });
          return;
        }

        cards.forEach((card) => {
          const gridItems = Array.from(
            card.querySelectorAll<HTMLElement>(".grid-item"),
          );
          const icons = Array.from(
            card.querySelectorAll<HTMLElement>(".tech-icon"),
          );

          if (!gridItems.length || !icons.length) {
            return;
          }

          gsap.set(gridItems, {
            opacity: 0,
          });
          gsap.set(icons, {
            xPercent: -50,
            yPercent: 85,
            force3D: true,
          });

          registerTrigger(
            ScrollTrigger.create({
              trigger: card,
              start: "top 78%",
              once: true,
              onEnter: () => {
                registerTween(
                  gsap.to(gridItems, {
                    opacity: 1,
                    duration: 0.18,
                    stagger: 0.08,
                    ease: "power2.out",
                    overwrite: "auto",
                  }),
                );

                registerTween(
                  gsap.to(icons, {
                    xPercent: -50,
                    yPercent: -50,
                    duration: 0.82,
                    stagger: 0.12,
                    ease: "power3.out",
                    overwrite: "auto",
                  }),
                );
              },
            }),
          );
        });

        const mm = gsap.matchMedia();

        onCleanup(() => mm.revert());

        mm.add("(min-width: 901px)", () => {
          registerTrigger(
            ScrollTrigger.create({
              trigger: cards[0],
              start: "top 70%",
              endTrigger: cards[cards.length - 1],
              end: "top 30%",
              pin: ".intro",
              pinSpacing: false,
            }),
          );

          cards.forEach((card: HTMLElement, index: number) => {
            const isLastCard = index === cards.length - 1;
            const cardInner = card.querySelector(".card-inner");

            if (!isLastCard) {
              registerTrigger(
                ScrollTrigger.create({
                  trigger: card,
                  start: "top 25%",
                  endTrigger: ".outro",
                  end: "top 65%",
                  pin: true,
                  pinSpacing: false,
                }),
              );

              registerTween(
                gsap.to(cardInner, {
                  y: `-${(cards.length - index) * 14}vh`,
                  ease: "none",
                  scrollTrigger: {
                    trigger: card,
                    start: "top 25%",
                    endTrigger: ".outro",
                    end: "top 65%",
                    scrub: true,
                  },
                }),
              );
            }
          });
        });

        mm.add("(max-width: 900px)", () => {
          registerTrigger(
            ScrollTrigger.create({
              trigger: cards[0],
              start: "top 60%",
              endTrigger: cards[cards.length - 1],
              end: "top 40%",
              pin: ".intro",
              pinSpacing: false,
            }),
          );

          cards.forEach((card: HTMLElement, index: number) => {
            const isLastCard = index === cards.length - 1;
            const cardInner = card.querySelector(".card-inner");

            if (!isLastCard) {
              registerTrigger(
                ScrollTrigger.create({
                  trigger: card,
                  start: "top 15%",
                  endTrigger: ".outro",
                  end: "top 75%",
                  pin: true,
                  pinSpacing: false,
                }),
              );

              registerTween(
                gsap.to(cardInner, {
                  y: `-${(cards.length - index) * 5}vh`,
                  ease: "none",
                  scrollTrigger: {
                    trigger: card,
                    start: "top 15%",
                    endTrigger: ".outro",
                    end: "top 75%",
                    scrub: true,
                  },
                }),
              );
            }
          });
        });
      };

      observer.observe(intro);
      onCleanup(() => observer.disconnect());
    });

  document.addEventListener("astro:page-load", initAboutCardsMotion);
</script>

<script>
  import { runPageScript } from "../lib/client/spa";

  const initAboutCardsGrid = () =>
    runPageScript("about-cards-grid", ({ signal }) => {
      const cards = document.querySelectorAll(".card");

      cards.forEach((card) => {
        const grid = card.querySelector(".grid");
        const highlight = card.querySelector(".highlight");
        const firstItem = card.querySelector(".grid-item");
        const cardInner = card.querySelector<HTMLElement>(".card-inner");

        if (!grid || !highlight || !firstItem) return;

        const isDarkBackground = (() => {
          if (!cardInner) return false;
          const bg = getComputedStyle(cardInner).backgroundColor;
          const [r, g, b] = bg
            .match(/\d+/g)
            ?.map((n) => parseInt(n, 10))
            .slice(0, 3) || [255, 255, 255];
          const luminance = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
          return luminance < 0.35;
        })();

        if (isDarkBackground && cardInner) {
          cardInner.classList.add("dark-card");
        }

        grid.querySelectorAll<HTMLElement>(".grid-item").forEach((item) => {
          const color = item.dataset.color || "#000";
          item.style.setProperty("--item-color", color);
          const textColor = item.dataset.textColor;
          if (textColor) {
            item.style.setProperty("--text-color", textColor);
          }
        });

        const moveToElement = (element: Element | null) => {
          if (element && highlight && grid) {
            const rect = element.getBoundingClientRect();
            const gridRect = grid.getBoundingClientRect();

            (highlight as HTMLElement).style.transform = `translate(${
              rect.left - gridRect.left
            }px, ${rect.top - gridRect.top}px)`;
            (highlight as HTMLElement).style.width = `${rect.width}px`;
            (highlight as HTMLElement).style.height = `${rect.height}px`;
            (highlight as HTMLElement).style.backgroundColor =
              (element as HTMLElement).dataset.color || "white";
          }
        };

        moveToElement(firstItem);

        // Touch & Mouse Event Handler
        const handleInteraction = (e: Event) => {
          let clientX, clientY;

          if (e.type.includes("touch")) {
            const touchEvent = e as TouchEvent;
            clientX = touchEvent.touches[0].clientX;
            clientY = touchEvent.touches[0].clientY;
          } else {
            const mouseEvent = e as MouseEvent;
            clientX = mouseEvent.clientX;
            clientY = mouseEvent.clientY;
          }

          const target = document.elementFromPoint(clientX, clientY);
          const hoveredElement = target?.closest(".grid-item") ?? null;

          if (hoveredElement) {
            moveToElement(hoveredElement);
          }
        };

        (grid as HTMLElement).addEventListener("mousemove", handleInteraction, {
          passive: true,
          signal,
        });

        // Added Touch Support
        (grid as HTMLElement).addEventListener(
          "touchstart",
          handleInteraction,
          {
            passive: true,
            signal,
          },
        );

        (grid as HTMLElement).addEventListener("touchmove", handleInteraction, {
          passive: true,
          signal,
        });
      });
    });

  document.addEventListener("astro:page-load", initAboutCardsGrid);
</script>
