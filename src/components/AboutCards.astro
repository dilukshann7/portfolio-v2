</section>

<section class="outro">
  <h1
    style="font-family: var(--font-melodrame); font-weight: 400;"
    class="header"
  >
    Featured Work
  </h1>
</section>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: "Space Grotesk", sans-serif;
  }

  h1 {
    font-size: 4rem;
    font-weight: 600;
    line-height: 1;
    margin-bottom: 2.5em;
  }

  .header {
    font-size: 5rem;
  }

  p {
    font-size: 1.25rem;
    font-weight: 500;
  }

  .hero,
  .intro,
  .outro {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100dvw;
    height: 80vh;
    padding-top: 4rem;
    padding-left: 2rem;
  }

  .hero {
    padding: 0;
  }

  .intro,
  .outro {
    background-color: #fff;
  }

  .intro h1,
  .outro h1 {
    margin-bottom: 0;
  }

  .outro {
    height: 30vh;
    position: relative;
    z-index: 5;
  }

  .card {
    position: relative;
  }

  .cards {
    position: relative;
    z-index: 1;
  }

  .card-inner {
    position: relative;
    will-change: transform;
    width: 100%;
    height: 100%;
    padding: 2em;
    display: flex;
    gap: 4em;
  }

  .card-content {
    flex: 3;
  }

  .grid-wrapper {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .grid {
    position: relative;
    width: 100%;
    max-width: 500px;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(0, 0, 0, 0.2);
  }

  .grid-row {
    display: flex;
    flex: 1;
  }

  .grid-item {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 4rem 0.5rem;
    border-right: 1px solid rgba(0, 0, 0, 0.2);
    cursor: pointer;
    position: relative;
    z-index: 2;
    background: transparent;
  }

  .grid-item:last-child {
    border-right: none;
  }

  .grid-row:first-child .grid-item {
    border-bottom: 1px solid rgba(0, 0, 0, 0.2);
  }

  .tech-icon,
  .tech-name {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .tech-icon {
    width: 52px;
    height: 52px;
    object-fit: contain;
    transition:
      filter 0.25s ease,
      opacity 0.25s ease;
    opacity: 1;
  }

  .grid-item:hover .tech-icon {
    opacity: 0;
  }

  .tech-name {
    margin-top: 0;
    text-transform: uppercase;
    color: #000;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 1px;
    transition:
      color 0.25s ease,
      opacity 0.25s ease;
    opacity: 0;
    white-space: nowrap;
    text-shadow: 0 0 10px rgba(0, 0, 0, 0.12);
  }

  .grid-item:hover .tech-name {
    color: var(--text-color, var(--item-color, #000));
    opacity: 1;
  }

  .dark-card .tech-icon {
    filter: invert(1) brightness(1.1);
  }

  .highlight {
    position: absolute;
    top: 0;
    left: 0;
    background: white;
    pointer-events: none;
    transition:
      transform 0.25s ease,
      width 0.25s ease,
      height 0.25s ease,
      background-color 0.25s ease;
    opacity: 0.25;
    z-index: 1;
  }

  #card-1 .card-inner {
    background-color: #0f0f0f;
    color: #fff;
  }
  #card-2 .card-inner {
    background-color: #f0ece3;
  }
  #card-3 .card-inner {
    background-color: #1a1a2e;
    color: #fff;
  }
  #card-4 .card-inner {
    background-color: #0d1117;
    color: #58a6ff;
  }
  #card-5 .card-inner {
    background-color: #1e1b18;
    color: #d4c5a9;
  }

  @media (max-width: 900px) {
    h1 {
      margin-bottom: 4rem;
    }

    p {
      font-size: 1rem;
    }

    .card-inner {
      flex-direction: column;
    }

    .grid-wrapper {
      max-width: 200px;
      margin-top: 2rem;
    }

    .highlight {
      display: none;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const intro = document.querySelector(".intro");
    if (!intro) return;

    const boot = async () => {
      const { getMotionSystem } = await import("../lib/client/motion");
      const { gsap, ScrollTrigger, reducedMotion } = await getMotionSystem();
      const cards = gsap.utils.toArray<HTMLElement>(".card");

      if (cards.length === 0 || reducedMotion) return;

      ScrollTrigger.create({
        trigger: cards[0],
        start: "top 80%",
        endTrigger: cards[cards.length - 1],
        end: "top 30%",
        pin: ".intro",
        pinSpacing: false,
      });

      cards.forEach((card: HTMLElement, index: number) => {
        const isLastCard = index === cards.length - 1;
        const cardInner = card.querySelector(".card-inner");

        if (!isLastCard) {
          ScrollTrigger.create({
            trigger: card,
            start: "top 25%",
            endTrigger: ".outro",
            end: "top 65%",
            pin: true,
            pinSpacing: false,
          });

          gsap.to(cardInner, {
            y: `-${(cards.length - index) * 14}vh`,
            ease: "none",
            scrollTrigger: {
              trigger: card,
              start: "top 25%",
              endTrigger: ".outro",
              end: "top 65%",
              scrub: true,
            },
          });
        }
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries.some((entry) => entry.isIntersecting)) {
          observer.disconnect();
          void boot();
        }
      },
      { rootMargin: "250px 0px" },
    );

    observer.observe(intro);
  });
</script>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const cards = document.querySelectorAll(".card");

    cards.forEach((card) => {
      const grid = card.querySelector(".grid");
      const highlight = card.querySelector(".highlight");
      const firstItem = card.querySelector(".grid-item");
      const cardInner = card.querySelector<HTMLElement>(".card-inner");

      if (!grid || !highlight || !firstItem) return;

      const isDarkBackground = (() => {
        if (!cardInner) return false;
        const bg = getComputedStyle(cardInner).backgroundColor;
        const [r, g, b] = bg
          .match(/\d+/g)
          ?.map((n) => parseInt(n, 10))
          .slice(0, 3) || [255, 255, 255];
        // Perceived luminance
        const luminance = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
        return luminance < 0.35;
      })();

      if (isDarkBackground && cardInner) {
        cardInner.classList.add("dark-card");
      }

      grid.querySelectorAll<HTMLElement>(".grid-item").forEach((item) => {
        const color = item.dataset.color || "#000";
        item.style.setProperty("--item-color", color);
        const textColor = item.dataset.textColor;
        if (textColor) {
          item.style.setProperty("--text-color", textColor);
        }
      });

      const moveToElement = (element: Element | null) => {
        if (element && highlight && grid) {
          const rect = element.getBoundingClientRect();
          const gridRect = grid.getBoundingClientRect();

          (highlight as HTMLElement).style.transform = `translate(${
            rect.left - gridRect.left
          }px, ${rect.top - gridRect.top}px)`;
          (highlight as HTMLElement).style.width = `${rect.width}px`;
          (highlight as HTMLElement).style.height = `${rect.height}px`;
          (highlight as HTMLElement).style.backgroundColor =
            (element as HTMLElement).dataset.color || "white";
        }
      };

      const moveHighlight = (e: MouseEvent) => {
        const hoveredElement = (e.target as Element | null)?.closest(".grid-item");
        moveToElement(hoveredElement);
      };

      moveToElement(firstItem);

      (grid as HTMLElement).addEventListener("mousemove", moveHighlight, {
        passive: true,
      });
    });
  });
</script>
