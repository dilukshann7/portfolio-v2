---
import { projects } from "../data/projects";

const rows = [];

for (let index = 0; index < projects.length; index += 3) {
  rows.push(projects.slice(index, index + 3));
}
---

<section class="work" id="projects">
  {
    rows.map((row) => (
      <div class="row">
        {row.map((project) => (
          <div class="work-item">
            <a href={project.route} class="work-item-link">
              <div class="work-item-img">
                <img
                  src={project.img}
                  alt={project.name}
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="work-item-copy">
                <h3>{project.name}</h3>
                <p>{project.description}</p>
              </div>
            </a>
          </div>
        ))}
      </div>
    ))
  }
</section>

<style>
  .work {
    color: #0f0f0f;
    font-family: "Space Grotesk", sans-serif;
  }

  .work img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .work h3 {
    font-size: 1.25rem;
    padding-left: 2px;
    letter-spacing: -0.025rem;
  }

  .work p {
    font-size: 1rem;
    padding-left: 2px;
    font-weight: 500;
    letter-spacing: -0.0125rem;
  }

  .work a {
    text-decoration: none;
  }

  .work {
    position: relative;
    height: 100%;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
    overflow: hidden;
  }

  .row {
    flex: 1;
    width: 100%;
    display: flex;
    gap: 1.5rem;
  }

  .work-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .work-item-img {
    aspect-ratio: 4/3;
    overflow: hidden;
    width: 100%;
    max-height: 400px;
  }

  .work-item-copy p {
    color: #999;
  }

  .work-item-link {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-decoration: none;
    color: inherit;
    width: 100%;
    height: 100%;
  }

  .work-item-link:hover {
    text-decoration: none;
    color: inherit;
  }

  @media (max-width: 1000px) {
    .work,
    .row {
      gap: 2rem;
    }

    .header,
    .footer {
      position: relative;
      width: 100%;
      height: 100px;
      text-align: center;
    }

    .row {
      flex-direction: column;
    }

    footer {
      flex-direction: column;
      justify-content: flex-end;
      align-items: flex-start;
    }
  }
</style>

<script>
  import { runPageScript } from "../lib/client/spa";

  const initProjects = () =>
    runPageScript("projects", ({ onCleanup }) => {
      const workContainer = document.querySelector(".work");
      if (!workContainer) return;

      const observer = new IntersectionObserver(
        (entries) => {
          if (entries.some((entry) => entry.isIntersecting)) {
            observer.disconnect();
            void boot();
          }
        },
        { rootMargin: "250px 0px" },
      );

      const boot = async () => {
        const { getMotionSystem } = await import("../lib/client/motion");
        const { gsap, ScrollTrigger, reducedMotion } = await getMotionSystem();
        const triggers: Array<ReturnType<typeof ScrollTrigger.create>> = [];
        const tweens: Array<ReturnType<typeof gsap.to>> = [];

        onCleanup(() => {
          tweens.forEach((tween) => tween.kill());
          triggers.forEach((trigger) => trigger.kill());
        });

        if (reducedMotion) return;

        gsap.set(".work-item", {
          y: 1000,
        });

        document.querySelectorAll(".row").forEach((row) => {
          const workItems = row.querySelectorAll(".work-item");

          workItems.forEach((item, itemIndex) => {
            const isLeftProjectItem = itemIndex === 0;
            gsap.set(item, {
              rotation: isLeftProjectItem ? -60 : 60,
              transformOrigin: "center center",
            });
          });

          triggers.push(
            ScrollTrigger.create({
              trigger: row,
              start: "top 70%",
              once: true,
              onEnter: () => {
                tweens.push(
                  gsap.to(workItems, {
                    y: 0,
                    rotation: 0,
                    duration: 1,
                    ease: "power4.out",
                    stagger: 0.25,
                  }),
                );
              },
            }),
          );
        });
      };

      observer.observe(workContainer);
      onCleanup(() => observer.disconnect());
    });

  document.addEventListener("astro:page-load", initProjects);
</script>
