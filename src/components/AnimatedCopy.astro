---
interface Props {
  colorInitial?: string;
  colorAccent?: string;
  colorFinal?: string;
}

const {
  colorInitial = "#dddddd",
  colorAccent = "#abff02",
  colorFinal = "#000000",
} = Astro.props;

// Generate a unique id so multiple instances on the same page are independent.
const uid = `ac-${Math.random().toString(36).slice(2, 9)}`;
---

<!--
  The wrapper carries the uid and colour props as data attributes so the
  inline <script> can read them without any module bundler involvement.
  Astro's is:inline script runs once per page; it uses a MutationObserver /
  DOMContentLoaded guard so it initialises every .animated-copy element it
  finds, including ones added after the initial parse.
-->
<div
  class="animated-copy"
  id={uid}
  data-color-initial={colorInitial}
  data-color-accent={colorAccent}
  data-color-final={colorFinal}
>
  <slot />
</div>

<script>
  /**
   * This script is bundled once by Vite and executed on every page that
   * includes the component.  It waits for the DOM, then initialises all
   * `.animated-copy` containers it finds.  A WeakSet guards against double-
   * initialisation if the component is used multiple times.
   */
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { SplitText } from "gsap/SplitText";

  gsap.registerPlugin(ScrollTrigger, SplitText);

  const initialised = new WeakSet<Element>();

  function initContainer(container: Element) {
    if (initialised.has(container)) return;
    initialised.add(container);

    const colorInitial =
      container.getAttribute("data-color-initial") ?? "#dddddd";
    const colorAccent =
      container.getAttribute("data-color-accent") ?? "#abff02";
    const colorFinal = container.getAttribute("data-color-final") ?? "#000000";

    // ── Split ──────────────────────────────────────────────────────────────
    const elements: Element[] = Array.from(container.children);

    const splitRefs: Array<{ wordSplit: SplitText; charSplit: SplitText }> = [];

    elements.forEach((element) => {
      const wordSplit = SplitText.create(element as HTMLElement, {
        type: "words",
        wordsClass: "word",
      });

      const charSplit = SplitText.create(wordSplit.words, {
        type: "chars",
        charsClass: "char",
      });

      splitRefs.push({ wordSplit, charSplit });
    });

    const allChars: HTMLElement[] = splitRefs.flatMap(
      ({ charSplit }) => charSplit.chars as HTMLElement[],
    );

    gsap.set(allChars, { color: colorInitial });

    // ── State ──────────────────────────────────────────────────────────────
    let lastScrollProgress = 0;
    const colorTransitionTimers = new Map<
      number,
      ReturnType<typeof setTimeout>
    >();
    const completedChars = new Set<number>();

    const scheduleFinalTransition = (char: HTMLElement, index: number) => {
      if (colorTransitionTimers.has(index)) {
        clearTimeout(colorTransitionTimers.get(index)!);
      }

      const timer = setTimeout(() => {
        if (!completedChars.has(index)) {
          gsap.to(char, {
            duration: 0.1,
            ease: "none",
            color: colorFinal,
            onComplete: () => completedChars.add(index),
          });
        }
        colorTransitionTimers.delete(index);
      }, 100);

      colorTransitionTimers.set(index, timer);
    };

    // ── ScrollTrigger ──────────────────────────────────────────────────────
    const st = ScrollTrigger.create({
      trigger: container as HTMLElement,
      start: "top 90%",
      end: "top 10%",
      scrub: 1,
      onUpdate(self) {
        const progress = self.progress;
        const totalChars = allChars.length;
        const isScrollingDown = progress >= lastScrollProgress;
        const currentCharIndex = Math.floor(progress * totalChars);

        allChars.forEach((char, index) => {
          if (!isScrollingDown && index >= currentCharIndex) {
            if (colorTransitionTimers.has(index)) {
              clearTimeout(colorTransitionTimers.get(index)!);
              colorTransitionTimers.delete(index);
            }
            completedChars.delete(index);
            gsap.set(char, { color: colorInitial });
            return;
          }

          if (completedChars.has(index)) return;

          if (index <= currentCharIndex) {
            gsap.set(char, { color: colorAccent });
            if (!colorTransitionTimers.has(index)) {
              scheduleFinalTransition(char, index);
            }
          } else {
            gsap.set(char, { color: colorInitial });
          }
        });

        lastScrollProgress = progress;
      },
    });

    // ── Cleanup (Astro View Transitions) ───────────────────────────────────
    document.addEventListener(
      "astro:before-swap",
      () => {
        colorTransitionTimers.forEach((t) => clearTimeout(t));
        colorTransitionTimers.clear();
        completedChars.clear();
        st.kill();
        splitRefs.forEach(({ wordSplit, charSplit }) => {
          charSplit?.revert();
          wordSplit?.revert();
        });
      },
      { once: true },
    );
  }

  function initAll() {
    document.querySelectorAll(".animated-copy").forEach(initContainer);
  }

  // Run on first load and after every Astro View Transition navigation.
  document.addEventListener("DOMContentLoaded", initAll);
  document.addEventListener("astro:page-load", initAll);
</script>
