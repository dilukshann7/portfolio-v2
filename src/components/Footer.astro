---
import Galaxy from "./ui/Galaxy";
---

<footer>
  <div class="footer-container">
    <div class="footer-galaxy">
      <Galaxy
        client:visible
        density={1}
        glowIntensity={0.3}
        saturation={0}
        hueShift={140}
        mouseRepulsion={true}
        twinkleIntensity={0.3}
        rotationSpeed={0.1}
        repulsionStrength={2}
        autoCenterRepulsion={0}
        starSpeed={0.5}
        speed={1}
        transparent={true}
        globalPointer={true}
      />
    </div>
    <div id="footer-canvas"></div>

    <div class="footer-content">
      <div class="footer-row">
        <div class="footer-col">
          <h2>I make it look easy because I put in the work.</h2>
        </div>

        <div class="footer-col">
          <div class="footer-sub-col"></div>

          <div class="footer-sub-col">
            <a
              href="https://instagram.com/silknye"
              target="_blank"
              rel="noreferrer"
            >
              Instagram</a
            >
            <a
              href="https://linkedin.com/in/dilukshann7"
              target="_blank"
              rel="noreferrer"
            >
              LinkedIn</a
            >
            <a href="https://x.com/silknye" target="_blank" rel="noreferrer"
              >X / Twitter</a
            >

            <a
              href="https://github.com/dilukshann7"
              target="_blank"
              rel="noreferrer"
            >
              GitHub
            </a>
            <a href="/blog/">Blog</a>
          </div>
        </div>
      </div>

      <div class="footer-row footer-credit-row">
        <p class="footer-credit">Built by Dilukshan N.</p>
      </div>
    </div>
  </div>
</footer>

<style>
  :root {
    --base-100: #e6eed6;
    --base-200: #6200b3;
    --base-300: #ffa630;
    --base-400: #171717;
  }

  h1,
  h2,
  h3 {
    font-weight: lighter;
    line-height: 1.25;
  }

  h1 {
    font-size: clamp(4rem, 5vw, 6rem);
  }

  h2 {
    font-size: clamp(3rem, 4vw, 5rem);
  }

  h3 {
    font-size: clamp(1.25rem, 1.75vw, 2.5rem);
  }

  a {
    text-decoration: none;
    color: #fff;
    font-size: clamp(1.25rem, 1.75vw, 2.5rem);
    font-weight: lighter;
    line-height: 1.25;
  }

  p {
    font-family: "DM Sans", sans-serif;
    font-size: 0.9rem;
    font-weight: 400;
  }

  footer {
    position: relative;
    width: 100%;
    background-color: #000000;
    color: #fff;
    overflow: hidden;
    font-family: "Stack Sans Notch", sans-serif;
  }

  .footer-container {
    position: relative;
    width: 100%;
    height: 100%;
    padding: clamp(3rem, 10vw, 5rem) clamp(1.25rem, 4vw, 3rem)
      clamp(1rem, 5vw, 2rem);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transform: translateY(-35%);
    will-change: transform;
  }

  .footer-galaxy {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    opacity: 0.72;
    z-index: -1;
  }

  .footer-galaxy :global(.galaxy-container) {
    width: 100%;
    height: 100%;
  }

  #footer-canvas {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 1;
    z-index: 1;
  }

  .footer-content {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    z-index: 2;
  }

  .footer-row {
    display: flex;
    justify-content: space-between;
  }

  .footer-credit-row {
    position: relative;
    z-index: 2;
    margin-top: clamp(2rem, 6vw, 4rem);
    align-items: flex-end;
  }

  .footer-credit {
    color: rgba(255, 255, 255, 0.78);
    letter-spacing: 0.08em;
  }

  .footer-row:nth-child(1) .footer-col:nth-child(1) {
    flex: 3;
  }

  .footer-row:nth-child(1) .footer-col:nth-child(2) {
    flex: 2;
    display: flex;
    gap: 2rem;
  }

  .footer-sub-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-row h2 {
    width: 75%;
  }

  @media (max-width: 1000px) {
    .footer-container {
      padding: calc(env(safe-area-inset-top, 0px) + 4rem) 2rem
        calc(env(safe-area-inset-bottom, 0px) + 6rem) 2rem;
      transform: translateY(-20%);
    }

    #footer-canvas {
      display: none;
    }

    .footer-row:nth-child(1) {
      flex-direction: column;
      gap: 2.25rem;
    }

    .footer-row h2 {
      width: 100%;
      text-align: left;
    }

    .footer-row:nth-child(1) .footer-col:nth-child(2) {
      flex-direction: column;
      gap: 1.25rem;
      align-items: flex-start;
    }

    .footer-sub-col {
      gap: 0.35rem;
      align-items: flex-start;
    }

    a {
      font-size: clamp(1rem, 5vw, 1.35rem);
    }

    h2 {
      font-size: clamp(2.1rem, 10vw, 3.2rem);
    }
  }
</style>

<script>
  import { runPageScript } from "../lib/client/spa";

  const initFooter = () =>
    runPageScript("footer", ({ signal, onCleanup }) => {
    const footer = document.querySelector("footer");
    if (!footer) return;

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries.some((entry) => entry.isIntersecting)) {
          observer.disconnect();
          void bootFooterScene();
        }
      },
      { rootMargin: "300px 0px" },
    );

    const bootFooterScene = async () => {
      const [{ getMotionSystem }, { initTextReveal }] = await Promise.all([
        import("../lib/client/motion"),
        import("../lib/client/textReveal"),
      ]);

      const { gsap, ScrollTrigger, reducedMotion } = await getMotionSystem();
      const isMobile = window.matchMedia("(max-width: 900px)").matches;
      const hasFinePointer = window.matchMedia(
        "(hover: hover) and (pointer: fine)",
      ).matches;

      const footerContainer = document.querySelector(".footer-container");
      const mouse = { x: 0, y: 0 };
      const clamp = (value: number, min: number, max: number) =>
        Math.min(max, Math.max(min, value));
      const container = document.getElementById("footer-canvas");
      const triggers: Array<import("gsap/ScrollTrigger").ScrollTrigger> = [];

      if (!container || !footerContainer) return;

      const textRevealCleanup = await initTextReveal(
        document.querySelector("footer") ?? document,
        [
          {
            selector: ".footer-col h2",
            mode: "lines",
            scroll: true,
          },
          {
            selector: ".footer-sub-col h3",
            mode: "lines",
            scroll: true,
          },
        ],
      );

      onCleanup(() => {
        textRevealCleanup?.();
        triggers.forEach((trigger) => trigger.kill());
      });

      if (!isMobile) {
        const [THREE, { GLTFLoader }] = await Promise.all([
          import("three"),
          import("three/addons/loaders/GLTFLoader.js"),
        ]);

        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(
          50,
          container.offsetWidth / container.offsetHeight,
          0.1,
          1000,
        );
        camera.position.set(0, 0, 0.75);

        const renderer = new THREE.WebGLRenderer({
          alpha: true,
          antialias: true,
        });
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.setSize(container.offsetWidth, container.offsetHeight);
        container.appendChild(renderer.domElement);

        const directionalLight = new THREE.DirectionalLight(0xffffff, 5);
        directionalLight.position.set(1, 1, 0);
        scene.add(directionalLight);

        const loader = new GLTFLoader();
        let model: import("three").Object3D | null = null;
        const modelOffsetX = 0.2;
        let modelBaseRotationX = 0.5;
        let modelBaseZ = -1;
        let frameId: number | null = null;
        let footerVisible = false;
        let pageVisible = !document.hidden;

        if (hasFinePointer) {
          window.addEventListener(
            "pointermove",
            (e) => {
              const pointerX = (e.clientX / window.innerWidth) * 2 - 1.8;
              const pointerY = -(e.clientY / window.innerHeight) * 2 + 1;
              const pointerPivotX = model
                ? model.position.clone().project(camera).x
                : 0;

              mouse.x = clamp(pointerX - pointerPivotX, -1, 1);
              mouse.y = clamp(pointerY, -1, 1);
            },
            { signal },
          );
        }

        loader.load("/model.glb", (gltf) => {
          model = gltf.scene;

          const box = new THREE.Box3().setFromObject(model);
          const center = box.getCenter(new THREE.Vector3());
          const size = box.getSize(new THREE.Vector3());

          model.position.sub(center);
          model.position.x = modelOffsetX;
          model.position.y = 0;
          model.position.z = -1;
          model.rotation.x = 0.5;

          const maxDim = Math.max(size.x, size.y, size.z);
          const scale = 1 / maxDim;
          model.scale.setScalar(scale);

          scene.add(model);
        });

        if (!reducedMotion) {
          triggers.push(
            ScrollTrigger.create({
              trigger: "footer",
              start: "top bottom",
              end: "bottom bottom",
              scrub: true,
              onUpdate: (self) => {
                const progress = self.progress;
                const yValue = -35 * (1 - progress);
                gsap.set(footerContainer, { y: `${yValue}%` });
                modelBaseZ = -1 * (1 - progress);
                modelBaseRotationX = 0.5 * (1 - progress);
              },
            }),
          );
        }

        const renderFrame = () => {
          if (!footerVisible || !pageVisible) {
            frameId = null;
            return;
          }

          frameId = requestAnimationFrame(renderFrame);

          if (model) {
            const targetRotationY = hasFinePointer ? mouse.x * 0.3 : 0;
            const targetRotationX = hasFinePointer
              ? -mouse.y * 0.2 + modelBaseRotationX
              : modelBaseRotationX;

            model.rotation.y += (targetRotationY - model.rotation.y) * 0.05;
            model.rotation.x += (targetRotationX - model.rotation.x) * 0.05;
            model.position.z += (modelBaseZ - model.position.z) * 0.05;
          }

          renderer.render(scene, camera);
        };

        const ensureAnimation = () => {
          if (frameId === null) {
            frameId = requestAnimationFrame(renderFrame);
          }
        };

        const footerObserver = new IntersectionObserver(
          ([entry]) => {
            footerVisible = entry?.isIntersecting ?? false;
            if (footerVisible && pageVisible) {
              ensureAnimation();
            }
          },
          { rootMargin: "200px 0px" },
        );

        footerObserver.observe(container);

        document.addEventListener(
          "visibilitychange",
          () => {
            pageVisible = !document.hidden;
            if (footerVisible && pageVisible) {
              ensureAnimation();
            }
          },
          { signal },
        );

        window.addEventListener(
          "resize",
          () => {
            camera.aspect = container.offsetWidth / container.offsetHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(container.offsetWidth, container.offsetHeight);
          },
          { signal },
        );

        onCleanup(() => {
          footerObserver.disconnect();
          if (frameId !== null) {
            cancelAnimationFrame(frameId);
          }
          renderer.dispose();
          container.replaceChildren();
        });
      } else if (!reducedMotion) {
        triggers.push(
          ScrollTrigger.create({
            trigger: "footer",
            start: "top bottom",
            end: "bottom bottom",
            scrub: true,
            onUpdate: (self) => {
              const progress = self.progress;
              const yValue = -20 * (1 - progress);
              gsap.set(footerContainer, { y: `${yValue}%` });
            },
          }),
        );
      }
    };

    observer.observe(footer);
    onCleanup(() => observer.disconnect());
    });

  document.addEventListener("astro:page-load", initFooter);
</script>
