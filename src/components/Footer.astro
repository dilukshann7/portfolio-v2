---
import Galaxy from "./ui/Galaxy";
---

<footer>
  <div class="footer-container">
    <div class="footer-galaxy">
      <Galaxy
        client:visible
        density={1}
        glowIntensity={0.3}
        saturation={0}
        hueShift={140}
        mouseRepulsion={true}
        twinkleIntensity={0.3}
        rotationSpeed={0.1}
        repulsionStrength={2}
        autoCenterRepulsion={0}
        starSpeed={0.5}
        speed={1}
        transparent={true}
        globalPointer={true}
      />
    </div>
    <div id="footer-canvas"></div>

    <div class="footer-content">
      <div class="footer-row">
        <div class="footer-col">
          <h2>I make it look easy because I put in the work.</h2>
        </div>

        <div class="footer-col">
          <div class="footer-sub-col">
            <h3>Improving Everyday</h3>
            <h3>Since 2004</h3>
          </div>

          <div class="footer-sub-col">
            <a
              href="https://instagram.com/silknye"
              target="_blank"
              rel="noreferrer"
            >
              Instagram</a
            >
            <a
              href="https://linkedin.com/in/dilukshann7"
              target="_blank"
              rel="noreferrer"
            >
              LinkedIn</a
            >
            <a href="https://x.com/silknye" target="_blank" rel="noreferrer"
              >X / Twitter</a
            >

            <a
              href="https://github.com/dilukshann7"
              target="_blank"
              rel="noreferrer"
            >
              GitHub
            </a>
            <a href="/blog/">Blog</a>
            <a href="/rss.xml">RSS</a>
            <a
              href="mailto:dilukshann7@gmail.com?subject=Hello%20Dilukshan!"
              target="_blank"
              rel="noreferrer">Email Me</a
            >
          </div>
        </div>
      </div>
    </div>

    <div class="footer-row">
      <p>Built by Dilukshan N.</p>
    </div>
  </div>
</footer>

<style>
  :root {
    --base-100: #e6eed6;
    --base-200: #6200b3;
    --base-300: #ffa630;
    --base-400: #171717;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  ::-webkit-scrollbar {
    display: none;
  }

  body {
    font-family: "Stack Sans Notch", sans-serif;
  }

  h1,
  h2,
  h3 {
    font-weight: lighter;
    line-height: 1.25;
  }

  h1 {
    font-size: clamp(4rem, 5vw, 6rem);
  }

  h2 {
    font-size: clamp(3rem, 4vw, 5rem);
  }

  h3 {
    font-size: clamp(1.25rem, 1.75vw, 2.5rem);
  }

  a {
    text-decoration: none;
    color: #fff;
    font-size: clamp(1.25rem, 1.75vw, 2.5rem);
    font-weight: lighter;
    line-height: 1.25;
  }

  p {
    font-family: "DM Sans", sans-serif;
    font-size: 0.9rem;
    font-weight: 400;
  }

  section {
    position: relative;
    width: 100%;
    height: 100svh;
    padding: 2rem;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 1;
  }

  .one {
    background-color: var(--base-100);
    color: #000;
  }

  .two {
    background-color: var(--base-200);
    color: #fff;
  }

  .three {
    background-color: #ffa630;
    color: #000;
  }

  footer {
    position: relative;
    width: 100%;
    min-height: 70svh;
    background-color: #000000;
    color: #fff;
    overflow: hidden;
  }

  .footer-container {
    position: relative;
    width: 100%;
    height: 100%;
    padding: clamp(3rem, 10vw, 5rem) clamp(1.25rem, 4vw, 3rem)
      clamp(1rem, 5vw, 2rem);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transform: translateY(-35%);
    will-change: transform;
  }

  .footer-galaxy {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    opacity: 0.72;
    z-index: -1;
  }

  .footer-galaxy :global(.galaxy-container) {
    width: 100%;
    height: 100%;
  }

  #footer-canvas {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 1;
    z-index: 1;
  }

  .footer-content {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    z-index: 2;
  }

  .footer-row {
    display: flex;
    justify-content: space-between;
  }

  .footer-row:nth-child(1) .footer-col:nth-child(1) {
    flex: 3;
  }

  .footer-row:nth-child(1) .footer-col:nth-child(2) {
    flex: 2;
    display: flex;
    gap: 2rem;
  }

  .footer-sub-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-row h2 {
    width: 75%;
  }

  @media (max-width: 1000px) {
    footer {
      min-height: 92svh;
    }

    .footer-container {
      padding: calc(env(safe-area-inset-top, 0px) + 4rem) 4em
        calc(env(safe-area-inset-bottom, 0px) + 1rem) 4em;
      transform: translateY(-20%);
    }

    .footer-row:nth-child(1) {
      flex-direction: column;
      gap: 2.25rem;
    }

    .footer-row h2 {
      width: 100%;
    }

    .footer-row:nth-child(1) .footer-col:nth-child(2) {
      flex-direction: column;
      gap: 1.25rem;
    }

    .footer-sub-col {
      gap: 0.35rem;
    }

    a {
      font-size: clamp(1rem, 5vw, 1.35rem);
    }

    h2 {
      font-size: clamp(2.1rem, 10vw, 3.2rem);
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const bootFooterScene = async () => {
      const [{ getMotionSystem }, THREE, { GLTFLoader }] = await Promise.all([
        import("../lib/client/motion"),
        import("three"),
        import("three/addons/loaders/GLTFLoader.js"),
      ]);

      const { gsap, ScrollTrigger, reducedMotion } = await getMotionSystem();
      const isMobile = window.matchMedia("(max-width: 900px)").matches;
      const hasFinePointer = window.matchMedia(
        "(hover: hover) and (pointer: fine)",
      ).matches;

      const footerContainer = document.querySelector(".footer-container");
      const mouse = { x: 0, y: 0 };
      const container = document.getElementById("footer-canvas");

      if (!container || !footerContainer) return;

      if (hasFinePointer) {
        window.addEventListener("pointermove", (e) => {
          mouse.x = (e.clientX / window.innerWidth) * 2 - 1;
          mouse.y = -(e.clientY / window.innerHeight) * 2 + 1;
        });
      }

      // Only set up the Three.js renderer and load the 3D model on non-mobile devices
      if (!isMobile) {
        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(
          50,
          container.offsetWidth / container.offsetHeight,
          0.1,
          1000,
        );
        camera.position.set(0, 0, 0.75);

        const renderer = new THREE.WebGLRenderer({
          alpha: true,
          antialias: true,
        });
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.setSize(container.offsetWidth, container.offsetHeight);
        container.appendChild(renderer.domElement);

        const directionalLight = new THREE.DirectionalLight(0xffffff, 5);
        directionalLight.position.set(1, 1, 0);
        scene.add(directionalLight);

        const loader = new GLTFLoader();
        let model: import("three").Object3D | null = null;
        let modelBaseRotationX = 0.5;
        let modelBaseZ = -1;

        loader.load("/model.glb", (gltf) => {
          model = gltf.scene;

          const box = new THREE.Box3().setFromObject(model);
          const center = box.getCenter(new THREE.Vector3());
          const size = box.getSize(new THREE.Vector3());

          model.position.sub(center);
          model.position.y = 0;
          model.position.z = -1;
          model.rotation.x = 0.5;

          const maxDim = Math.max(size.x, size.y, size.z);
          const scale = 1 / maxDim;
          model.scale.setScalar(scale);

          scene.add(model);
        });

        if (!reducedMotion) {
          ScrollTrigger.create({
            trigger: "footer",
            start: "top bottom",
            end: "bottom bottom",
            scrub: true,
            onUpdate: (self) => {
              const progress = self.progress;
              const yValue = -35 * (1 - progress);
              gsap.set(footerContainer, { y: `${yValue}%` });
              modelBaseZ = -1 * (1 - progress);
              modelBaseRotationX = 0.5 * (1 - progress);
            },
          });
        }

        const animate = () => {
          requestAnimationFrame(animate);

          if (model) {
            const targetRotationY = hasFinePointer ? mouse.x * 0.3 : 0;
            const targetRotationX = hasFinePointer
              ? -mouse.y * 0.2 + modelBaseRotationX
              : modelBaseRotationX;

            model.rotation.y += (targetRotationY - model.rotation.y) * 0.05;
            model.rotation.x += (targetRotationX - model.rotation.x) * 0.05;
            model.position.z += (modelBaseZ - model.position.z) * 0.05;
          }

          renderer.render(scene, camera);
        };
        animate();

        window.addEventListener("resize", () => {
          camera.aspect = container.offsetWidth / container.offsetHeight;
          camera.updateProjectionMatrix();
          renderer.setSize(container.offsetWidth, container.offsetHeight);
        });
      } else {
        // On mobile, still handle the scroll animation for the footer container
        if (!reducedMotion) {
          ScrollTrigger.create({
            trigger: "footer",
            start: "top bottom",
            end: "bottom bottom",
            scrub: true,
            onUpdate: (self) => {
              const progress = self.progress;
              const yValue = -20 * (1 - progress);
              gsap.set(footerContainer, { y: `${yValue}%` });
            },
          });
        }
      }
    };

    const footer = document.querySelector("footer");
    if (!footer) return;

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries.some((entry) => entry.isIntersecting)) {
          observer.disconnect();
          void bootFooterScene();
        }
      },
      { rootMargin: "300px 0px" },
    );

    observer.observe(footer);
  });
</script>
