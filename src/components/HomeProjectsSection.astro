---
import { projects } from "../data/projects";

const rows = [];

for (let index = 0; index < projects.length; index += 3) {
  rows.push(
    projects.slice(index, index + 3).map((project) => ({
      project,
      proofPoint: project.caseStudy.proofPoints[0],
    })),
  );
}
---

<section class="work" id="projects">
  {
    rows.map((row) => (
      <div class="row">
        {row.map(({ project, proofPoint }) => (
          <div class="work-item">
            <a href={project.route} class="work-item-link">
              <div class="work-item-img">
                <img
                  src={project.img}
                  alt={project.name}
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="work-item-copy">
                <div class="work-item-meta">
                  <span>{project.status}</span>
                  <span>{project.timeline}</span>
                </div>
                <h3>{project.name}</h3>
                <p>{project.description}</p>
                {proofPoint && (
                  <span class="work-item-proof">
                    {proofPoint.label}: {proofPoint.value}
                  </span>
                )}
                <span class="work-item-cta">Open Case Study</span>
              </div>
            </a>
          </div>
        ))}
      </div>
    ))
  }
</section>

<style>
  .work {
    color: #0f0f0f;
    font-family: "Space Grotesk", sans-serif;
    margin-top: 4rem;
  }

  .work-intro {
    display: grid;
    gap: 0.8rem;
    width: min(960px, 100%);
    padding: clamp(1.5rem, 3vw, 2.5rem) 0 clamp(0.5rem, 1vw, 1rem);
  }

  .work-kicker,
  .work-item-meta span,
  .work-item-cta {
    margin: 0;
    font-size: 0.72rem;
    padding-left: 3px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .work-kicker {
    color: rgba(15, 15, 15, 0.5);
  }

  .work-intro-copy {
    display: grid;
    gap: 0.7rem;
  }

  .work-intro h2 {
    margin: 0;
    font-family: var(--font-melodrame);
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 0.94;
    font-weight: 400;
    max-width: 12ch;
  }

  .work-intro p {
    margin: 0;
    max-width: 42ch;
    font-family: "DM Sans", sans-serif;
    font-size: 1rem;
    line-height: 1.75;
    letter-spacing: normal;
    color: rgba(15, 15, 15, 0.68);
    padding-left: 0;
    font-weight: 400;
  }

  .work img {
    width: 100%;
    height: auto;
    display: block;
  }

  .work h3 {
    font-size: 1.25rem;
    padding-left: 2px;
    letter-spacing: -0.025rem;
    font-weight: bold;
  }

  .work p {
    font-size: 1rem;
    padding-left: 2px;
    font-weight: 500;
    letter-spacing: -0.0125rem;
  }

  .work a {
    text-decoration: none;
  }

  .work {
    position: relative;
    height: 100%;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
    overflow: hidden;
  }

  .row {
    flex: 1;
    width: 100%;
    display: flex;
    gap: 1.5rem;
  }

  .work-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .work-item-img {
    overflow: hidden;
    width: 100%;
    border-radius: 0.7rem;
    background: rgba(15, 15, 15, 0.04);
  }

  .work-item-copy p {
    color: rgba(15, 15, 15, 0.55);
  }

  .work-item-proof {
    display: block;
    margin-top: 0.85rem;
    padding-left: 2px;
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(15, 15, 15, 0.62);
  }

  .work-item-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-bottom: 0.65rem;
  }

  .work-item-meta span {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    padding: 0.35rem 0.6rem;
    border-radius: 999px;
    background: rgba(15, 15, 15, 0.05);
    color: rgba(15, 15, 15, 0.58);
  }

  .work-item-cta {
    display: inline-flex;
    margin-top: 1rem;
    color: #0f0f0f;
  }

  .work-item-link {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-decoration: none;
    color: inherit;
    width: 100%;
    height: 100%;
  }

  .work-item-link:hover {
    text-decoration: none;
    color: inherit;
  }

  .work-item-link:hover .work-item-cta {
    text-decoration: underline;
    text-underline-offset: 0.22em;
  }

  .work-item-link:focus-visible {
    outline: 2px solid rgba(15, 15, 15, 0.4);
    outline-offset: 4px;
    border-radius: 0.7rem;
  }

  .work-item-link:focus-visible .work-item-cta {
    text-decoration: underline;
    text-underline-offset: 0.22em;
  }

  @media (max-width: 1000px) {
    .work,
    .row {
      gap: 2rem;
    }

    .row {
      flex-direction: column;
    }
  }

  @media (max-width: 640px) {
    .work {
      padding: 1rem;
      gap: 1.5rem;
    }

    .work-item-meta span {
      font-size: 0.65rem;
      padding: 0.3rem 0.5rem;
      min-height: 28px;
    }

    .work-item-proof {
      font-size: 0.72rem;
    }

    .work-item-cta {
      font-size: 0.72rem;
      margin-top: 0.75rem;
    }

    .work h3 {
      font-size: 1.15rem;
    }

    .work p {
      font-size: 0.95rem;
    }
  }

  @media (max-width: 480px) {
    .work {
      padding: 0.75rem;
      gap: 1.25rem;
      margin-top: 2rem;
    }

    .work-item-img {
      border-radius: 0.5rem;
    }

    .work-item-meta span {
      font-size: 0.6rem;
      padding: 0.25rem 0.45rem;
      min-height: 26px;
    }

    .work h3 {
      font-size: 1.05rem;
    }

    .work p {
      font-size: 0.9rem;
    }

    .work-item-proof {
      font-size: 0.7rem;
      margin-top: 0.6rem;
    }

    .work-item-cta {
      font-size: 0.7rem;
      margin-top: 0.6rem;
    }
  }
</style>

<script>
  import { runPageScript } from "../lib/client/spa";

  const initHomeProjectsSection = () =>
    runPageScript("home-projects-section", ({ onCleanup }) => {
      const workContainer = document.querySelector(".work");
      if (!workContainer) return;

      const observer = new IntersectionObserver(
        (entries) => {
          if (entries.some((entry) => entry.isIntersecting)) {
            observer.disconnect();
            void boot();
          }
        },
        { rootMargin: "250px 0px" },
      );

      const boot = async () => {
        const { getMotionSystem } = await import("../lib/client/motion");
        const { gsap, ScrollTrigger, reducedMotion } = await getMotionSystem();
        const triggers: Array<ReturnType<typeof ScrollTrigger.create>> = [];
        const tweens: Array<ReturnType<typeof gsap.to>> = [];

        onCleanup(() => {
          tweens.forEach((tween) => tween.kill());
          triggers.forEach((trigger) => trigger.kill());
        });

        if (reducedMotion) return;

        gsap.set(".work-item", {
          y: 1000,
        });

        document.querySelectorAll(".row").forEach((row) => {
          const workItems = row.querySelectorAll(".work-item");

          workItems.forEach((item, itemIndex) => {
            const isLeftProjectItem = itemIndex === 0;
            gsap.set(item, {
              rotation: isLeftProjectItem ? -60 : 60,
              transformOrigin: "center center",
            });
          });

          triggers.push(
            ScrollTrigger.create({
              trigger: row,
              start: "top 70%",
              once: true,
              onEnter: () => {
                tweens.push(
                  gsap.to(workItems, {
                    y: 0,
                    rotation: 0,
                    duration: 1,
                    ease: "power4.out",
                    stagger: 0.25,
                  }),
                );
              },
            }),
          );
        });
      };

      observer.observe(workContainer);
      onCleanup(() => observer.disconnect());
    });

  document.addEventListener("astro:page-load", initHomeProjectsSection);
</script>
