---
import { actions } from "astro:actions";
import BaseLayout from "../layouts/BaseLayout.astro";
import LightRays from "../components/ui/LightRays";
import { SITE } from "../lib/site";

const pageTitle = `Contact ${SITE.name} | Hire a Full-Stack Developer & AI Engineer`;
const pageDescription =
  "Get in touch with Dilukshan Niranjan for full-stack development, AI engineering, product builds, and technical collaborations.";
const siteOrigin = Astro.site?.origin ?? Astro.url.origin;
const contactUrl = new URL("/contact", siteOrigin).toString();
const contactAction = actions.send;
const actionResult = Astro.getActionResult(contactAction);
const initialStatus = actionResult?.error
  ? actionResult.error.message
  : actionResult?.data
    ? "Message sent. I’ll get back to you soon."
    : "";
const initialTone = actionResult?.error
  ? "error"
  : initialStatus
    ? "default"
    : undefined;
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    name: pageTitle,
    description: pageDescription,
    url: contactUrl,
    mainEntity: {
      "@type": "Person",
      name: SITE.author,
      url: siteOrigin,
      email: `mailto:${SITE.email}`,
      jobTitle: SITE.profession,
      address: {
        "@type": "PostalAddress",
        addressCountry: SITE.location,
      },
      contactPoint: [
        {
          "@type": "ContactPoint",
          contactType: "business inquiries",
          email: SITE.email,
          availableLanguage: ["English"],
        },
      ],
    },
  },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  keywords={[
    ...SITE.keywords,
    "contact Dilukshan Niranjan",
    "hire AI engineer",
    "hire full-stack developer",
  ]}
  schemaType="ContactPage"
  structuredData={structuredData}
>
  <div class="cp">
    <main class="cp-main" id="main-content">
      <header class="cp-page-hero" data-nav-contrast="dark">
        <div class="cp-page-hero__bg" aria-hidden="true">
          <LightRays
            client:idle
            raysOrigin="top-center"
            raysColor="#f8f5ef"
            raysSpeed={0.55}
            lightSpread={0.42}
            rayLength={1.9}
            followMouse={true}
            mouseInfluence={0.035}
            noiseAmount={0}
            distortion={0.05}
            className="cp-page-hero__rays"
            pulsating={false}
            fadeDistance={0.9}
            saturation={0.7}
          />
        </div>

        <div class="cp-page-hero__inner">
          <nav class="cp-breadcrumb" aria-label="Breadcrumb">
            <a href="/" class="cp-back">
              <span class="cp-back__arrow" aria-hidden="true">←</span>
              Home
            </a>
            <span class="cp-breadcrumb__sep" aria-hidden="true">/</span>
            <span class="cp-breadcrumb__current">Contact</span>
          </nav>

          <div class="cp-page-hero__meta">
            <span class="cp-page-hero__eyebrow">Start a conversation</span>
            <span class="cp-page-hero__availability">Available worldwide</span>
          </div>

          <h1 class="cp-page-hero__title">
            Let&apos;s unlock the next level of possibilities.
          </h1>
          <p class="cp-page-hero__dek">{pageDescription}</p>

          <div class="cp-page-hero__footer">
            <div class="cp-page-hero__facts">
              <div class="cp-page-hero__fact">
                <span class="cp-page-hero__fact-label">Email</span>
                <span class="cp-page-hero__fact-value">{SITE.email}</span>
              </div>
              <div class="cp-page-hero__fact">
                <span class="cp-page-hero__fact-label">Location</span>
                <span class="cp-page-hero__fact-value">{SITE.location}</span>
              </div>
            </div>

            <div class="cp-page-hero__actions">
              <a href={`mailto:${SITE.email}`} class="cp-btn cp-btn--primary">
                <span>Send Email</span>
                <span aria-hidden="true">↗</span>
              </a>
              <a
                href="https://linkedin.com/in/dilukshann7"
                class="cp-btn cp-btn--ghost"
                target="_blank"
                rel="noreferrer"
              >
                <span>LinkedIn</span>
                <span aria-hidden="true">↗</span>
              </a>
            </div>
          </div>
        </div>
      </header>

      <div class="cp-shell">
        <div class="page">
          <div class="col-info">
            <div class="col-info__intro">
              <p class="col-info__eyebrow">Direct contact</p>
              <h2 class="col-info__heading">Reach out directly.</h2>
              <p class="col-info__copy">
                If you already know the shape of the project, email is the fastest
                route.
              </p>
            </div>

            <div class="col-info__details">
              <div>
                <p class="detail__label">Get in touch</p>
                <p class="detail__value">
                  <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
                </p>
              </div>
              <div>
                <p class="detail__label">Location</p>
                <p class="detail__value">{SITE.location}</p>
              </div>
              <div>
                <p class="detail__label">Social media</p>
                <p class="detail__value">
                  <a
                    href="https://x.com/silknye"
                    target="_blank"
                    rel="noreferrer"
                    >Twitter</a
                  ><br />
                  <a
                    href="https://instagram.com/silknye"
                    target="_blank"
                    rel="noreferrer">Instagram</a
                  ><br />
                  <a
                    href="https://github.com/dilukshann7"
                    target="_blank"
                    rel="noreferrer">GitHub</a
                  >
                </p>
              </div>
            </div>
          </div>

          <div class="col-form">
            <div class="form__header">
              <h2 class="form__title">Tell me about your project.</h2>
            </div>

            <form
              class="form__fields"
              method="POST"
              action={contactAction}
              novalidate
              data-contact-form
            >
              <div class="field field--trap" aria-hidden="true">
                <label class="field__label" for="f-company">Company</label>
                <input
                  id="f-company"
                  type="text"
                  name="company"
                  tabindex="-1"
                  autocomplete="off"
                />
              </div>

              <div class="field">
                <label class="field__label" for="f-name">Name</label>
                <input
                  id="f-name"
                  type="text"
                  placeholder="Your full name"
                  autocomplete="name"
                  name="name"
                  maxlength="80"
                  required
                />
              </div>

              <div class="field">
                <label class="field__label" for="f-email">Email</label>
                <input
                  id="f-email"
                  type="email"
                  placeholder="your@email.com"
                  autocomplete="email"
                  name="email"
                  maxlength="254"
                  required
                />
              </div>

              <div class="field">
                <label class="field__label" for="f-message">Message</label>
                <textarea
                  id="f-message"
                  placeholder="What are you working on?"
                  rows="4"
                  name="message"
                  minlength="10"
                  maxlength="5000"
                  required></textarea>
              </div>

              <div class="form__submit">
                <button type="submit" class="submit-btn" data-contact-submit>
                  <span>Send it</span>
                  <span class="submit-btn__arrow" aria-hidden="true">→</span>
                </button>
                <p
                  class="form__status"
                  data-contact-status
                  data-tone={initialTone}
                  aria-live="polite"
                >
                  {initialStatus}
                </p>
              </div>
            </form>
          </div>
        </div>
      </div>
    </main>

    <footer class="footer">
      <span class="footer__copy">{SITE.name}</span>
      <div class="footer__socials">
        <a href="https://x.com/silknye" target="_blank" rel="noreferrer"
          >Twitter</a
        >
        <a href="https://instagram.com/silknye" target="_blank" rel="noreferrer"
          >Instagram</a
        >
        <a href="https://github.com/dilukshann7" target="_blank" rel="noreferrer"
          >GitHub</a
        >
        <a
          href="https://linkedin.com/in/dilukshann7"
          target="_blank"
          rel="noreferrer">LinkedIn</a
        >
      </div>
    </footer>
  </div>
</BaseLayout>

<script>
  import { actions } from "astro:actions";
  import { runPageScript } from "../lib/client/spa";

  const initContactForm = () =>
    runPageScript("contact-form", ({ signal }) => {
      const form = document.querySelector<HTMLFormElement>(
        "[data-contact-form]",
      );
      const status = document.querySelector<HTMLElement>(
        "[data-contact-status]",
      );
      const submitButton = document.querySelector<HTMLButtonElement>(
        "[data-contact-submit]",
      );

      if (!form || !status || !submitButton) return;

      const setStatus = (
        message: string,
        tone: "default" | "error" = "default",
      ) => {
        status.textContent = message;
        status.dataset.tone = tone;
      };

      form.addEventListener(
        "submit",
        (event) => {
          event.preventDefault();

          const formData = new FormData(form);
          const name = String(formData.get("name") ?? "").trim();
          const email = String(formData.get("email") ?? "").trim();
          const message = String(formData.get("message") ?? "").trim();

          if (!name || !email || !message) {
            setStatus("Fill out name, email, and message first.", "error");
            return;
          }

          submitButton.disabled = true;
          submitButton.dataset.loading = "true";
          setStatus("Sending message...");

          void actions
            .send(new FormData(form))
            .then((result: any) => {
              if (result.error) {
                throw result.error;
              }

              form.reset();
              setStatus("Message sent. I’ll get back to you soon.");
            })
            .catch((error: unknown) => {
              const messageText =
                error instanceof Error
                  ? error.message
                  : "Could not send the message right now.";

              setStatus(messageText, "error");
            })
            .finally(() => {
              submitButton.disabled = false;
              delete submitButton.dataset.loading;
            });
        },
        { signal },
      );
    });

  document.addEventListener("astro:page-load", initContactForm);
</script>

<style>
  :global(body) {
    background: #fff;
    color: #0a0a08;
  }

  .cp {
    min-height: 100vh;
  }

  .cp-page-hero {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    background: linear-gradient(180deg, #020202 0%, #050505 52%, #090909 100%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .cp-page-hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    opacity: 0.78;
    z-index: 0;
  }

  .cp-page-hero__bg::before {
    content: "";
    position: absolute;
    inset: -24% -6% 28%;
    background: radial-gradient(
      circle at 50% 0%,
      rgba(184, 147, 106, 0.26),
      rgba(184, 147, 106, 0.08) 38%,
      transparent 70%
    );
    mix-blend-mode: screen;
    z-index: 1;
  }

  .cp-page-hero__bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.08) 0%,
      rgba(0, 0, 0, 0.36) 54%,
      rgba(0, 0, 0, 0.72) 100%
    );
    z-index: 1;
  }

  .cp-page-hero__bg :global(.cp-page-hero__rays) {
    width: 100%;
    height: 100%;
    opacity: 0.92;
  }

  .cp-page-hero__inner {
    position: relative;
    z-index: 1;
    width: 100%;
    margin: 0 auto;
    padding-top: calc(64px + clamp(2rem, 4vw, 3rem));
    padding-bottom: clamp(3rem, 5vw, 5rem);
    padding-left: clamp(1.5rem, 4vw, 3.5rem);
    padding-right: clamp(1.5rem, 4vw, 3.5rem);
  }

  .cp-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: clamp(1.5rem, 3vw, 2.25rem);
  }

  .cp-back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.72);
    transition:
      color 200ms,
      gap 200ms;
  }

  .cp-back:hover {
    color: rgba(255, 255, 255, 0.98);
    gap: 0.75rem;
  }

  .cp-back__arrow {
    transition: transform 200ms;
  }

  .cp-back:hover .cp-back__arrow {
    transform: translateX(-3px);
  }

  .cp-breadcrumb__sep {
    font-family: var(--font-melodrame);
    font-style: italic;
    color: rgba(255, 255, 255, 0.32);
    font-size: 0.9rem;
    line-height: 1;
  }

  .cp-breadcrumb__current {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #c17d3c;
  }

  .cp-page-hero__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem 1rem;
    margin-bottom: 1.25rem;
  }

  .cp-page-hero__eyebrow {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #d8b38c;
  }

  .cp-page-hero__availability {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
  }

  .cp-page-hero__title {
    font-family: var(--font-melodrame);
    font-size: clamp(2.8rem, 5.5vw, 5.5rem);
    font-weight: 300;
    line-height: 0.92;
    letter-spacing: -0.02em;
    color: rgba(255, 255, 255, 0.96);
    margin: 0;
    max-width: 15ch;
    text-wrap: balance;
  }

  .cp-page-hero__dek {
    font-size: clamp(1rem, 1.2vw, 1.1rem);
    line-height: 1.78;
    color: rgba(255, 255, 255, 0.72);
    margin: 1rem 0 0;
    max-width: 66ch;
  }

  .cp-page-hero__footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-top: 2rem;
  }

  .cp-page-hero__facts {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .cp-page-hero__fact {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .cp-page-hero__fact-label {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.42);
  }

  .cp-page-hero__fact-value {
    font-size: 1rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.88);
  }

  .cp-page-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .cp-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.9rem 1.6rem;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1.5px solid transparent;
    transition:
      background 220ms,
      color 220ms,
      border-color 220ms;
  }

  .cp-btn--primary {
    background: rgba(255, 255, 255, 0.94);
    color: #050505;
    border-color: rgba(255, 255, 255, 0.94);
  }

  .cp-btn--primary:hover {
    background: transparent;
    color: rgba(255, 255, 255, 0.96);
    border-color: rgba(255, 255, 255, 0.28);
  }

  .cp-btn--ghost {
    color: rgba(255, 255, 255, 0.82);
    border-color: rgba(255, 255, 255, 0.18);
  }

  .cp-btn--ghost:hover {
    background: rgba(255, 255, 255, 0.94);
    color: #050505;
    border-color: rgba(255, 255, 255, 0.94);
  }

  .cp-shell {
    width: min(1500px, 86%);
    margin: 0 auto;
    padding: clamp(2rem, 4vw, 3rem) clamp(1.5rem, 4vw, 3.5rem)
      clamp(4rem, 7vw, 7rem);
  }

  .page {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border: 1px solid rgba(10, 10, 8, 0.12);
  }

  .col-info {
    padding: clamp(2rem, 3.5vw, 3.5rem) clamp(2rem, 4vw, 4rem);
    border-right: 1px solid rgba(10, 10, 8, 0.12);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2.5rem;
  }

  .col-info__intro {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .col-info__eyebrow {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(10, 10, 8, 0.45);
    margin: 0;
  }

  .col-info__heading {
    font-family: var(--font-melodrame);
    font-size: clamp(2rem, 3vw, 3rem);
    font-weight: 300;
    line-height: 0.96;
    letter-spacing: -0.02em;
    color: #0a0a08;
    margin: 0;
  }

  .col-info__copy {
    font-size: 0.92rem;
    line-height: 1.7;
    color: rgba(10, 10, 8, 0.6);
    margin: 0;
    max-width: 34ch;
  }

  .col-info__details {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .detail__label {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(10, 10, 8, 0.45);
    margin-bottom: 0.45rem;
  }

  .detail__value {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #0a0a08;
    line-height: 2;
  }

  .detail__value a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid rgba(10, 10, 8, 0.18);
    padding-bottom: 1px;
    transition: border-color 200ms;
  }

  .detail__value a:hover {
    border-color: #0a0a08;
  }

  .col-form {
    padding: clamp(2rem, 3.5vw, 3.5rem) clamp(2rem, 4vw, 4rem);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .form__header {
    margin-bottom: 2rem;
  }

  .form__title {
    font-family: var(--font-melodrame);
    font-size: clamp(2rem, 3vw, 3rem);
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -0.01em;
    color: #0a0a08;
    margin: 0;
  }

  .form__fields {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 0;
  }

  .field {
    position: relative;
    border-bottom: 1px solid rgba(10, 10, 8, 0.12);
    transition: border-color 250ms;
  }

  .field--trap {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .field:first-child {
    border-top: 1px solid rgba(10, 10, 8, 0.12);
  }

  .field:focus-within {
    border-color: #0a0a08;
  }

  .field__label {
    position: absolute;
    top: 0.85rem;
    left: 0;
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(10, 10, 8, 0.45);
    pointer-events: none;
    transition: color 250ms;
  }

  .field:focus-within .field__label {
    color: #c17d3c;
  }

  .field input,
  .field textarea {
    display: block;
    width: 100%;
    background: transparent;
    border: none;
    outline: none;
    padding: 2rem 0 0.75rem;
    font-family: var(--font-melodrame);
    font-size: clamp(1.2rem, 1.6vw, 1.75rem);
    font-weight: 300;
    color: #0a0a08;
    letter-spacing: -0.01em;
    resize: none;
  }

  .field input::placeholder,
  .field textarea::placeholder {
    color: rgba(10, 10, 8, 0.18);
  }

  .field textarea {
    min-height: 90px;
  }

  .form__submit {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 1rem;
    padding-top: 1.75rem;
  }

  .form__status {
    min-height: 1.5rem;
    margin: 0;
    margin-left: auto;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(10, 10, 8, 0.42);
    text-align: right;
  }

  .form__status[data-tone="error"] {
    color: #a13b24;
  }

  .form__status[data-tone="default"] {
    color: rgba(10, 10, 8, 0.42);
  }

  .submit-btn {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    background: #0a0a08;
    color: #fff;
    border: none;
    cursor: pointer;
    padding: 1rem 1.6rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    border-radius: 999px;
    transition: gap 200ms;
    position: relative;
    overflow: hidden;
  }

  .submit-btn:disabled {
    cursor: wait;
    opacity: 0.8;
  }

  .submit-btn[data-loading="true"] {
    gap: 1.4rem;
  }

  .submit-btn[data-loading="true"]::before {
    transform: scaleX(1);
  }

  .submit-btn::before {
    content: "";
    position: absolute;
    inset: 0;
    background: #c17d3c;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 350ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .submit-btn:hover::before {
    transform: scaleX(1);
  }

  .submit-btn:hover {
    gap: 1.4rem;
  }

  .submit-btn > * {
    position: relative;
    z-index: 1;
  }

  .submit-btn__arrow {
    transition: transform 200ms;
  }

  .submit-btn:hover .submit-btn__arrow {
    transform: translateX(3px);
  }

  .footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem clamp(1.5rem, 3vw, 3rem);
    border-top: 1px solid rgba(10, 10, 8, 0.12);
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .footer__copy {
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(10, 10, 8, 0.4);
  }

  .footer__socials {
    display: flex;
    gap: 1.5rem;
  }

