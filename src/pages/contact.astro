---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../lib/site";

const pageTitle = `Contact | ${SITE.name}`;
---

<BaseLayout title={pageTitle} description={SITE.description}>
  <div class="page">
    <div class="col-info">
      <div>
        <h1 class="col-info__heading">
          Let's unlock<br />
          the next level<br />
          of <em>possibilities.</em>
        </h1>
      </div>

      <div class="col-info__details">
        <div>
          <p class="detail__label">Get in touch</p>
          <p class="detail__value">
            <a href="mailto:info@dilukshan.dev">info@dilukshan.dev</a>
          </p>
        </div>
        <div>
          <p class="detail__label">Location</p>
          <p class="detail__value">Sri Lanka</p>
        </div>
        <div>
          <p class="detail__label">Social media</p>
          <p class="detail__value">
            <a href="https://x.com/silknye" target="_blank" rel="noreferrer"
              >Twitter</a
            ><br />
            <a
              href="https://instagram.com/silknye"
              target="_blank"
              rel="noreferrer">Instagram</a
            ><br />
            <a
              href="https://github.com/dilukshann7"
              target="_blank"
              rel="noreferrer">GitHub</a
            >
          </p>
        </div>
      </div>
    </div>

    <div class="col-form">
      <div class="form__header">
        <h2 class="form__title">Tell me about<br />your project.</h2>
      </div>

      <form class="form__fields" novalidate>
        <div class="field">
          <label class="field__label" for="f-name">Name</label>
          <input
            id="f-name"
            type="text"
            placeholder="Your full name"
            autocomplete="name"
          />
        </div>

        <div class="field">
          <label class="field__label" for="f-email">Email</label>
          <input
            id="f-email"
            type="email"
            placeholder="your@email.com"
            autocomplete="email"
          />
        </div>

        <div class="field">
          <label class="field__label" for="f-message">Message</label>
          <textarea
            id="f-message"
            placeholder="What are you working on?"
            rows="4"></textarea>
        </div>

        <div class="form__submit">
          <p class="form__note">
            I'll get back to<br />you as soon as possible.
          </p>
          <button type="submit" class="submit-btn">
            <span>Send it</span>
            <span class="submit-btn__arrow" aria-hidden="true">→</span>
          </button>
        </div>
      </form>
    </div>
  </div>

  <footer class="footer">
    <span class="footer__copy">{SITE.name}</span>
    <div class="footer__socials">
      <a href="https://x.com/silknye" target="_blank" rel="noreferrer"
        >Twitter</a
      >
      <a href="https://instagram.com/silknye" target="_blank" rel="noreferrer"
        >Instagram</a
      >
      <a href="https://github.com/dilukshann7" target="_blank" rel="noreferrer"
        >GitHub</a
      >
      <a
        href="https://linkedin.com/in/dilukshann7"
        target="_blank"
        rel="noreferrer">LinkedIn</a
      >
    </div>
  </footer>
</BaseLayout>

<style>
  :global(body) {
    background: #fff;
    color: #0a0a08;
    height: 100dvh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .page {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 0; /* allow flex child to shrink */
  }

  .col-info {
    padding: clamp(2rem, 3.5vw, 3.5rem) clamp(2rem, 4vw, 4rem);
    border-right: 1px solid rgba(10, 10, 8, 0.12);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
  }

  .col-info__heading {
    font-family: var(--font-melodrame);
    font-size: clamp(3rem, 5vw, 5rem);
    font-weight: 300;
    line-height: 0.93;
    letter-spacing: -0.02em;
    color: #0a0a08;
  }

  .col-info__heading em {
    font-style: italic;
    color: rgba(10, 10, 8, 0.45);
  }

  .col-info__details {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .detail__label {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(10, 10, 8, 0.45);
    margin-bottom: 0.45rem;
  }

  .detail__value {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #0a0a08;
    line-height: 2;
  }

  .detail__value a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid rgba(10, 10, 8, 0.18);
    padding-bottom: 1px;
    transition: border-color 200ms;
  }

  .detail__value a:hover {
    border-color: #0a0a08;
  }

  .col-info__watermark {
    font-family: var(--font-melodrame);
    font-size: clamp(5rem, 9vw, 10rem);
    font-weight: 300;
    line-height: 0.9;
    color: rgba(10, 10, 8, 0.06);
    letter-spacing: -0.04em;
    user-select: none;
  }

  .col-form {
    padding: clamp(2rem, 3.5vw, 3.5rem) clamp(2rem, 4vw, 4rem);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
  }

  .form__header {
    margin-bottom: 2rem;
  }

  .form__title {
    font-family: var(--font-melodrame);
    font-size: clamp(2rem, 3vw, 3rem);
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -0.01em;
    color: #0a0a08;
  }

  .form__fields {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
    justify-content: space-between;
  }

  .field {
    position: relative;
    border-bottom: 1px solid rgba(10, 10, 8, 0.12);
    transition: border-color 250ms;
  }

  .field:first-child {
    border-top: 1px solid rgba(10, 10, 8, 0.12);
  }
  .field:focus-within {
    border-color: #0a0a08;
  }

  .field__label {
    position: absolute;
    top: 0.85rem;
    left: 0;
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(10, 10, 8, 0.45);
    pointer-events: none;
    transition: color 250ms;
  }

  .field:focus-within .field__label {
    color: #c17d3c;
  }

  .field input,
  .field textarea {
    display: block;
    width: 100%;
    background: transparent;
    border: none;
    outline: none;
    padding: 2rem 0 0.75rem;
    font-family: var(--font-melodrame);
    font-size: clamp(1.2rem, 1.6vw, 1.75rem);
    font-weight: 300;
    color: #0a0a08;
    letter-spacing: -0.01em;
    resize: none;
  }

  .field input::placeholder,
  .field textarea::placeholder {
    color: rgba(10, 10, 8, 0.18);
  }

  .field textarea {
    min-height: 90px;
  }

  .form__submit {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.75rem;
  }

  .form__note {
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(10, 10, 8, 0.45);
    max-width: 22ch;
    line-height: 1.65;
  }

  .submit-btn {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    background: #0a0a08;
    color: #fff;
    border: none;
    cursor: pointer;
    padding: 1rem 1.6rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    border-radius: 999px;
    transition: gap 200ms;
    position: relative;
    overflow: hidden;
  }

  .submit-btn::before {
    content: "";
    position: absolute;
    inset: 0;
    background: #c17d3c;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 350ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .submit-btn:hover::before {
    transform: scaleX(1);
  }
  .submit-btn:hover {
    gap: 1.4rem;
  }
  .submit-btn > * {
    position: relative;
    z-index: 1;
  }
  .submit-btn__arrow {
    transition: transform 200ms;
  }
  .submit-btn:hover .submit-btn__arrow {
    transform: translateX(3px);
  }

  .footer {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem clamp(1.5rem, 3vw, 3rem);
    border-top: 1px solid rgba(10, 10, 8, 0.12);
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .footer__copy {
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(10, 10, 8, 0.4);
  }

  .footer__socials {
    display: flex;
    gap: 1.5rem;
  }

  .footer__socials a {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(10, 10, 8, 0.4);
    transition: color 200ms;
  }

  .footer__socials a:hover {
    color: #0a0a08;
  }

  @media (max-width: 800px) {
    :global(body) {
      height: auto;
      overflow: auto;
    }

    .page {
      grid-template-columns: 1fr;
    }

    .col-info {
      border-right: none;
      border-bottom: 1px solid rgba(10, 10, 8, 0.12);
    }

    .col-info__watermark {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .col-info,
    .col-form {
      padding: clamp(1.5rem, 3vw, 2rem) clamp(1.25rem, 3vw, 1.5rem);
    }

    .col-info__heading {
      font-size: clamp(2.2rem, 10vw, 3rem);
    }

    .form__title {
      font-size: clamp(1.6rem, 6vw, 2rem);
    }

    .form__header {
      margin-bottom: 1.25rem;
    }

    .field input,
    .field textarea {
      font-size: clamp(1rem, 4vw, 1.25rem);
      padding: 1.75rem 0 0.65rem;
      min-height: 44px;
    }

    .field textarea {
      min-height: 70px;
    }

    .form__submit {
      flex-direction: column;
      gap: 1rem;
      align-items: stretch;
    }

    .form__note {
      text-align: center;
    }

    .submit-btn {
      justify-content: center;
    }

    .col-info__details {
      gap: 1.25rem;
    }

    .footer__socials {
      gap: 1rem;
    }
  }
</style>
