---
import { actions } from "astro:actions";
import BaseLayout from "../layouts/BaseLayout.astro";
import LightRays from "../components/ui/LightRays";
import { SITE } from "../lib/site";

const pageTitle = `Contact ${SITE.name} | Hire a Full-Stack Developer & AI Engineer`;
const pageDescription =
  "Get in touch with Dilukshan Niranjan for full-stack development, AI engineering, product builds, and technical collaborations.";
const siteOrigin = Astro.site?.origin ?? Astro.url.origin;
const contactUrl = new URL("/contact", siteOrigin).toString();
const contactAction = actions.send;
const actionResult = Astro.getActionResult(contactAction);
const initialStatus = actionResult?.error
  ? actionResult.error.message
  : actionResult?.data
    ? "Message sent. I’ll get back to you soon."
    : "";
const initialTone = actionResult?.error
  ? "error"
  : initialStatus
    ? "default"
    : undefined;
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    name: pageTitle,
    description: pageDescription,
    url: contactUrl,
    mainEntity: {
      "@type": "Person",
      name: SITE.author,
      url: siteOrigin,
      email: `mailto:${SITE.email}`,
      jobTitle: SITE.profession,
      address: {
        "@type": "PostalAddress",
        addressCountry: SITE.location,
      },
      contactPoint: [
        {
          "@type": "ContactPoint",
          contactType: "business inquiries",
          email: SITE.email,
          availableLanguage: ["English"],
        },
      ],
    },
  },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  keywords={[
    ...SITE.keywords,
    "contact Dilukshan Niranjan",
    "hire AI engineer",
    "hire full-stack developer",
  ]}
  schemaType="ContactPage"
  structuredData={structuredData}
>
  <div class="cp">
    <main class="cp-main" id="main-content">
      <header class="cp-page-hero" data-nav-contrast="dark">
        <div class="cp-page-hero__bg" aria-hidden="true">
          <LightRays
            client:idle
            raysOrigin="top-center"
            raysColor="#f8f5ef"
            raysSpeed={0.55}
            lightSpread={0.42}
            rayLength={1.9}
            followMouse={true}
            mouseInfluence={0.035}
            noiseAmount={0}
            distortion={0.05}
            className="cp-page-hero__rays"
            pulsating={false}
            fadeDistance={0.9}
            saturation={0.7}
          />
        </div>

        <div class="cp-page-hero__inner">
          <nav class="cp-breadcrumb" aria-label="Breadcrumb">
            <a href="/" class="cp-back">
              <span class="cp-back__arrow" aria-hidden="true">←</span>
              Home
            </a>
            <span class="cp-breadcrumb__sep" aria-hidden="true">/</span>
            <span class="cp-breadcrumb__current">Contact</span>
          </nav>

          <div class="cp-page-hero__meta">
            <span class="cp-page-hero__eyebrow">Start a conversation</span>
            <span class="cp-page-hero__availability">Available worldwide</span>
          </div>

          <h1 class="cp-page-hero__title">
            Let&apos;s unlock the next level of possibilities.
          </h1>
          <p class="cp-page-hero__dek">{pageDescription}</p>

          <div class="cp-page-hero__footer">
            <div class="cp-page-hero__facts">
              <div class="cp-page-hero__fact">
                <span class="cp-page-hero__fact-label">Email</span>
                <span class="cp-page-hero__fact-value">{SITE.email}</span>
              </div>
              <div class="cp-page-hero__fact">
                <span class="cp-page-hero__fact-label">Location</span>
                <span class="cp-page-hero__fact-value">{SITE.location}</span>
              </div>
            </div>

            <div class="cp-page-hero__actions">
              <a href={`mailto:${SITE.email}`} class="cp-btn cp-btn--primary">
                <span>Send Email</span>
                <span aria-hidden="true">↗</span>
              </a>
              <a
                href="https://linkedin.com/in/dilukshann7"
                class="cp-btn cp-btn--ghost"
                target="_blank"
                rel="noreferrer"
              >
                <span>LinkedIn</span>
                <span aria-hidden="true">↗</span>
              </a>
            </div>
          </div>
        </div>
      </header>

      <div class="cp-shell">
        <div class="page">
          <div class="col-info">
            <div class="col-info__intro">
              <p class="col-info__eyebrow">Direct contact</p>
              <h2 class="col-info__heading">Reach out directly.</h2>
              <p class="col-info__copy">
                If you already know the shape of the project, email is the
                fastest route.
              </p>
            </div>

            <div class="col-info__details">
              <div>
                <p class="detail__label">Get in touch</p>
                <p class="detail__value">
                  <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
                </p>
              </div>
              <div>
                <p class="detail__label">Location</p>
                <p class="detail__value">{SITE.location}</p>
              </div>
              <div>
                <p class="detail__label">Social media</p>
                <p class="detail__value">
                  <a
                    href="https://x.com/silknye"
                    target="_blank"
                    rel="noreferrer">Twitter</a
                  ><br />
                  <a
                    href="https://instagram.com/silknye"
                    target="_blank"
                    rel="noreferrer">Instagram</a
                  ><br />
                  <a
                    href="https://github.com/dilukshann7"
                    target="_blank"
                    rel="noreferrer">GitHub</a
                  >
                </p>
              </div>
            </div>
          </div>

          <div class="col-form">
            <div class="form__header">
              <h2 class="form__title">Tell me about your project.</h2>
            </div>

            <form
              class="form__fields"
              method="POST"
              action={contactAction}
              novalidate
              data-contact-form
            >
              <div class="field field--trap" aria-hidden="true">
                <label class="field__label" for="f-company">Company</label>
                <input
                  id="f-company"
                  type="text"
                  name="company"
                  tabindex="-1"
                  autocomplete="off"
                />
              </div>

              <div class="field">
                <label class="field__label" for="f-name">Name</label>
                <input
                  id="f-name"
                  type="text"
                  placeholder="Your full name"
                  autocomplete="name"
                  name="name"
                  maxlength="80"
                  required
                />
              </div>

              <div class="field">
                <label class="field__label" for="f-email">Email</label>
                <input
                  id="f-email"
                  type="email"
                  placeholder="your@email.com"
                  autocomplete="email"
                  name="email"
                  maxlength="254"
                  required
                />
              </div>

              <div class="field">
                <label class="field__label" for="f-message">Message</label>
                <textarea
                  id="f-message"
                  placeholder="What are you working on?"
                  rows="4"
                  name="message"
                  minlength="10"
                  maxlength="5000"
                  required></textarea>
              </div>

              <div class="form__submit">
                <button type="submit" class="submit-btn" data-contact-submit>
                  <span>Send it</span>
                  <span class="submit-btn__arrow" aria-hidden="true">→</span>
                </button>
                <p
                  class="form__status"
                  data-contact-status
                  data-tone={initialTone}
                  aria-live="polite"
                >
                  {initialStatus}
                </p>
              </div>
            </form>
          </div>
        </div>
      </div>
    </main>

    <footer class="footer">
      <span class="footer__copy">{SITE.name}</span>
      <div class="footer__socials">
        <a href="https://x.com/silknye" target="_blank" rel="noreferrer"
          >Twitter</a
        >
        <a href="https://instagram.com/silknye" target="_blank" rel="noreferrer"
          >Instagram</a
        >
        <a
          href="https://github.com/dilukshann7"
          target="_blank"
          rel="noreferrer">GitHub</a
        >
        <a
          href="https://linkedin.com/in/dilukshann7"
          target="_blank"
          rel="noreferrer">LinkedIn</a
        >
      </div>
    </footer>
  </div>
</BaseLayout>

<script>
  import { actions } from "astro:actions";
  import { runPageScript } from "../lib/client/spa";

  const initContactForm = () =>
    runPageScript("contact-form", ({ signal }) => {
      const form = document.querySelector<HTMLFormElement>(
        "[data-contact-form]",
      );
      const status = document.querySelector<HTMLElement>(
        "[data-contact-status]",
      );
      const submitButton = document.querySelector<HTMLButtonElement>(
        "[data-contact-submit]",
      );

      if (!form || !status || !submitButton) return;

      const setStatus = (
        message: string,
        tone: "default" | "error" = "default",
      ) => {
        status.textContent = message;
        status.dataset.tone = tone;
      };

      form.addEventListener(
        "submit",
        (event) => {
          event.preventDefault();

          const formData = new FormData(form);
          const name = String(formData.get("name") ?? "").trim();
          const email = String(formData.get("email") ?? "").trim();
          const message = String(formData.get("message") ?? "").trim();

          if (!name || !email || !message) {
            setStatus("Fill out name, email, and message first.", "error");
            return;
          }

          submitButton.disabled = true;
          submitButton.dataset.loading = "true";
          setStatus("Sending message...");

          void actions
            .send(new FormData(form))
            .then((result: any) => {
              if (result.error) {
                throw result.error;
              }

              form.reset();
              setStatus("Message sent. I’ll get back to you soon.");
            })
            .catch((error: unknown) => {
              const messageText =
                error instanceof Error
                  ? error.message
                  : "Could not send the message right now.";

              setStatus(messageText, "error");
            })
            .finally(() => {
              submitButton.disabled = false;
              delete submitButton.dataset.loading;
            });
        },
        { signal },
      );
    });

  document.addEventListener("astro:page-load", initContactForm);
</script>

<style>
  :global(body) {
    background: #f5f5f7;
    color: #1a1a1e;
  }

  .cp {
    --bg: #f5f5f7;
    --bg-1: #ffffff;
    --bg-2: #f0f0f2;
    --bg-hover: #f8f8fa;

    --border: rgba(0, 0, 0, 0.07);
    --border-md: rgba(0, 0, 0, 0.1);
    --border-strong: rgba(0, 0, 0, 0.16);

    --silver: #8e8e93;
    --silver-light: #aeaeb2;
    --silver-dim: rgba(142, 142, 147, 0.5);
    --silver-faint: rgba(142, 142, 147, 0.1);

    --glass-bg: rgba(255, 255, 255, 0.62);
    --glass-border: rgba(255, 255, 255, 0.75);

    --text-primary: #1a1a1e;
    --text-secondary: rgba(26, 26, 30, 0.52);
    --text-tertiary: rgba(26, 26, 30, 0.32);
    --text-disabled: rgba(26, 26, 30, 0.18);

    --f-display: "Inter", system-ui, sans-serif;
    --f-mono: "JetBrains Mono", "Fira Code", monospace;
    --f-body: "Inter", system-ui, sans-serif;

    --radius-xs: 4px;
    --radius-sm: 8px;
    --radius: 12px;
    --radius-lg: 16px;

    --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
    --ease-standard: cubic-bezier(0.4, 0, 0.2, 1);

    --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.06), 0 1px 2px rgba(0, 0, 0, 0.04);
    --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.07), 0 1px 4px rgba(0, 0, 0, 0.05);
    --shadow-lg: 0 12px 40px rgba(0, 0, 0, 0.09), 0 2px 8px rgba(0, 0, 0, 0.05);

    min-height: 100vh;
    font-family: var(--f-body);
    -webkit-font-smoothing: antialiased;
  }

  .cp-page-hero {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    background: #080808;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .cp-page-hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }

  .cp-page-hero__bg::before {
    content: "";
    position: absolute;
    inset: -24% -6% 28%;
    background: radial-gradient(
      circle at 50% 0%,
      rgba(200, 200, 210, 0.18),
      rgba(180, 180, 200, 0.06) 38%,
      transparent 70%
    );
    mix-blend-mode: screen;
    z-index: 1;
  }

  .cp-page-hero__bg::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 45%;
    background: linear-gradient(to bottom, transparent, #080808);
    z-index: 2;
  }

  .cp-page-hero__bg :global(.cp-page-hero__rays) {
    width: 100%;
    height: 100%;
    opacity: 0.82;
  }

  .cp-page-hero__inner {
    position: relative;
    z-index: 1;
    width: 100%;
    margin: 0 auto;
    padding-top: calc(64px + clamp(2rem, 4vw, 3rem));
    padding-bottom: clamp(3rem, 5vw, 5rem);
    padding-left: clamp(1.5rem, 4vw, 3.5rem);
    padding-right: clamp(1.5rem, 4vw, 3.5rem);
  }

  .cp-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: clamp(1.5rem, 3vw, 2.25rem);
  }

  .cp-back {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.75rem;
    font-weight: 450;
    letter-spacing: -0.01em;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.38);
    transition:
      color 140ms var(--ease-standard),
      gap 140ms var(--ease-standard);
  }

  .cp-back:hover {
    color: rgba(255, 255, 255, 0.7);
    gap: 0.55rem;
  }

  .cp-back__arrow {
    transition: transform 200ms var(--ease-out-expo);
  }

  .cp-back:hover .cp-back__arrow {
    transform: translateX(-2px);
  }

  .cp-breadcrumb__sep {
    color: rgba(255, 255, 255, 0.18);
    font-size: 0.7rem;
  }

  .cp-breadcrumb__current {
    font-size: 0.75rem;
    font-weight: 450;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: -0.01em;
  }

  .cp-page-hero__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem 0.65rem;
    margin-bottom: 1.5rem;
  }

  .cp-page-hero__eyebrow {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: rgba(255, 255, 255, 0.5);
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 0.22rem 0.6rem;
    border-radius: var(--radius-xs);
  }

  .cp-page-hero__availability {
    font-family: var(--f-mono);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.32);
  }

  .cp-page-hero__title {
    font-family: var(--f-display);
    font-size: clamp(2.6rem, 5.5vw, 5.25rem);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: rgba(255, 255, 255, 0.96);
    margin: 0;
    max-width: 16ch;
    text-wrap: balance;
  }

  .cp-page-hero__dek {
    font-size: clamp(0.9rem, 1.15vw, 1.05rem);
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.52);
    margin: 1rem 0 0;
    max-width: 60ch;
    font-weight: 400;
    letter-spacing: -0.01em;
  }

  .cp-page-hero__footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-top: 2rem;
  }

  .cp-page-hero__facts {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .cp-page-hero__fact {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .cp-page-hero__fact-label {
    font-family: var(--f-mono);
    font-size: 0.55rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.28);
  }

  .cp-page-hero__fact-value {
    font-size: 0.9rem;
    font-weight: 450;
    color: rgba(255, 255, 255, 0.72);
    letter-spacing: -0.01em;
  }

  .cp-page-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .cp-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.55rem 1.1rem;
    font-family: var(--f-body);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    text-transform: none;
    text-decoration: none;
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition:
      background 140ms var(--ease-standard),
      color 140ms var(--ease-standard),
      border-color 140ms var(--ease-standard);
    white-space: nowrap;
  }

  .cp-btn--primary {
    background: var(--silver-faint);
    color: rgba(255, 255, 255, 0.9);
    border-color: rgba(200, 200, 204, 0.18);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .cp-btn--primary:hover {
    background: rgba(200, 200, 204, 0.18);
    border-color: rgba(200, 200, 204, 0.28);
  }

  .cp-btn--ghost {
    background: transparent;
    color: rgba(255, 255, 255, 0.55);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .cp-btn--ghost:hover {
    background: rgba(255, 255, 255, 0.07);
    color: rgba(255, 255, 255, 0.85);
    border-color: rgba(255, 255, 255, 0.18);
  }

  .cp-shell {
    width: min(1400px, 90%);
    margin: 0 auto;
    padding: clamp(2rem, 4vw, 3rem) clamp(1.5rem, 4vw, 3.5rem)
      clamp(4rem, 7vw, 7rem);
  }

  .page {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border: 1px solid rgba(255, 255, 255, 0.7);
    background: var(--glass-bg);
    backdrop-filter: blur(20px) saturate(1.6);
    -webkit-backdrop-filter: blur(20px) saturate(1.6);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow:
      var(--shadow-lg),
      inset 0 1px 0 rgba(255, 255, 255, 0.8);
  }

  .col-info {
    padding: clamp(2rem, 3.5vw, 3.5rem) clamp(1.75rem, 3.5vw, 3rem);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2.5rem;
  }

  .col-info__intro {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .col-info__eyebrow {
    font-family: var(--f-mono);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin: 0;
  }

  .col-info__heading {
    font-family: var(--f-display);
    font-size: clamp(1.7rem, 2.6vw, 2.6rem);
    font-weight: 680;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--text-primary);
    margin: 0;
  }

  .col-info__copy {
    font-size: 0.88rem;
    line-height: 1.72;
    color: var(--text-secondary);
    margin: 0;
    max-width: 34ch;
    letter-spacing: -0.005em;
  }

  .col-info__details {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .detail__label {
    font-family: var(--f-mono);
    font-size: 0.55rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin: 0 0 0.35rem;
  }

  .detail__value {
    font-size: 0.85rem;
    font-weight: 450;
    color: var(--text-primary);
    line-height: 1.9;
    margin: 0;
    letter-spacing: -0.005em;
  }

  .detail__value a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid var(--border-md);
    padding-bottom: 1px;
    transition:
      border-color 140ms,
      color 140ms;
  }

  .detail__value a:hover {
    border-color: var(--silver);
    color: var(--silver);
  }

  .col-form {
    padding: clamp(2rem, 3.5vw, 3.5rem) clamp(1.75rem, 3.5vw, 3rem);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.75rem;
  }

  .form__header {
    margin-bottom: 0;
  }

  .form__title {
    font-family: var(--f-display);
    font-size: clamp(1.7rem, 2.6vw, 2.6rem);
    font-weight: 680;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--text-primary);
    margin: 0;
  }

  .form__fields {
    display: flex;
    flex-direction: column;
    gap: 0;
    flex: 1;
  }

  .field {
    position: relative;
    border-bottom: 1px solid var(--border-md);
    transition: border-color 200ms;
  }

  .field--trap {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .field:first-child {
    border-top: 1px solid var(--border-md);
  }

  .field:focus-within {
    border-color: var(--silver);
  }

  .field__label {
    position: absolute;
    top: 0.75rem;
    left: 0;
    font-family: var(--f-mono);
    font-size: 0.55rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    pointer-events: none;
    transition: color 200ms;
  }

  .field:focus-within .field__label {
    color: var(--silver);
  }

  .field input,
  .field textarea {
    display: block;
    width: 100%;
    background: transparent;
    border: none;
    outline: none;
    padding: 1.75rem 0 0.65rem;
    font-family: var(--f-display);
    font-size: clamp(1.1rem, 1.5vw, 1.5rem);
    font-weight: 580;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    resize: none;
  }

