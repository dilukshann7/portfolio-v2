---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import LightRays from "../components/ui/LightRays";
import { projects, type Project } from "../data/projects";
import { SITE } from "../lib/site";
import ProjectTech from "@/components/ProjectTech.astro";

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
const { caseStudy } = project;
const siteOrigin = Astro.site?.origin ?? Astro.url.origin;
const projectUrl = new URL(project.route, siteOrigin).toString();
const imageUrl = new URL(project.img, siteOrigin).toString();

const relatedProjects = projects.filter((p) => p.id !== project.id).slice(0, 2);

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: project.name,
    description: project.description,
    applicationCategory: "DeveloperApplication",
    operatingSystem: "Any",
    author: {
      "@type": "Person",
      name: SITE.author,
      url: siteOrigin,
    },
    url: projectUrl,
    image: imageUrl,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: siteOrigin },
      { "@type": "ListItem", position: 2, name: "Projects" },
      {
        "@type": "ListItem",
        position: 3,
        name: project.name,
        item: projectUrl,
      },
    ],
  },
];
---

<BaseLayout
  title={`${project.name} Case Study | ${SITE.author}`}
  description={project.description}
  image={project.img}
  imageAlt={`Screenshot of ${project.name}`}
  keywords={[
    project.name,
    "software case study",
    "portfolio project",
    ...project.technologies,
  ]}
  schemaType="WebPage"
  structuredData={structuredData}
>
  <div class="pp">
    <main class="pp-main" id="main-content">
      <header class="pp-page-hero" data-nav-contrast="dark">
        <div class="pp-page-hero__bg" aria-hidden="true">
          <LightRays
            client:idle
            raysOrigin="top-center"
            raysColor="#f8f5ef"
            raysSpeed={0.55}
            lightSpread={0.42}
            rayLength={1.9}
            followMouse={true}
            mouseInfluence={0.035}
            noiseAmount={0}
            distortion={0.05}
            className="pp-page-hero__rays"
            pulsating={false}
            fadeDistance={0.9}
            saturation={0.7}
          />
        </div>

        <div class="pp-page-hero__inner">
          <nav class="pp-breadcrumb" aria-label="Breadcrumb">
            <a href="/" class="pp-back">
              <span class="pp-back__icon" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path
                    d="M10 3L5 8L10 13"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </span>
              <span>Work</span>
            </a>
            <span class="pp-breadcrumb__sep" aria-hidden="true">/</span>
            <span class="pp-breadcrumb__current">{project.name}</span>
          </nav>

          <div class="pp-page-hero__meta">
            <span class="pp-page-hero__eyebrow">Case Study</span>
            <span
              class="pp-hero__status pp-hero__status--hero"
              data-status={project.status.toLowerCase()}
            >
              <span class="pp-hero__status-dot" aria-hidden="true"></span>
              {project.status}
            </span>
            <span class="pp-page-hero__timeline">{project.timeline}</span>
          </div>

          <h1 class="pp-page-hero__title">{project.name}</h1>
          <p class="pp-page-hero__dek">{project.fullDescription}</p>

          <div class="pp-page-hero__footer">
            <div class="pp-page-hero__role">
              <span class="pp-page-hero__role-label">Role</span>
              <span class="pp-page-hero__role-value">{project.role}</span>
            </div>

            <div class="pp-hero__actions pp-hero__actions--hero">
              {
                project.links.demo && (
                  <a
                    href={project.links.demo}
                    class="pp-btn pp-btn--primary"
                    target="_blank"
                    rel="noopener"
                  >
                    <span>View Live</span>
                    <svg
                      width="12"
                      height="12"
                      viewBox="0 0 12 12"
                      fill="none"
                      aria-hidden="true"
                    >
                      <path
                        d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </a>
                )
              }
              {
                project.links.github && (
                  <a
                    href={project.links.github}
                    class="pp-btn pp-btn--ghost"
                    target="_blank"
                    rel="noopener"
                  >
                    <span>GitHub</span>
                    <svg
                      width="12"
                      height="12"
                      viewBox="0 0 12 12"
                      fill="none"
                      aria-hidden="true"
                    >
                      <path
                        d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </a>
                )
              }
              {
                project.links.website && !project.links.demo && (
                  <a
                    href={project.links.website}
                    class="pp-btn pp-btn--primary"
                    target="_blank"
                    rel="noopener"
                  >
                    <span>Visit Website</span>
                    <svg
                      width="12"
                      height="12"
                      viewBox="0 0 12 12"
                      fill="none"
                      aria-hidden="true"
                    >
                      <path
                        d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </a>
                )
              }
            </div>
          </div>
        </div>
      </header>

      <div class="pp-shell">
        <article class="pp-article">
          <div class="pp-tech-wrap">
            <ProjectTech
              technologies={project.technologies}
              techImages={project.techImages}
            />
          </div>

          <section class="pp-proof-strip" aria-label="Project proof points">
            {
              caseStudy.proofPoints.map((point) => (
                <div class="pp-proof-card">
                  <span class="pp-proof-card__label">{point.label}</span>
                  <span class="pp-proof-card__value">{point.value}</span>
                </div>
              ))
            }
          </section>

          <div class="pp-body">
            <section class="pp-section pp-section--problem">
              <div class="pp-section__head">
                <span class="pp-section__index" aria-hidden="true">01</span>
                <h2 class="pp-section__title">Problem</h2>
              </div>
              <p class="pp-section__copy">{caseStudy.problem}</p>
            </section>

            <section class="pp-section pp-section--constraints">
              <div class="pp-section__head">
                <span class="pp-section__index" aria-hidden="true">02</span>
                <h2 class="pp-section__title">Constraints</h2>
              </div>
              <ul class="pp-feature-list">
                {
                  caseStudy.constraints.map((constraint, i) => (
                    <li class="pp-feature">
                      <span class="pp-feature__num" aria-hidden="true">
                        {String(i + 1).padStart(2, "0")}
                      </span>
                      <span class="pp-feature__text">{constraint}</span>
                      <span class="pp-feature__arrow" aria-hidden="true">
                        ↗
                      </span>
                    </li>
                  ))
                }
              </ul>
            </section>

            <section class="pp-section pp-section--features">
              <div class="pp-section__head">
                <span class="pp-section__index" aria-hidden="true">03</span>
                <h2 class="pp-section__title">Key Features</h2>
              </div>
              <ul class="pp-feature-list">
                {
                  project.features.map((feature, i) => (
                    <li class="pp-feature">
                      <span class="pp-feature__num" aria-hidden="true">
                        {String(i + 1).padStart(2, "0")}
                      </span>
                      <span class="pp-feature__text">{feature}</span>
                      <span class="pp-feature__arrow" aria-hidden="true">
                        ↗
                      </span>
                    </li>
                  ))
                }
              </ul>
            </section>

            <section class="pp-section pp-section--highlights">
              <div class="pp-section__head">
                <span class="pp-section__index" aria-hidden="true">04</span>
                <h2 class="pp-section__title">Highlights</h2>
              </div>
              <ul class="pp-highlight-list">
                {
                  project.highlights.map((highlight, i) => (
                    <li class="pp-highlight">
                      <div class="pp-highlight__header">
                        <span class="pp-highlight__number" aria-hidden="true">
                          {String(i + 1).padStart(2, "0")}
                        </span>
                        <div class="pp-highlight__bar" aria-hidden="true" />
                      </div>
                      <p class="pp-highlight__text">{highlight}</p>
                    </li>
                  ))
                }
              </ul>
            </section>

            <section class="pp-section pp-section--deep-dive">
              <div class="pp-section__head">
                <span class="pp-section__index" aria-hidden="true">05</span>
                <h2 class="pp-section__title">Approach & Decisions</h2>
              </div>
              <div class="pp-deep-dive-grid">
                <div class="pp-deep-dive-card">
                  <span>Approach</span>
                  <ul>
                    {
                      caseStudy.approach.map((item) => (
                        <li>{item}</li>
                      ))
                    }
                  </ul>
                </div>
                <div class="pp-deep-dive-card">
                  <span>Decisions</span>
                  <ul>
                    {
                      caseStudy.decisions.map((item) => (
                        <li>{item}</li>
                      ))
                    }
                  </ul>
                </div>
              </div>
            </section>
          </div>
        </article>

        {
          relatedProjects.length > 0 && (
            <section class="pp-related" aria-labelledby="pp-related-title">
              <div class="pp-related__header">
                <div class="pp-related__eyebrow">
                  <div class="pp-related__eyebrow-line" aria-hidden="true" />
                  <span>More work</span>
                </div>
                <h2 class="pp-related__title" id="pp-related-title">
                  Other <em>Projects</em>
                </h2>
              </div>

              <div class="pp-related__grid">
                {relatedProjects.map((relProject, i) => (
                  <article class="pp-related-card" style={`--ri: ${i}`}>
                    <a href={relProject.route} class="pp-related-card__link">
                      <div class="pp-related-card__image">
                        <img
                          src={relProject.img}
                          alt={relProject.name}
                          loading="lazy"
                          decoding="async"
                        />
                        <div
                          class="pp-related-card__image-scrim"
                          aria-hidden="true"
                        />
                      </div>
                      <div class="pp-related-card__content">
                        <h3 class="pp-related-card__title">
                          {relProject.name}
                        </h3>
                        <p class="pp-related-card__desc">
                          {relProject.description}
                        </p>
                        <div class="pp-related-card__footer">
                          <span class="pp-related-card__cta">View Project</span>
                          <span
                            class="pp-related-card__arrow"
                            aria-hidden="true"
                          >
                            ↗
                          </span>
                        </div>
                      </div>
                    </a>
                  </article>
                ))}
              </div>
            </section>
          )
        }
      </div>
    </main>

    <footer class="bi-footer">
      <span class="bi-footer__copy">{SITE.name}</span>
      <div class="bi-footer__socials">
        <a href="https://x.com/silknye" target="_blank" rel="noreferrer"
          >Twitter</a
        >
        <a href="https://instagram.com/silknye" target="_blank" rel="noreferrer"
          >Instagram</a
        >
        <a
          href="https://github.com/dilukshann7"
          target="_blank"
          rel="noreferrer">GitHub</a
        >
        <a
          href="https://linkedin.com/in/dilukshann7"
          target="_blank"
          rel="noreferrer">LinkedIn</a
        >
      </div>
    </footer>
  </div>
</BaseLayout>

<script>
  import { getMotionSystem } from "../lib/client/motion";
  import { initTextReveal } from "../lib/client/textReveal";

  const bootProjectPage = async () => {
    const { gsap, ScrollTrigger } = await getMotionSystem();

    gsap.registerPlugin(ScrollTrigger);
    await import("../lib/client/textReveal");

    const container = document.querySelector(".pp");
    if (!container) return;

    const TRANSITION_OFFSET = 0.8;

    await initTextReveal(container, [
      {
        selector: ".pp-page-hero__title",
        mode: "lines",
        scroll: true,
        delay: TRANSITION_OFFSET,
      },
      {
        selector: ".pp-page-hero__dek",
        mode: "lines",
        scroll: true,
        delay: TRANSITION_OFFSET,
      },
      {
        selector:
          ".pp-page-hero__eyebrow, .pp-hero__status--hero, .pp-page-hero__timeline, .pp-page-hero__role-value",
        mode: "lines",
        scroll: true,
        delay: TRANSITION_OFFSET,
      },
      { selector: ".pp-section__title", mode: "lines", scroll: true },
      { selector: ".pp-section__copy", mode: "lines", scroll: true },
      { selector: ".pp-feature__text", mode: "lines", scroll: true },
      { selector: ".pp-highlight__text", mode: "lines", scroll: true },
      { selector: ".pp-deep-dive-card li", mode: "lines", scroll: true },
      { selector: ".pp-related__eyebrow span", mode: "lines", scroll: true },
      { selector: ".pp-related__title", mode: "lines", scroll: true },
      {
        selector: ".pp-related-card__title, .pp-related-card__desc",
        mode: "lines",
        scroll: true,
      },
    ]);
  };

  document.addEventListener("astro:page-load", bootProjectPage);
</script>

<style>
  .pp {
    --white: #ffffff;
    --off: #f8f7f4;
    --ink: #0a0a09;
    --ink-80: rgba(10, 10, 9, 0.8);
    --ink-55: rgba(10, 10, 9, 0.55);
    --ink-35: rgba(10, 10, 9, 0.35);
    --ink-15: rgba(10, 10, 9, 0.15);
    --ink-07: rgba(10, 10, 9, 0.07);
    --warm: #c2855a;
    --teal: #0b6a8e;
    --rule: rgba(10, 10, 9, 0.1);
    --rule-md: rgba(10, 10, 9, 0.18);

    --f-display: "Cormorant Garamond", Georgia, serif;
    --f-ui: "Syne", sans-serif;
    --f-body: "DM Sans", sans-serif;

    --radius-sm: 3px;
    --radius: 6px;

    --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);

    background: var(--white);
    color: var(--ink);
    font-family: var(--f-body);
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
  }

  .pp-shell {
    padding-top: clamp(1rem, 2.5vw, 2rem);
    padding-bottom: clamp(3rem, 5vw, 5.5rem);
    padding-left: clamp(1.5rem, 4vw, 3.5rem);
    padding-right: clamp(1.5rem, 4vw, 3.5rem);
    width: min(1500px, 92%);
    margin: 0 auto;
  }

  .pp-page-hero {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    background: linear-gradient(180deg, #020202 0%, #050505 52%, #090909 100%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .pp-page-hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    opacity: 0.78;
    z-index: 0;
  }

  .pp-page-hero__bg::before {
    content: "";
    position: absolute;
    inset: -24% -6% 28%;
    background: radial-gradient(
      circle at 50% 0%,
      rgba(184, 147, 106, 0.26),
      rgba(184, 147, 106, 0.08) 38%,
      transparent 70%
    );
    mix-blend-mode: screen;
    z-index: 1;
  }

  .pp-page-hero__bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.08) 0%,
      rgba(0, 0, 0, 0.36) 54%,
      rgba(0, 0, 0, 0.72) 100%
    );
    z-index: 1;
  }

  .pp-page-hero__bg :global(.pp-page-hero__rays) {
    width: 100%;
    height: 100%;
    opacity: 0.92;
  }

  .pp-page-hero__inner {
    position: relative;
    z-index: 1;
    width: 100%;
    margin: 0 auto;
    padding-top: calc(64px + clamp(1.25rem, 3vw, 2.25rem));
    padding-bottom: clamp(2rem, 3.5vw, 3.5rem);
    padding-left: clamp(1.5rem, 4vw, 3.5rem);
    padding-right: clamp(1.5rem, 4vw, 3.5rem);
  }

  .pp-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: clamp(1rem, 2vw, 1.6rem);
  }

  .pp-back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--f-ui);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.72);
    transition:
      color 200ms,
      gap 200ms;
  }

  .pp-back:hover {
    color: rgba(255, 255, 255, 0.98);
    gap: 0.75rem;
  }

  .pp-back__icon {
    display: flex;
    align-items: center;
    transition:
      transform 200ms var(--ease-out-expo),
      opacity 200ms;
  }

  .pp-back:hover .pp-back__icon {
    transform: translateX(-3px);
    opacity: 1;
  }

  .pp-breadcrumb__sep {
    font-family: var(--f-display);
    font-style: italic;
    color: rgba(255, 255, 255, 0.32);
    font-size: 0.9rem;
    line-height: 1;
  }

  .pp-breadcrumb__current {
    font-family: var(--f-ui);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--warm);
  }

  .pp-page-hero__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem 1rem;
    margin-bottom: 1.25rem;
  }

  .pp-page-hero__eyebrow {
    font-family: var(--f-ui);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #d8b38c;
  }

  .pp-article {
    border: 1px solid var(--rule-md);
    background: var(--white);
    overflow: hidden;
  }

  .pp-hero__status {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.3rem 0.7rem;
    border: 1px solid currentColor;
    font-family: var(--f-ui);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    border-radius: 999px;
  }

  .pp-hero__status-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: currentColor;
    flex-shrink: 0;
  }

  .pp-hero__status[data-status="live"] {
    color: #1a8c40;
  }
  .pp-hero__status[data-status="completed"] {
    color: var(--ink-55);
  }
  .pp-hero__status[data-status="in progress"] {
    color: var(--teal);
  }

  .pp-hero__status[data-status="live"] .pp-hero__status-dot {
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.4;
      transform: scale(0.7);
    }
  }

  .pp-hero__status--hero {
    border-color: rgba(255, 255, 255, 0.16);
    color: rgba(255, 255, 255, 0.78);
  }

  .pp-hero__status--hero[data-status="live"] {
    color: #8cdaaa;
    border-color: rgba(140, 218, 170, 0.26);
  }

  .pp-hero__status--hero[data-status="completed"] {
    color: rgba(255, 255, 255, 0.62);
    border-color: rgba(255, 255, 255, 0.14);
  }

  .pp-hero__status--hero[data-status="in progress"] {
    color: #8cc6da;
    border-color: rgba(140, 198, 218, 0.24);
  }

  .pp-page-hero__timeline {
    font-family: var(--f-ui);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
  }

  .pp-page-hero__title {
    font-family: var(--f-display);
    font-size: clamp(2.8rem, 5.5vw, 5.5rem);
    font-weight: 300;
    line-height: 0.92;
    letter-spacing: -0.02em;
    color: rgba(255, 255, 255, 0.96);
    margin: 0;
    text-wrap: balance;
  }

  .pp-page-hero__dek {
    font-size: clamp(1rem, 1.2vw, 1.1rem);
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.72);
    margin: 0.75rem 0 0;
  }

  .pp-page-hero__footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.25rem;
    margin-top: 1.35rem;
  }

  .pp-page-hero__role {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .pp-page-hero__role-label {
    font-family: var(--f-ui);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.42);
  }

  .pp-page-hero__role-value {
    font-family: var(--f-body);
    font-size: 1rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.88);
  }

  .pp-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
  }

  .pp-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.9rem 1.6rem;
    font-family: var(--f-ui);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1.5px solid transparent;
    cursor: pointer;
    transition:
      background 220ms,
      color 220ms,
      border-color 220ms,
      gap 220ms;
    white-space: nowrap;
  }

  .pp-btn svg {
    transition: transform 220ms var(--ease-out-expo);
    flex-shrink: 0;
  }

  .pp-btn:hover svg {
    transform: translate(2px, -2px);
  }

  .pp-btn--primary {
    background: var(--ink);
    color: var(--white);
    border-color: var(--ink);
  }
