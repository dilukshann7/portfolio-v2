---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import { projects, type Project } from "../data/projects";
import { SITE } from "../lib/site";
import ProjectTech from "@/components/ProjectTech.astro";

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
const siteOrigin = Astro.site?.origin ?? Astro.url.origin;
const projectUrl = new URL(project.route, siteOrigin).toString();
const imageUrl = new URL(project.img, siteOrigin).toString();

const relatedProjects = projects.filter((p) => p.id !== project.id).slice(0, 2);

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: project.name,
    description: project.description,
    applicationCategory: "DeveloperApplication",
    operatingSystem: "Any",
    author: {
      "@type": "Person",
      name: SITE.author,
      url: siteOrigin,
    },
    url: projectUrl,
    image: imageUrl,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: siteOrigin },
      { "@type": "ListItem", position: 2, name: "Projects" },
      {
        "@type": "ListItem",
        position: 3,
        name: project.name,
        item: projectUrl,
      },
    ],
  },
];
---

<BaseLayout
  title={`${project.name} Case Study | ${SITE.author}`}
  description={project.description}
  image={project.img}
  imageAlt={`Screenshot of ${project.name}`}
  keywords={[
    project.name,
    "software case study",
    "portfolio project",
    ...project.technologies,
  ]}
  schemaType="WebPage"
  structuredData={structuredData}
>
  <div class="pp">
    <main class="pp-main">
      <div class="pp-shell">
        <nav class="pp-breadcrumb" aria-label="Breadcrumb">
          <a href="/" class="pp-back">
            <span class="pp-back__icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path
                  d="M10 3L5 8L10 13"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </span>
            <span>Work</span>
          </a>
          <span class="pp-breadcrumb__sep" aria-hidden="true">/</span>
          <span class="pp-breadcrumb__current">{project.name}</span>
        </nav>

        <article class="pp-article">
          <header class="pp-hero">
            <div class="pp-hero__top">
              <div class="pp-hero__meta">
                <span
                  class="pp-hero__status"
                  data-status={project.status.toLowerCase()}
                >
                  <span class="pp-hero__status-dot" aria-hidden="true"></span>
                  {project.status}
                </span>
                <span class="pp-hero__timeline">{project.timeline}</span>
              </div>
              <div class="pp-hero__index" aria-hidden="true">001</div>
            </div>

            <div class="pp-hero__body">
              <div class="pp-hero__left">
                <h1 class="pp-hero__title">{project.name}</h1>

                <div class="pp-hero__image-wrap">
                  <img
                    class="pp-hero__image"
                    src={project.img}
                    alt={`Screenshot of ${project.name}`}
                    loading="eager"
                    decoding="async"
                  />
                  <div class="pp-hero__image-overlay" aria-hidden="true"></div>
                </div>
              </div>

              <div class="pp-hero__right">
                <p class="pp-hero__dek">{project.fullDescription}</p>

                <div class="pp-hero__role">
                  <span class="pp-hero__role-label">Role</span>
                  <span class="pp-hero__role-value">{project.role}</span>
                </div>

                <div class="pp-hero__actions">
                  {
                    project.links.demo && (
                      <a
                        href={project.links.demo}
                        class="pp-btn pp-btn--primary"
                        target="_blank"
                        rel="noopener"
                      >
                        <span>View Live</span>
                        <svg
                          width="12"
                          height="12"
                          viewBox="0 0 12 12"
                          fill="none"
                          aria-hidden="true"
                        >
                          <path
                            d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8"
                            stroke="currentColor"
                            stroke-width="1.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          />
                        </svg>
                      </a>
                    )
                  }
                  {
                    project.links.github && (
                      <a
                        href={project.links.github}
                        class="pp-btn pp-btn--ghost"
                        target="_blank"
                        rel="noopener"
                      >
                        <span>GitHub</span>
                        <svg
                          width="12"
                          height="12"
                          viewBox="0 0 12 12"
                          fill="none"
                          aria-hidden="true"
                        >
                          <path
                            d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8"
                            stroke="currentColor"
                            stroke-width="1.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          />
                        </svg>
                      </a>
                    )
                  }
                  {
                    project.links.website && !project.links.demo && (
                      <a
                        href={project.links.website}
                        class="pp-btn pp-btn--primary"
                        target="_blank"
                        rel="noopener"
                      >
                        <span>Visit Website</span>
                        <svg
                          width="12"
                          height="12"
                          viewBox="0 0 12 12"
                          fill="none"
                          aria-hidden="true"
                        >
                          <path
                            d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8"
                            stroke="currentColor"
                            stroke-width="1.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          />
                        </svg>
                      </a>
                    )
                  }
                </div>
              </div>
            </div>
          </header>

          <!-- TECH STACK -->
          <div class="pp-tech-wrap">
            <ProjectTech
              technologies={project.technologies}
              techImages={project.techImages}
            />
          </div>

          <div class="pp-body">
            <section class="pp-section pp-section--features">
              <div class="pp-section__head">
                <span class="pp-section__index" aria-hidden="true">01</span>
                <h2 class="pp-section__title">Key Features</h2>
              </div>
              <ul class="pp-feature-list">
                {
                  project.features.map((feature, i) => (
                    <li class="pp-feature">
                      <span class="pp-feature__num" aria-hidden="true">
                        {String(i + 1).padStart(2, "0")}
                      </span>
                      <span class="pp-feature__text">{feature}</span>
                      <span class="pp-feature__arrow" aria-hidden="true">
                        ↗
                      </span>
                    </li>
                  ))
                }
              </ul>
            </section>

            <section class="pp-section pp-section--highlights">
              <div class="pp-section__head">
                <span class="pp-section__index" aria-hidden="true">02</span>
                <h2 class="pp-section__title">Highlights</h2>
              </div>
              <ul class="pp-highlight-list">
                {
                  project.highlights.map((highlight, i) => (
                    <li class="pp-highlight">
                      <div class="pp-highlight__header">
                        <span class="pp-highlight__number" aria-hidden="true">
                          {String(i + 1).padStart(2, "0")}
                        </span>
                        <div class="pp-highlight__bar" aria-hidden="true" />
                      </div>
                      <p class="pp-highlight__text">{highlight}</p>
                    </li>
                  ))
                }
              </ul>
            </section>
          </div>
        </article>

        {
          relatedProjects.length > 0 && (
            <section class="pp-related" aria-labelledby="pp-related-title">
              <div class="pp-related__header">
                <div class="pp-related__eyebrow">
                  <div class="pp-related__eyebrow-line" aria-hidden="true" />
                  <span>More work</span>
                </div>
                <h2 class="pp-related__title" id="pp-related-title">
                  Other <em>Projects</em>
                </h2>
              </div>

              <div class="pp-related__grid">
                {relatedProjects.map((relProject, i) => (
                  <article class="pp-related-card" style={`--ri: ${i}`}>
                    <a
                      href={relProject.route}
                      class="pp-related-card__link"
                      tabindex="-1"
                      aria-hidden="true"
                    />
                    <div class="pp-related-card__image">
                      <img
                        src={relProject.img}
                        alt={relProject.name}
                        loading="lazy"
                        decoding="async"
                      />
                      <div
                        class="pp-related-card__image-scrim"
                        aria-hidden="true"
                      />
                    </div>
                    <div class="pp-related-card__content">
                      <div class="pp-related-card__top">
                        <span class="pp-related-card__num" aria-hidden="true">
                          {String(i + 1).padStart(2, "0")}
                        </span>
                      </div>
                      <h3 class="pp-related-card__title">
                        <a href={relProject.route}>{relProject.name}</a>
                      </h3>
                      <p class="pp-related-card__desc">
                        {relProject.description}
                      </p>
                      <div class="pp-related-card__footer">
                        <span class="pp-related-card__cta">View Project</span>
                        <span class="pp-related-card__arrow" aria-hidden="true">
                          ↗
                        </span>
                      </div>
                    </div>
                  </article>
                ))}
              </div>
            </section>
          )
        }
      </div>
    </main>

    <footer class="bi-footer">
      <span class="bi-footer__copy">{SITE.name}</span>
      <div class="bi-footer__socials">
        <a href="https://x.com/silknye" target="_blank" rel="noreferrer"
          >Twitter</a
        >
        <a href="https://instagram.com/silknye" target="_blank" rel="noreferrer"
          >Instagram</a
        >
        <a
          href="https://github.com/dilukshann7"
          target="_blank"
          rel="noreferrer">GitHub</a
        >
        <a
          href="https://linkedin.com/in/dilukshann7"
          target="_blank"
          rel="noreferrer">LinkedIn</a
        >
      </div>
    </footer>
  </div>
</BaseLayout>

<script>
  import { getMotionSystem } from "../lib/client/motion";
  import { initTextReveal } from "../lib/client/textReveal";

  const bootProjectPage = async () => {
    const { gsap, ScrollTrigger } = await getMotionSystem();

    gsap.registerPlugin(ScrollTrigger);
    await import("../lib/client/textReveal");

    const container = document.querySelector(".pp");
    if (!container) return;

    const TRANSITION_OFFSET = 0.8;

    await initTextReveal(container, [
      {
        selector: ".pp-hero__title",
        mode: "lines",
        scroll: true,
        delay: TRANSITION_OFFSET,
      },
      {
        selector: ".pp-hero__dek",
        mode: "lines",
        scroll: true,
        delay: TRANSITION_OFFSET,
      },
      {
        selector: ".pp-hero__status, .pp-hero__timeline, .pp-hero__role",
        mode: "lines",
        scroll: true,
        delay: TRANSITION_OFFSET,
      },
      { selector: ".pp-section__title", mode: "lines", scroll: true },
      { selector: ".pp-feature__text", mode: "lines", scroll: true },
      { selector: ".pp-highlight__text", mode: "lines", scroll: true },
      { selector: ".pp-related__eyebrow span", mode: "lines", scroll: true },
      { selector: ".pp-related__title", mode: "lines", scroll: true },
      {
        selector: ".pp-related-card__title, .pp-related-card__desc",
        mode: "lines",
        scroll: true,
      },
    ]);
  };

  document.addEventListener("astro:page-load", bootProjectPage);
</script>

<style>
  .pp {
    --white: #ffffff;
    --off: #f8f7f4;
    --ink: #0a0a09;
    --ink-80: rgba(10, 10, 9, 0.8);
    --ink-55: rgba(10, 10, 9, 0.55);
    --ink-35: rgba(10, 10, 9, 0.35);
    --ink-15: rgba(10, 10, 9, 0.15);
    --ink-07: rgba(10, 10, 9, 0.07);
    --warm: #c2855a;
    --teal: #0b6a8e;
    --rule: rgba(10, 10, 9, 0.1);
    --rule-md: rgba(10, 10, 9, 0.18);

    --f-display: "Cormorant Garamond", Georgia, serif;
    --f-ui: "Syne", sans-serif;
    --f-body: "DM Sans", sans-serif;

    --radius-sm: 3px;
    --radius: 6px;

    --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);

    background: var(--white);
    color: var(--ink);
    font-family: var(--f-body);
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
  }

  .pp-shell {
    padding-top: clamp(2rem, 4vw, 3.5rem);
    padding-bottom: clamp(5rem, 8vw, 9rem);
    padding-left: clamp(1rem, 2vw, 1rem);
    padding-right: clamp(1rem, 2vw, 1rem);
    width: min(1280px, 100%);
    margin: 0 auto;
  }

  .pp-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
  }

  .pp-back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--f-ui);
    font-size: 0.67rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--ink-55);
    transition: color 200ms;
  }

  .pp-back:hover {
    color: var(--ink);
  }

  .pp-back__icon {
    display: flex;
    align-items: center;
    opacity: 0.6;
    transition:
      transform 200ms var(--ease-out-expo),
      opacity 200ms;
  }
  .pp-back:hover .pp-back__icon {
    transform: translateX(-3px);
    opacity: 1;
  }

  .pp-breadcrumb__sep {
    font-family: var(--f-display);
    font-style: italic;
    color: var(--ink-35);
    font-size: 0.85rem;
    line-height: 1;
  }

  .pp-breadcrumb__current {
    font-family: var(--f-ui);
    font-size: 0.67rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--warm);
  }

  .pp-article {
    border: 1px solid var(--rule-md);
    background: var(--white);
    overflow: hidden;
  }

  .pp-hero {
    border-bottom: 1px solid var(--rule-md);
  }

  .pp-hero__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.1rem clamp(1.5rem, 3vw, 2.75rem);
    border-bottom: 1px solid var(--rule);
  }

  .pp-hero__meta {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .pp-hero__status {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.3rem 0.7rem;
    border: 1px solid currentColor;
    font-family: var(--f-ui);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    border-radius: 999px;
  }

  .pp-hero__status-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: currentColor;
    flex-shrink: 0;
  }

  .pp-hero__status[data-status="live"] {
    color: #1a8c40;
  }
  .pp-hero__status[data-status="completed"] {
    color: var(--ink-55);
  }
  .pp-hero__status[data-status="in progress"] {
    color: var(--teal);
  }

  .pp-hero__status[data-status="live"] .pp-hero__status-dot {
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.4;
      transform: scale(0.7);
    }
  }

  .pp-hero__timeline {
    font-family: var(--f-ui);
    font-size: 0.67rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--ink-35);
  }

  .pp-hero__index {
    font-family: var(--f-display);
    font-size: 0.8rem;
    font-style: italic;
    color: var(--ink-15);
    letter-spacing: 0.1em;
    user-select: none;
  }

  /* Hero body — two-column */
  .pp-hero__body {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .pp-hero__left {
    border-right: 1px solid var(--rule-md);
    display: flex;
    flex-direction: column;
  }

  .pp-hero__title {
    font-family: var(--f-display);
    font-size: clamp(3.2rem, 6.5vw, 7rem);
    font-weight: 300;
    line-height: 0.92;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin: 0;
    padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1.5rem, 3vw, 2.75rem);
    border-bottom: 1px solid var(--rule);
  }

  .pp-hero__image-wrap {
    position: relative;
    overflow: hidden;
    flex: 1;
    min-height: 360px;
    background: var(--off);
  }

  .pp-hero__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 700ms var(--ease-out-expo);
  }

  .pp-hero__image-wrap:hover .pp-hero__image {
    transform: scale(1.04);
  }

  .pp-hero__image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(10, 10, 9, 0.08) 0%,
      transparent 50%
    );
    pointer-events: none;
  }

  /* Right side */
  .pp-hero__right {
    display: flex;
    flex-direction: column;
    padding: clamp(2rem, 3vw, 3rem) clamp(1.5rem, 3vw, 2.75rem);
    gap: 2.25rem;
    justify-content: space-between;
  }

  .pp-hero__dek {
    font-size: clamp(1rem, 1.3vw, 1.2rem);
    line-height: 1.75;
    color: var(--ink-55);
    margin: 0;
    max-width: 42ch;
  }

  .pp-hero__role {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .pp-hero__role-label {
    font-family: var(--f-ui);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-35);
  }

  .pp-hero__role-value {
    font-family: var(--f-body);
    font-size: 1rem;
    font-weight: 500;
    color: var(--ink-80);
  }

  .pp-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
  }

  .pp-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.9rem 1.6rem;
    font-family: var(--f-ui);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1.5px solid transparent;
    cursor: pointer;
    transition:
      background 220ms,
      color 220ms,
      border-color 220ms,
      gap 220ms;
    white-space: nowrap;
  }

  .pp-btn svg {
    transition: transform 220ms var(--ease-out-expo);
    flex-shrink: 0;
  }

  .pp-btn:hover svg {
    transform: translate(2px, -2px);
  }

  .pp-btn--primary {
    background: var(--ink);
    color: var(--white);
    border-color: var(--ink);
  }
  .pp-btn--primary:hover {
    background: transparent;
    color: var(--ink);
  }

  .pp-btn--ghost {
    background: transparent;
    color: var(--ink);
    border-color: var(--rule-md);
  }
  .pp-btn--ghost:hover {
    background: var(--ink);
    color: var(--white);
    border-color: var(--ink);
  }

  .pp-tech-wrap {
    border-bottom: 1px solid var(--rule-md);
  }

  .pp-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .pp-section {
    padding: clamp(2.5rem, 4vw, 4rem) clamp(1.5rem, 3vw, 2.75rem);
  }

  .pp-section--features {
    border-right: 1px solid var(--rule-md);
  }

  .pp-section__head {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 2.25rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--rule);
  }

  .pp-section__index {
    font-family: var(--f-display);
    font-size: 0.8rem;
    font-style: italic;
    color: var(--warm);
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  .pp-section__title {
    font-family: var(--f-display);
    font-size: clamp(1.7rem, 2.5vw, 2.4rem);
    font-weight: 300;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0;
  }

  .pp-feature-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .pp-feature {
    display: grid;
    grid-template-columns: 2.5rem 1fr auto;
    align-items: start;
    gap: 0.75rem;
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--rule);
    cursor: default;
    transition: background 200ms;
    padding-left: 0.5rem;
    padding-right: 0.5rem;
    margin-left: -0.5rem;
    margin-right: -0.5rem;
  }

  .pp-feature:last-child {
    border-bottom: none;
  }

  .pp-feature:hover {
    background: var(--off);
  }

  .pp-feature__num {
    font-family: var(--f-display);
    font-size: 0.75rem;
    font-style: italic;
    color: var(--ink-35);
    line-height: 1.6;
    flex-shrink: 0;
    user-select: none;
  }

  .pp-feature__text {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--ink-80);
  }

  .pp-feature__arrow {
    font-size: 0.75rem;
    color: var(--ink-15);
    transition:
      color 200ms,
      transform 200ms;
    line-height: 1.6;
    flex-shrink: 0;
  }

  .pp-feature:hover .pp-feature__arrow {
    color: var(--warm);
    transform: translate(1px, -1px);
  }

  .pp-highlight-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .pp-highlight {
    padding: 1.75rem;
    border: 1px solid var(--rule);
    background: var(--white);
    transition:
      border-color 220ms,
      background 220ms,
      transform 220ms var(--ease-out-expo),
