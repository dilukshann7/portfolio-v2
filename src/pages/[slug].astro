---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import { projects, type Project } from "../data/projects";
import { SITE } from "../lib/site";
import ProjectTech from "@/components/ProjectTech.astro";

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
const { caseStudy } = project;
const siteOrigin = Astro.site?.origin ?? Astro.url.origin;
const projectUrl = new URL(project.route, siteOrigin).toString();
const imageUrl = new URL(project.img, siteOrigin).toString();

const relatedProjects = projects.filter((p) => p.id !== project.id).slice(0, 2);

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: project.name,
    description: project.description,
    applicationCategory: "DeveloperApplication",
    operatingSystem: "Any",
    author: {
      "@type": "Person",
      name: SITE.author,
      url: siteOrigin,
    },
    url: projectUrl,
    image: imageUrl,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: siteOrigin },
      { "@type": "ListItem", position: 2, name: "Projects" },
      {
        "@type": "ListItem",
        position: 3,
        name: project.name,
        item: projectUrl,
      },
    ],
  },
];
---

<BaseLayout
  title={`${project.name} Case Study | ${SITE.author}`}
  description={project.description}
  image={project.img}
  imageAlt={`Screenshot of ${project.name}`}
  keywords={[
    project.name,
    "software case study",
    "portfolio project",
    ...project.technologies,
  ]}
  schemaType="WebPage"
  structuredData={structuredData}
>
  <div class="pp">
    <main class="pp-main" id="main-content">
      <header class="pp-page-hero" data-nav-contrast="dark">
        <div class="pp-page-hero__inner">
          <nav class="pp-breadcrumb" aria-label="Breadcrumb">
            <a href="/" class="pp-back">
              <span class="pp-back__icon" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path
                    d="M10 3L5 8L10 13"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </span>
              <span>Work</span>
            </a>
            <span class="pp-breadcrumb__sep" aria-hidden="true">/</span>
            <span class="pp-breadcrumb__current">{project.name}</span>
          </nav>

          <div class="pp-page-hero__meta">
            <span class="pp-page-hero__eyebrow">Case Study</span>
            <span
              class="pp-hero__status pp-hero__status--hero"
              data-status={project.status.toLowerCase()}
            >
              <span class="pp-hero__status-dot" aria-hidden="true"></span>
              {project.status}
            </span>
            <span class="pp-page-hero__timeline">{project.timeline}</span>
          </div>

          <h1 class="pp-page-hero__title">{project.name}</h1>
          <p class="pp-page-hero__dek">{project.fullDescription}</p>

          <div class="pp-page-hero__footer">
            <div class="pp-page-hero__role">
              <span class="pp-page-hero__role-label">Role</span>
              <span class="pp-page-hero__role-value">{project.role}</span>
            </div>

            <div class="pp-hero__actions pp-hero__actions--hero">
              {
                project.links.demo && (
                  <a
                    href={project.links.demo}
                    class="pp-btn pp-btn--primary"
                    target="_blank"
                    rel="noopener"
                  >
                    <span>View Live</span>
                    <svg
                      width="12"
                      height="12"
                      viewBox="0 0 12 12"
                      fill="none"
                      aria-hidden="true"
                    >
                      <path
                        d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </a>
                )
              }
              {
                project.links.github && (
                  <a
                    href={project.links.github}
                    class="pp-btn pp-btn--ghost"
                    target="_blank"
                    rel="noopener"
                  >
                    <span>GitHub</span>
                    <svg
                      width="12"
                      height="12"
                      viewBox="0 0 12 12"
                      fill="none"
                      aria-hidden="true"
                    >
                      <path
                        d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </a>
                )
              }
              {
                project.links.website && !project.links.demo && (
                  <a
                    href={project.links.website}
                    class="pp-btn pp-btn--primary"
                    target="_blank"
                    rel="noopener"
                  >
                    <span>Visit Website</span>
                    <svg
                      width="12"
                      height="12"
                      viewBox="0 0 12 12"
                      fill="none"
                      aria-hidden="true"
                    >
                      <path
                        d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </a>
                )
              }
            </div>
          </div>
        </div>
      </header>

      <div class="pp-shell">
        <article class="pp-article">
          <section class="pp-proof-strip" aria-label="Project proof points">
            {
              caseStudy.proofPoints.map((point) => (
                <div class="pp-proof-card">
                  <span class="pp-proof-card__label">{point.label}</span>
                  <span class="pp-proof-card__value">{point.value}</span>
                </div>
              ))
            }
          </section>
          <div class="pp-tech-wrap">
            <ProjectTech
              technologies={project.technologies}
              techImages={project.techImages}
            />
          </div>

          <div class="pp-body">
            <section class="pp-section pp-section--problem">
              <div class="pp-section__head">
                <span class="pp-section__index" aria-hidden="true">01</span>
                <h2 class="pp-section__title">Problem</h2>
              </div>
              <p class="pp-section__copy">{caseStudy.problem}</p>
            </section>

            <section class="pp-section pp-section--constraints">
              <div class="pp-section__head">
                <span class="pp-section__index" aria-hidden="true">02</span>
                <h2 class="pp-section__title">Constraints</h2>
              </div>
              <ul class="pp-feature-list">
                {
                  caseStudy.constraints.map((constraint, i) => (
                    <li class="pp-feature">
                      <span class="pp-feature__num" aria-hidden="true">
                        {String(i + 1).padStart(2, "0")}
                      </span>
                      <span class="pp-feature__text">{constraint}</span>
                      <span class="pp-feature__arrow" aria-hidden="true">
                        ↗
                      </span>
                    </li>
                  ))
                }
              </ul>
            </section>

            <section class="pp-section pp-section--features">
              <div class="pp-section__head">
                <span class="pp-section__index" aria-hidden="true">03</span>
                <h2 class="pp-section__title">Key Features</h2>
              </div>
              <ul class="pp-feature-list">
                {
                  project.features.map((feature, i) => (
                    <li class="pp-feature">
                      <span class="pp-feature__num" aria-hidden="true">
                        {String(i + 1).padStart(2, "0")}
                      </span>
                      <span class="pp-feature__text">{feature}</span>
                      <span class="pp-feature__arrow" aria-hidden="true">
                        ↗
                      </span>
                    </li>
                  ))
                }
              </ul>
            </section>

            <section class="pp-section pp-section--highlights">
              <div class="pp-section__head">
                <span class="pp-section__index" aria-hidden="true">04</span>
                <h2 class="pp-section__title">Highlights</h2>
              </div>
              <ul class="pp-highlight-list">
                {
                  project.highlights.map((highlight, i) => (
                    <li class="pp-highlight">
                      <div class="pp-highlight__header">
                        <span class="pp-highlight__number" aria-hidden="true">
                          {String(i + 1).padStart(2, "0")}
                        </span>
                        <div class="pp-highlight__bar" aria-hidden="true" />
                      </div>
                      <p class="pp-highlight__text">{highlight}</p>
                    </li>
                  ))
                }
              </ul>
            </section>

            <section class="pp-section pp-section--deep-dive">
              <div class="pp-section__head">
                <span class="pp-section__index" aria-hidden="true">05</span>
                <h2 class="pp-section__title">Approach & Decisions</h2>
              </div>
              <div class="pp-deep-dive-grid">
                <div class="pp-deep-dive-card">
                  <span>Approach</span>
                  <ul>
                    {caseStudy.approach.map((item) => <li>{item}</li>)}
                  </ul>
                </div>
                <div class="pp-deep-dive-card">
                  <span>Decisions</span>
                  <ul>
                    {caseStudy.decisions.map((item) => <li>{item}</li>)}
                  </ul>
                </div>
              </div>
            </section>
          </div>
        </article>

        {
          relatedProjects.length > 0 && (
            <section class="pp-related" aria-labelledby="pp-related-title">
              <div class="pp-related__header">
                <div class="pp-related__eyebrow">
                  <div class="pp-related__eyebrow-line" aria-hidden="true" />
                  <span>More work</span>
                </div>
                <h2 class="pp-related__title" id="pp-related-title">
                  Other <em>Projects</em>
                </h2>
              </div>

              <div class="pp-related__grid">
                {relatedProjects.map((relProject, i) => (
                  <article class="pp-related-card" style={`--ri: ${i}`}>
                    <a href={relProject.route} class="pp-related-card__link">
                      <div class="pp-related-card__image">
                        <img
                          src={relProject.img}
                          alt={relProject.name}
                          loading="lazy"
                          decoding="async"
                        />
                        <div
                          class="pp-related-card__image-scrim"
                          aria-hidden="true"
                        />
                      </div>
                      <div class="pp-related-card__content">
                        <h3 class="pp-related-card__title">
                          {relProject.name}
                        </h3>
                        <p class="pp-related-card__desc">
                          {relProject.description}
                        </p>
                        <div class="pp-related-card__footer">
                          <span class="pp-related-card__cta">View Project</span>
                          <span
                            class="pp-related-card__arrow"
                            aria-hidden="true"
                          >
                            ↗
                          </span>
                        </div>
                      </div>
                    </a>
                  </article>
                ))}
              </div>
            </section>
          )
        }
      </div>
    </main>

    <footer class="bi-footer">
      <span class="bi-footer__copy">{SITE.name}</span>
      <div class="bi-footer__socials">
        <a href="https://x.com/silknye" target="_blank" rel="noreferrer"
          >Twitter</a
        >
        <a href="https://instagram.com/silknye" target="_blank" rel="noreferrer"
          >Instagram</a
        >
        <a
          href="https://github.com/dilukshann7"
          target="_blank"
          rel="noreferrer">GitHub</a
        >
        <a
          href="https://linkedin.com/in/dilukshann7"
          target="_blank"
          rel="noreferrer">LinkedIn</a
        >
      </div>
    </footer>
  </div>
</BaseLayout>

<script>
  import { getMotionSystem } from "../lib/client/motion";
  import { initTextReveal } from "../lib/client/textReveal";

  const bootProjectPage = async () => {
    const { gsap, ScrollTrigger } = await getMotionSystem();

    gsap.registerPlugin(ScrollTrigger);
    await import("../lib/client/textReveal");

    const container = document.querySelector(".pp");
    if (!container) return;

    const TRANSITION_OFFSET = 0.8;

    await initTextReveal(container, [
      {
        selector: ".pp-page-hero__title",
        mode: "lines",
        scroll: true,
        delay: TRANSITION_OFFSET,
      },
      {
        selector: ".pp-page-hero__dek",
        mode: "lines",
        scroll: true,
        delay: TRANSITION_OFFSET,
      },
      {
        selector:
          ".pp-page-hero__eyebrow, .pp-hero__status--hero, .pp-page-hero__timeline, .pp-page-hero__role-value",
        mode: "lines",
        scroll: true,
        delay: TRANSITION_OFFSET,
      },
      { selector: ".pp-section__title", mode: "lines", scroll: true },
      { selector: ".pp-section__copy", mode: "lines", scroll: true },
      { selector: ".pp-feature__text", mode: "lines", scroll: true },
      { selector: ".pp-highlight__text", mode: "lines", scroll: true },
      { selector: ".pp-deep-dive-card li", mode: "lines", scroll: true },
      { selector: ".pp-related__eyebrow span", mode: "lines", scroll: true },
      { selector: ".pp-related__title", mode: "lines", scroll: true },
      {
        selector: ".pp-related-card__title, .pp-related-card__desc",
        mode: "lines",
        scroll: true,
      },
    ]);
  };

  document.addEventListener("astro:page-load", bootProjectPage);
</script>

<style>
  .pp {
    --bg: #f5f5f7;
    --bg-1: #ffffff;
    --bg-2: #f0f0f2;
    --bg-hover: #f8f8fa;
    --bg-elevated: #ffffff;

    --border: rgba(0, 0, 0, 0.07);
    --border-md: rgba(0, 0, 0, 0.1);
    --border-strong: rgba(0, 0, 0, 0.16);

    --silver: #8e8e93;
    --silver-light: #aeaeb2;
    --silver-dim: rgba(142, 142, 147, 0.5);
    --silver-faint: rgba(142, 142, 147, 0.1);
    --silver-glow: rgba(142, 142, 147, 0.06);

    --glass-bg: rgba(255, 255, 255, 0.62);
    --glass-border: rgba(255, 255, 255, 0.75);
    --glass-bg-2: rgba(245, 245, 247, 0.55);

    --text-primary: #1a1a1e;
    --text-secondary: rgba(26, 26, 30, 0.52);
    --text-tertiary: rgba(26, 26, 30, 0.32);
    --text-disabled: rgba(26, 26, 30, 0.18);

    --status-live: #16a34a;
    --status-wip: #4f46e5;
    --status-done: rgba(26, 26, 30, 0.32);

    --f-display: "Inter", system-ui, sans-serif;
    --f-ui: "Inter", system-ui, sans-serif;
    --f-mono: "JetBrains Mono", "Fira Code", monospace;
    --f-body: "Inter", system-ui, sans-serif;

    --radius-xs: 4px;
    --radius-sm: 8px;
    --radius: 12px;
    --radius-lg: 16px;

    --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
    --ease-standard: cubic-bezier(0.4, 0, 0.2, 1);

    --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.06), 0 1px 2px rgba(0, 0, 0, 0.04);
    --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.07), 0 1px 4px rgba(0, 0, 0, 0.05);
    --shadow-lg: 0 12px 40px rgba(0, 0, 0, 0.09), 0 2px 8px rgba(0, 0, 0, 0.05);

    background: var(--bg);
    color: var(--text-primary);
    font-family: var(--f-body);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    min-height: 100vh;
  }

  .pp-shell {
    padding-top: clamp(1rem, 2.5vw, 2rem);
    padding-bottom: clamp(3rem, 6vw, 6rem);
    padding-left: clamp(1.5rem, 4vw, 3.5rem);
    padding-right: clamp(1.5rem, 4vw, 3.5rem);
    width: min(1320px, 92%);
    margin: 0 auto;
  }

  .pp-page-hero {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    background: linear-gradient(160deg, #f0f0f5 0%, #e8e8f0 50%, #ececf2 100%);
    border-bottom: 1px solid var(--border);
  }

  .pp-page-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
    opacity: 0.45;
  }

  .pp-page-hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .pp-page-hero__bg::before {
    content: "";
    position: absolute;
    top: -30%;
    left: 55%;
    width: 700px;
    height: 500px;
    background: radial-gradient(
      ellipse at center,
      rgba(200, 200, 220, 0.45) 0%,
      rgba(180, 180, 210, 0.15) 45%,
      transparent 70%
    );
    z-index: 1;
  }

  .pp-page-hero__bg::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 40%;
    background: linear-gradient(
      to bottom,
      transparent,
      rgba(240, 240, 245, 0.6)
    );
    z-index: 2;
  }

  .pp-page-hero__bg :global(.pp-page-hero__rays) {
    width: 100%;
    height: 100%;
    opacity: 0.08;
    filter: saturate(0) brightness(0.5);
  }

  .pp-page-hero__inner {
    position: relative;
    z-index: 1;
    width: 100%;
    margin: 0 auto;
    padding-top: calc(64px + clamp(1.25rem, 3vw, 2.5rem));
    padding-bottom: clamp(2.5rem, 4.5vw, 4.5rem);
    padding-left: clamp(1.5rem, 4vw, 3.5rem);
    padding-right: clamp(1.5rem, 4vw, 3.5rem);
  }

  .pp-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: clamp(1.5rem, 2.5vw, 2.25rem);
  }

  .pp-back {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.78rem;
    font-weight: 450;
    letter-spacing: -0.01em;
    text-decoration: none;
    color: var(--text-tertiary);
    transition:
      color 140ms var(--ease-standard),
      gap 140ms var(--ease-standard);
  }

  .pp-back:hover {
    color: var(--text-secondary);
    gap: 0.55rem;
  }

  .pp-back__icon {
    display: flex;
    align-items: center;
    transition: transform 200ms var(--ease-out-expo);
  }

  .pp-back:hover .pp-back__icon {
    transform: translateX(-2px);
  }

  .pp-breadcrumb__sep {
    color: var(--text-disabled);
    font-size: 0.7rem;
  }

  .pp-breadcrumb__current {
    font-size: 0.78rem;
    font-weight: 450;
    color: var(--text-secondary);
    letter-spacing: -0.01em;
  }

  .pp-page-hero__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem 0.65rem;
    margin-bottom: 1.5rem;
  }
  .pp-page-hero__eyebrow {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--text-secondary);
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    backdrop-filter: blur(12px) saturate(1.4);
    -webkit-backdrop-filter: blur(12px) saturate(1.4);
    padding: 0.22rem 0.6rem;
    border-radius: var(--radius-xs);
    box-shadow: var(--shadow-sm);
  }

  .pp-hero__status {
    display: inline-flex;
    align-items: center;
    gap: 0.38rem;
    padding: 0.22rem 0.6rem;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    backdrop-filter: blur(12px) saturate(1.4);
    -webkit-backdrop-filter: blur(12px) saturate(1.4);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    border-radius: var(--radius-xs);
    box-shadow: var(--shadow-sm);
  }

  .pp-hero__status-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: currentColor;
    flex-shrink: 0;
  }

  .pp-hero__status[data-status="live"] {
    color: var(--status-live);
  }
  .pp-hero__status[data-status="completed"] {
    color: var(--status-done);
  }
  .pp-hero__status[data-status="in progress"] {
    color: var(--status-wip);
  }

  .pp-hero__status[data-status="live"] .pp-hero__status-dot {
    animation: pulse-dot 2.4s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.35;
      transform: scale(0.65);
    }
  }

  .pp-hero__status--hero {
    /* inherits */
  }

  .pp-page-hero__timeline {
    font-size: 0.7rem;
    font-weight: 450;
    color: var(--text-tertiary);
    letter-spacing: -0.01em;
  }

  /* ── Title ── */
  .pp-page-hero__title {
    font-family: var(--f-display);
    font-size: clamp(2.8rem, 5.5vw, 5.75rem);
    font-weight: 700;
    line-height: 0.96;
    letter-spacing: -0.04em;
    color: var(--text-primary);
    margin: 0;
    text-wrap: balance;
  }

  .pp-page-hero__dek {
    font-size: clamp(0.9rem, 1.15vw, 1.05rem);
    line-height: 1.72;
    color: var(--text-secondary);
    margin: 1rem 0 0;
    max-width: 560px;
    font-weight: 400;
    letter-spacing: -0.01em;
  }

  .pp-page-hero__footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.25rem;
    margin-top: 2rem;
  }

  .pp-page-hero__role {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .pp-page-hero__role-label {
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .pp-page-hero__role-value {
    font-size: 0.9rem;
    font-weight: 450;
    color: var(--text-secondary);
    letter-spacing: -0.01em;
  }

  /* ── Buttons ── */
  .pp-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .pp-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.55rem 1.1rem;
    font-family: var(--f-body);
