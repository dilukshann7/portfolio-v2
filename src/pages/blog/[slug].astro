---
export const prerender = true;

import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import LightRays from "../../components/ui/LightRays";
import {
  formatBlogDate,
  getAllBlogPosts,
  getPostUrl,
  getReadingTime,
  getWordCount,
} from "../../lib/blog";
import { SITE } from "../../lib/site";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const siteOrigin = Astro.site?.origin ?? Astro.url.origin;
const postUrl = new URL(getPostUrl(post.id), siteOrigin).toString();
const imageUrl = new URL(
  post.data.heroImage ?? SITE.socialImage,
  siteOrigin,
).toString();
const readingTime = getReadingTime(post.body);
const wordCount = getWordCount(post.body);
const tableOfContents = headings.filter(
  (heading) => heading.depth >= 2 && heading.depth <= 3,
);
const relatedPosts = (await getAllBlogPosts())
  .filter((candidate) => candidate.id !== post.id)
  .sort((left, right) => {
    const leftScore = left.data.tags.filter((tag) =>
      post.data.tags.includes(tag),
    ).length;
    const rightScore = right.data.tags.filter((tag) =>
      post.data.tags.includes(tag),
    ).length;
    if (leftScore !== rightScore) return rightScore - leftScore;
    return right.data.publishDate.getTime() - left.data.publishDate.getTime();
  })
  .slice(0, 3);

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.publishDate.toISOString(),
    dateModified: (
      post.data.updatedDate ?? post.data.publishDate
    ).toISOString(),
    author: { "@type": "Person", name: SITE.author, url: siteOrigin },
    publisher: { "@type": "Person", name: SITE.author, url: siteOrigin },
    mainEntityOfPage: postUrl,
    image: [imageUrl],
    articleSection: post.data.category,
    keywords: post.data.tags.join(", "),
    wordCount,
    timeRequired: `PT${readingTime}M`,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: siteOrigin },
      {
        "@type": "ListItem",
        position: 2,
        name: "Blog",
        item: new URL("/blog/", siteOrigin).toString(),
      },
      {
        "@type": "ListItem",
        position: 3,
        name: post.data.title,
        item: postUrl,
      },
    ],
  },
];
---

<BaseLayout
  title={`${post.data.title} | ${SITE.author} Blog`}
  description={post.data.description}
  image={post.data.heroImage ?? SITE.socialImage}
  imageAlt={post.data.heroImageAlt ?? post.data.title}
  keywords={[...post.data.tags, post.data.category, "blog post"]}
  pageType="article"
  schemaType="Article"
  publishedTime={post.data.publishDate}
  modifiedTime={post.data.updatedDate ?? post.data.publishDate}
  articleSection={post.data.category}
  structuredData={structuredData}
  themeColor="#ffffff"
  colorScheme="light"
>
  <Fragment slot="head">
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE.blogTitle} RSS feed`}
      href="/rss.xml"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;1,9..40,300&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div class="bp-cursor" id="bpCursor" aria-hidden="true"></div>
  <div class="bp-scroll-line" id="bpScrollLine" aria-hidden="true"></div>

  <main class="bp" id="main-content">
    <header class="bp-page-hero" data-nav-contrast="dark">
      <div class="bp-page-hero__bg" aria-hidden="true">
        <LightRays
          client:idle
          raysOrigin="top-center"
          raysColor="#f8f5ef"
          raysSpeed={0.55}
          lightSpread={0.42}
          rayLength={1.9}
          followMouse={true}
          mouseInfluence={0.035}
          noiseAmount={0}
          distortion={0.05}
          className="bp-page-hero__rays"
          pulsating={false}
          fadeDistance={0.9}
          saturation={0.7}
        />
      </div>

      <div class="bp-page-hero__inner">
        <div class="bp-breadcrumb" aria-label="Breadcrumb">
          <a href="/blog/" class="bp-back">
            <span class="bp-back__arrow" aria-hidden="true">←</span>
            Journal
          </a>
          <span class="bp-breadcrumb__sep" aria-hidden="true">/</span>
          <span class="bp-breadcrumb__current">{post.data.category}</span>
        </div>

        <div class="bp-hero bp-hero--single">
          <div class="bp-hero__left">
            <h1 class="bp-hero__title">{post.data.title}</h1>
            <p class="bp-hero__dek">{post.data.description}</p>

            <div class="bp-hero__stats" aria-label="Post stats">
              <div class="bp-stat">
                <span class="bp-stat__value">{readingTime}</span>
                <span class="bp-stat__label">min read</span>
              </div>
              <div class="bp-stat__div" aria-hidden="true"></div>
              <div class="bp-stat">
                <span class="bp-stat__value">{wordCount}</span>
                <span class="bp-stat__label">words</span>
              </div>
              <div class="bp-stat__div" aria-hidden="true"></div>
              <div class="bp-stat">
                <span class="bp-stat__value">{post.data.tags.length}</span>
                <span class="bp-stat__label">topics</span>
              </div>
            </div>

            <div class="bp-hero__tags">
              {post.data.tags.map((tag) => <span class="bp-tag">{tag}</span>)}
            </div>
          </div>
        </div>
      </div>
    </header>

    <div class="bp-shell">
      <article class="bp-article">
        <div class="bp-body">
          {
            tableOfContents.length > 0 && (
              <aside class="bp-toc" aria-labelledby="bp-toc-title">
                <p class="bp-toc__title" id="bp-toc-title">
                  On this page
                </p>
                <nav>
                  {tableOfContents.map((heading) => (
                    <a
                      href={`#${heading.slug}`}
                      class="bp-toc__link"
                      data-depth={heading.depth}
                    >
                      {heading.text}
                    </a>
                  ))}
                </nav>
              </aside>
            )
          }

          <div class="bp-prose">
            <Content />
          </div>
        </div>

        <footer class="bp-post-footer">
          <div class="bp-post-footer__tags">
            {post.data.tags.map((tag) => <span class="bp-tag">{tag}</span>)}
          </div>
          <a href="/blog/" class="bp-post-footer__back"> ← Back to Journal </a>
        </footer>
      </article>

      {
        relatedPosts.length > 0 && (
          <section class="bp-related" aria-labelledby="bp-related-title">
            <div class="bp-related__header">
              <div class="bp-related__eyebrow">
                <div class="bp-related__eyebrow-line" aria-hidden="true" />
                <span>Keep reading</span>
              </div>
              <h2 class="bp-related__title" id="bp-related-title">
                More from the <em>Journal</em>
              </h2>
            </div>

            <div class="bp-related__grid">
              {relatedPosts.map((relatedPost, i) => (
                <article class="bp-related-card" style={`--ri: ${i}`}>
                  <div class="bp-related-card__index" aria-hidden="true">
                    {String(i + 1).padStart(2, "0")}
                  </div>
                  <span class="bp-related-card__category">
                    {relatedPost.data.category}
                  </span>
                  <h3 class="bp-related-card__title">
                    <a href={getPostUrl(relatedPost.id)}>
                      {relatedPost.data.title}
                    </a>
                  </h3>
                  <p class="bp-related-card__desc">
                    {relatedPost.data.description}
                  </p>
                  <div class="bp-related-card__footer">
                    <span class="bp-related-card__meta">
                      {formatBlogDate(relatedPost.data.publishDate)}
                      &nbsp;·&nbsp;
                      {getReadingTime(relatedPost.body)} min
                    </span>
                    <span class="bp-related-card__arrow" aria-hidden="true">
                      →
                    </span>
                  </div>
                </article>
              ))}
            </div>
          </section>
        )
      }
    </div>
    <footer class="bi-footer">
      <span class="bi-footer__copy">{SITE.name}</span>
      <div class="bi-footer__socials">
        <a href="https://x.com/silknye" target="_blank" rel="noreferrer"
          >Twitter</a
        >
        <a href="https://instagram.com/silknye" target="_blank" rel="noreferrer"
          >Instagram</a
        >
        <a
          href="https://github.com/dilukshann7"
          target="_blank"
          rel="noreferrer">GitHub</a
        >
        <a
          href="https://linkedin.com/in/dilukshann7"
          target="_blank"
          rel="noreferrer">LinkedIn</a
        >
      </div>
    </footer>
  </main>
</BaseLayout>

<style>
  .bp *,
  .bp *::before,
  .bp *::after {
    box-sizing: border-box;
  }

  .bp {
    --bg: #f5f5f7;
    --bg-1: #ffffff;
    --bg-2: #f0f0f2;
    --bg-hover: #f8f8fa;

    --border: rgba(0, 0, 0, 0.07);
    --border-md: rgba(0, 0, 0, 0.1);
    --border-strong: rgba(0, 0, 0, 0.16);

    --silver: #8e8e93;
    --silver-light: #aeaeb2;
    --silver-dim: rgba(142, 142, 147, 0.5);
    --silver-faint: rgba(142, 142, 147, 0.1);

    --glass-bg: rgba(255, 255, 255, 0.62);
    --glass-border: rgba(255, 255, 255, 0.75);

    --text-primary: #1a1a1e;
    --text-secondary: rgba(26, 26, 30, 0.52);
    --text-tertiary: rgba(26, 26, 30, 0.32);
    --text-disabled: rgba(26, 26, 30, 0.18);

    --status-live: #16a34a;
    --status-wip: #4f46e5;

    --f-display: "Inter", system-ui, sans-serif;
    --f-ui: "Inter", system-ui, sans-serif;
    --f-mono: "JetBrains Mono", "Fira Code", monospace;
    --f-body: "Inter", system-ui, sans-serif;

    --radius-xs: 4px;
    --radius-sm: 8px;
    --radius: 12px;
    --radius-lg: 16px;

    --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
    --ease-standard: cubic-bezier(0.4, 0, 0.2, 1);

    --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.06), 0 1px 2px rgba(0, 0, 0, 0.04);
    --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.07), 0 1px 4px rgba(0, 0, 0, 0.05);
    --shadow-lg: 0 12px 40px rgba(0, 0, 0, 0.09), 0 2px 8px rgba(0, 0, 0, 0.05);

    background: var(--bg);
    color: var(--text-primary);
    font-family: var(--f-body);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
    min-height: 100vh;
  }

  /* ── Cursor + scroll line ── */
  .bp-cursor {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--text-primary);
    position: fixed;
    pointer-events: none;
    z-index: 9999;
    mix-blend-mode: multiply;
    transform: translate(-50%, -50%);
    transition:
      transform 120ms ease,
      opacity 200ms;
  }

  .bp-scroll-line {
    position: fixed;
    top: 64px;
    left: 0;
    height: 1px;
    background: var(--silver);
    z-index: 9998;
    width: 0%;
    transition: width 60ms linear;
  }

  /* ── Hero — black with light rays ── */
  .bp-page-hero {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    background: #080808;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .bp-page-hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }

  .bp-page-hero__bg::before {
    content: "";
    position: absolute;
    inset: -24% -6% 28%;
    background: radial-gradient(
      circle at 50% 0%,
      rgba(200, 200, 210, 0.18),
      rgba(180, 180, 200, 0.06) 38%,
      transparent 70%
    );
    mix-blend-mode: screen;
    z-index: 1;
  }

  .bp-page-hero__bg::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 45%;
    background: linear-gradient(to bottom, transparent, #080808);
    z-index: 2;
  }

  .bp-page-hero__bg :global(.bp-page-hero__rays) {
    width: 100%;
    height: 100%;
    opacity: 0.82;
  }

  .bp-page-hero__inner {
    position: relative;
    z-index: 1;
    width: 100%;
    margin: 0 auto;
    padding-top: calc(64px + clamp(2rem, 4vw, 3rem));
    padding-bottom: clamp(3rem, 5vw, 5rem);
    padding-left: clamp(1.5rem, 4vw, 3.5rem);
    padding-right: clamp(1.5rem, 4vw, 3.5rem);
  }

  .bp-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2.25rem;
    opacity: 0;
    animation: bpUp 0.6s 0.05s forwards;
  }

  .bp-back {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.75rem;
    font-weight: 450;
    letter-spacing: -0.01em;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.38);
    transition:
      color 140ms var(--ease-standard),
      gap 140ms var(--ease-standard);
  }

  .bp-back:hover {
    color: rgba(255, 255, 255, 0.7);
    gap: 0.55rem;
  }

  .bp-back__arrow {
    transition: transform 200ms var(--ease-out-expo);
  }

  .bp-back:hover .bp-back__arrow {
    transform: translateX(-2px);
  }

  .bp-breadcrumb__sep {
    color: rgba(255, 255, 255, 0.18);
    font-size: 0.7rem;
  }

  .bp-breadcrumb__current {
    font-size: 0.75rem;
    font-weight: 450;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: -0.01em;
  }

  .bp-hero {
    display: block;
  }
  .bp-hero--single {
    display: block;
  }

  .bp-hero__left {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .bp-hero__title {
    font-family: var(--f-display);
    font-size: clamp(2.6rem, 5.5vw, 5.25rem);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: rgba(255, 255, 255, 0.96);
    max-width: none;
    text-wrap: balance;
    margin: 0;
    opacity: 0;
    animation: bpUp 0.9s 0.2s var(--ease-out-expo) forwards;
  }

  .bp-hero__dek {
    font-size: clamp(0.9rem, 1.15vw, 1.05rem);
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.52);
    max-width: 620px;
    margin: 0;
    font-weight: 400;
    letter-spacing: -0.01em;
    opacity: 0;
    animation: bpUp 0.7s 0.32s forwards;
  }

  .bp-hero__stats {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    opacity: 0;
    animation: bpUp 0.6s 0.42s forwards;
  }

  .bp-stat {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .bp-stat__value {
    font-family: var(--f-display);
    font-size: 1.5rem;
    font-weight: 660;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--silver-light);
  }

  .bp-stat__label {
    font-family: var(--f-mono);
    font-size: 0.55rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.28);
  }

  .bp-stat__div {
    width: 1px;
    height: 1.75rem;
    background: rgba(255, 255, 255, 0.1);
    flex-shrink: 0;
  }

  .bp-hero__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    opacity: 0;
    animation: bpUp 0.6s 0.5s forwards;
  }

  .bp-tag {
    padding: 0.22rem 0.6rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: var(--radius-xs);
    font-family: var(--f-mono);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    transition:
      border-color 140ms,
      color 140ms;
  }

  .bp-tag:hover {
    border-color: rgba(255, 255, 255, 0.22);
    color: rgba(255, 255, 255, 0.82);
  }

  .bp-post-footer .bp-tag {
    border-color: var(--border-md);
    background: var(--silver-faint);
    color: var(--silver);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  .bp-post-footer .bp-tag:hover {
    border-color: var(--border-strong);
    color: var(--text-primary);
  }

  .bp-shell {
    padding-top: clamp(2rem, 4vw, 3rem);
    padding-bottom: clamp(4rem, 7vw, 7rem);
    padding-left: clamp(1.5rem, 4vw, 3.5rem);
    padding-right: clamp(1.5rem, 4vw, 3.5rem);
    width: min(1400px, 90%);
    margin: 0 auto;
  }

  .bp-article {
    border: 1px solid rgba(255, 255, 255, 0.7);
    background: var(--glass-bg);
    backdrop-filter: blur(20px) saturate(1.6);
    -webkit-backdrop-filter: blur(20px) saturate(1.6);
    overflow: hidden;
    border-radius: var(--radius-lg);
    box-shadow:
      var(--shadow-lg),
      inset 0 1px 0 rgba(255, 255, 255, 0.8);
  }

  .bp-rule {
    height: 1px;
    background: var(--border);
  }

  .bp-body {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    align-items: start;
  }

  .bp-toc {
    position: sticky;
    align-self: start;
    padding: 1.75rem 1.25rem;
    border-right: 1px solid var(--border);
  }

  .bp-toc__title {
    font-family: var(--f-mono);
    font-size: 0.58rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin: 0 0 1rem;
  }

  .bp-toc nav {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .bp-toc__link {
    display: block;
    padding: 0.42rem 0;
    font-family: var(--f-body);
    font-size: 0.8rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: -0.005em;
    color: var(--text-tertiary);
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    transition:
      color 140ms,
      padding-left 140ms;
  }

  .bp-toc__link:last-child {
    border-bottom: none;
  }

  .bp-toc__link:hover {
    color: var(--text-primary);
    padding-left: 0.35rem;
  }

  .bp-toc__link[data-depth="3"] {
    padding-left: 0.85rem;
    font-size: 0.75rem;
    color: var(--text-disabled);
  }

  .bp-toc__link[data-depth="3"]:hover {
    padding-left: 1.2rem;
    color: var(--text-tertiary);
  }

  .bp-toc__link.is-active {
    color: var(--silver);
    font-weight: 500;
  }

  .bp-prose {
    padding: clamp(2rem, 3vw, 3.5rem) clamp(1.5rem, 3vw, 3rem);
    min-width: 0;
  }

  :global(.bp-prose h2),
  :global(.bp-prose h3),
  :global(.bp-prose h1) {
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 660;
    line-height: 1.1;
    letter-spacing: -0.035em;
    scroll-margin-top: calc(64px + 1.5rem);
    color: #1a1a1e;
  }

  :global(.bp-prose h2) {
    margin: 3rem 0 1rem;
    font-size: clamp(1.5rem, 2.4vw, 2.1rem);
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.07);
  }

  :global(.bp-prose h3) {
    margin: 2rem 0 0.65rem;
    font-size: clamp(1.1rem, 1.6vw, 1.5rem);
    font-weight: 600;
  }

  :global(.bp-prose p),
  :global(.bp-prose li) {
    font-family: "Inter", system-ui, sans-serif;
    font-size: clamp(0.95rem, 1.05vw, 1.02rem);
    line-height: 1.85;
    color: rgba(26, 26, 30, 0.7);
    letter-spacing: -0.005em;
  }

  :global(.bp-prose p) {
    margin: 0 0 1.2rem;
  }

  :global(.bp-prose ul),
  :global(.bp-prose ol) {
    margin: 0 0 1.2rem;
    padding-left: 1.4rem;
  }

  :global(.bp-prose li) {
    margin-bottom: 0.4rem;
  }

  :global(.bp-prose a) {
    color: var(--silver);
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
    transition: color 140ms;
  }

  :global(.bp-prose a:hover) {
    color: #1a1a1e;
  }

  :global(.bp-prose strong) {
    color: #1a1a1e;
    font-weight: 600;
  }

  :global(.bp-prose em) {
    font-style: italic;
    color: rgba(26, 26, 30, 0.8);
  }

  :global(.bp-prose blockquote) {
    margin: 2rem 0;
    padding: 1.25rem 1.5rem;
    border-left: 2px solid var(--silver-light);
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    font-size: clamp(1rem, 1.4vw, 1.15rem);
