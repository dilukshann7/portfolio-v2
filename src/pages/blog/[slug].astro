---
export const prerender = true;

import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  formatBlogDate,
  getAllBlogPosts,
  getPostUrl,
  getReadingTime,
  getWordCount,
} from "../../lib/blog";
import { SITE } from "../../lib/site";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const siteOrigin = Astro.site?.origin ?? Astro.url.origin;
const postUrl = new URL(getPostUrl(post.id), siteOrigin).toString();
const imageUrl = new URL(
  post.data.heroImage ?? SITE.socialImage,
  siteOrigin,
).toString();
const readingTime = getReadingTime(post.body);
const wordCount = getWordCount(post.body);
const tableOfContents = headings.filter(
  (heading) => heading.depth >= 2 && heading.depth <= 3,
);
const relatedPosts = (await getAllBlogPosts())
  .filter((candidate) => candidate.id !== post.id)
  .sort((left, right) => {
    const leftScore = left.data.tags.filter((tag) =>
      post.data.tags.includes(tag),
    ).length;
    const rightScore = right.data.tags.filter((tag) =>
      post.data.tags.includes(tag),
    ).length;
    if (leftScore !== rightScore) return rightScore - leftScore;
    return right.data.publishDate.getTime() - left.data.publishDate.getTime();
  })
  .slice(0, 3);

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.publishDate.toISOString(),
    dateModified: (
      post.data.updatedDate ?? post.data.publishDate
    ).toISOString(),
    author: { "@type": "Person", name: SITE.author, url: siteOrigin },
    publisher: { "@type": "Person", name: SITE.author, url: siteOrigin },
    mainEntityOfPage: postUrl,
    image: [imageUrl],
    articleSection: post.data.category,
    keywords: post.data.tags.join(", "),
    wordCount,
    timeRequired: `PT${readingTime}M`,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: siteOrigin },
      {
        "@type": "ListItem",
        position: 2,
        name: "Blog",
        item: new URL("/blog/", siteOrigin).toString(),
      },
      {
        "@type": "ListItem",
        position: 3,
        name: post.data.title,
        item: postUrl,
      },
    ],
  },
];
---

<BaseLayout
  title={`${post.data.title} | ${SITE.author}`}
  description={post.data.description}
  image={post.data.heroImage ?? SITE.socialImage}
  imageAlt={post.data.heroImageAlt ?? post.data.title}
  keywords={[...post.data.tags, post.data.category, "blog post"]}
  pageType="article"
  publishedTime={post.data.publishDate}
  modifiedTime={post.data.updatedDate ?? post.data.publishDate}
  structuredData={structuredData}
  themeColor="#ffffff"
  colorScheme="light"
>
  <Fragment slot="head">
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE.blogTitle} RSS feed`}
      href="/rss.xml"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;1,9..40,300&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div class="bp-cursor" id="bpCursor" aria-hidden="true"></div>
  <div class="bp-scroll-line" id="bpScrollLine" aria-hidden="true"></div>

  <main class="bp">
    <nav class="bp-nav">
      <a href="/" class="bp-nav__logo">{SITE.author}</a>
      <ul class="bp-nav__links">
        <li><a href="/">Work</a></li>
        <li><a href="/blog/">Journal</a></li>
      </ul>
      <a href="/rss.xml" class="bp-nav__pill" aria-label="Subscribe via RSS">
        <svg
          width="10"
          height="10"
          viewBox="0 0 10 10"
          fill="none"
          aria-hidden="true"
        >
          <circle cx="2" cy="8" r="1.5" fill="currentColor"></circle>
          <path
            d="M1 5a4 4 0 014 4"
            stroke="currentColor"
            stroke-width="1.2"
            stroke-linecap="round"
            fill="none"></path>
          <path
            d="M1 2a7 7 0 017 7"
            stroke="currentColor"
            stroke-width="1.2"
            stroke-linecap="round"
            fill="none"></path>
        </svg>
        RSS
      </a>
    </nav>

    <div class="bp-shell">
      <div class="bp-breadcrumb" aria-label="Breadcrumb">
        <a href="/blog/" class="bp-back">
          <span class="bp-back__arrow" aria-hidden="true">←</span>
          Journal
        </a>
        <span class="bp-breadcrumb__sep" aria-hidden="true">/</span>
        <span class="bp-breadcrumb__current">{post.data.category}</span>
      </div>

      <article class="bp-article">
        <header class="bp-hero">
          <div class="bp-hero__left">
            <div class="bp-hero__meta-row">
              <span class="bp-hero__category">{post.data.category}</span>
              <span class="bp-hero__sep" aria-hidden="true">—</span>
              <span class="bp-hero__date"
                >{formatBlogDate(post.data.publishDate)}</span
              >
            </div>

            <h1 class="bp-hero__title">{post.data.title}</h1>
            <p class="bp-hero__dek">{post.data.description}</p>

            <div class="bp-hero__stats" aria-label="Post stats">
              <div class="bp-stat">
                <span class="bp-stat__value">{readingTime}</span>
                <span class="bp-stat__label">min read</span>
              </div>
              <div class="bp-stat__div" aria-hidden="true"></div>
              <div class="bp-stat">
                <span class="bp-stat__value">{wordCount}</span>
                <span class="bp-stat__label">words</span>
              </div>
              <div class="bp-stat__div" aria-hidden="true"></div>
              <div class="bp-stat">
                <span class="bp-stat__value">{post.data.tags.length}</span>
                <span class="bp-stat__label">topics</span>
              </div>
            </div>

            <div class="bp-hero__tags">
              {post.data.tags.map((tag) => <span class="bp-tag">{tag}</span>)}
            </div>
          </div>

          {
            post.data.heroImage && (
              <div class="bp-hero__image-wrap">
                <img
                  class="bp-hero__image"
                  src={post.data.heroImage}
                  alt={post.data.heroImageAlt ?? post.data.title}
                  loading="eager"
                  decoding="async"
                />
              </div>
            )
          }
        </header>

        <div class="bp-rule" aria-hidden="true"></div>

        <div class="bp-body">
          {
            tableOfContents.length > 0 && (
              <aside class="bp-toc" aria-labelledby="bp-toc-title">
                <p class="bp-toc__title" id="bp-toc-title">
                  On this page
                </p>
                <nav>
                  {tableOfContents.map((heading) => (
                    <a
                      href={`#${heading.slug}`}
                      class="bp-toc__link"
                      data-depth={heading.depth}
                    >
                      {heading.text}
                    </a>
                  ))}
                </nav>
              </aside>
            )
          }

          <div class="bp-prose">
            <Content />
          </div>
        </div>

        <footer class="bp-post-footer">
          <div class="bp-post-footer__tags">
            {post.data.tags.map((tag) => <span class="bp-tag">{tag}</span>)}
          </div>
          <a href="/blog/" class="bp-post-footer__back"> ← Back to Journal </a>
        </footer>
      </article>

      {
        relatedPosts.length > 0 && (
          <section class="bp-related" aria-labelledby="bp-related-title">
            <div class="bp-related__header">
              <div class="bp-related__eyebrow">
                <div class="bp-related__eyebrow-line" aria-hidden="true" />
                <span>Keep reading</span>
              </div>
              <h2 class="bp-related__title" id="bp-related-title">
                More from the <em>Journal</em>
              </h2>
            </div>

            <div class="bp-related__grid">
              {relatedPosts.map((relatedPost, i) => (
                <article class="bp-related-card" style={`--ri: ${i}`}>
                  <div class="bp-related-card__index" aria-hidden="true">
                    {String(i + 1).padStart(2, "0")}
                  </div>
                  <span class="bp-related-card__category">
                    {relatedPost.data.category}
                  </span>
                  <h3 class="bp-related-card__title">
                    <a href={getPostUrl(relatedPost.id)}>
                      {relatedPost.data.title}
                    </a>
                  </h3>
                  <p class="bp-related-card__desc">
                    {relatedPost.data.description}
                  </p>
                  <div class="bp-related-card__footer">
                    <span class="bp-related-card__meta">
                      {formatBlogDate(relatedPost.data.publishDate)}
                      &nbsp;·&nbsp;
                      {getReadingTime(relatedPost.body)} min
                    </span>
                    <span class="bp-related-card__arrow" aria-hidden="true">
                      →
                    </span>
                  </div>
                </article>
              ))}
            </div>
          </section>
        )
      }
    </div>
  </main>
</BaseLayout>

<style>
  .bp *,
  .bp *::before,
  .bp *::after {
    box-sizing: border-box;
  }

  .bp {
    --white: #ffffff;
    --paper: #f4f2ee;
    --ink: #0d0d0b;
    --ink-72: rgba(13, 13, 11, 0.72);
    --ink-60: rgba(13, 13, 11, 0.6);
    --ink-30: rgba(13, 13, 11, 0.3);
    --ink-10: rgba(13, 13, 11, 0.1);
    --ink-06: rgba(13, 13, 11, 0.06);
    --warm: #b8936a;
    --teal: #0d6f92;
    --rule: rgba(13, 13, 11, 0.12);
    --f-display: "Cormorant Garamond", Georgia, serif;
    --f-ui: "Syne", sans-serif;
    --f-body: "DM Sans", sans-serif;
    --f-mono: "Geist Variable", ui-monospace, monospace;

    background: var(--white);
    color: var(--ink);
    font-family: var(--f-body);
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
    min-height: 100vh;
  }

  .bp-cursor {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--ink);
    position: fixed;
    pointer-events: none;
    z-index: 9999;
    mix-blend-mode: difference;
    transform: translate(-50%, -50%);
    transition: transform 120ms ease;
  }

  .bp-scroll-line {
    position: fixed;
    top: 64px;
    left: 0;
    height: 2px;
    background: var(--ink);
    z-index: 9998;
    width: 0%;
    transition: width 60ms linear;
  }

  .bp-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 clamp(1.5rem, 4vw, 3.5rem);
    height: 64px;
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(20px) saturate(1.4);
    border-bottom: 1px solid var(--rule);
  }

  .bp-nav__logo {
    font-family: var(--f-ui);
    font-weight: 700;
    font-size: 0.82rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--ink);
  }

  .bp-nav__links {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .bp-nav__links a {
    font-family: var(--f-ui);
    font-size: 0.76rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--ink-60);
    transition: color 200ms;
  }

  .bp-nav__links a:hover {
    color: var(--ink);
  }

  .bp-nav__pill {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.42rem 0.9rem;
    border: 1px solid var(--ink);
    border-radius: 999px;
    font-family: var(--f-ui);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    transition:
      background 200ms,
      color 200ms;
  }

  .bp-nav__pill:hover {
    background: var(--ink);
    color: var(--white);
  }

  .bp-shell {
    padding-top: calc(64px + clamp(2.5rem, 5vw, 4rem));
    padding-bottom: clamp(4rem, 7vw, 7rem);
    padding-left: clamp(1.5rem, 4vw, 3.5rem);
    padding-right: clamp(1.5rem, 4vw, 3.5rem);
    width: min(1160px, 100%);
    margin: 0 auto;
  }

  .bp-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
    opacity: 0;
    animation: bpUp 0.6s 0.05s forwards;
  }

  .bp-back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--f-ui);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--ink-60);
    transition:
      color 200ms,
      gap 200ms;
  }

  .bp-back:hover {
    color: var(--ink);
    gap: 0.75rem;
  }

  .bp-back__arrow {
    transition: transform 200ms;
  }
  .bp-back:hover .bp-back__arrow {
    transform: translateX(-3px);
  }

  .bp-breadcrumb__sep {
    font-family: var(--f-display);
    font-style: italic;
    color: var(--ink-30);
    font-size: 0.9rem;
  }

  .bp-breadcrumb__current {
    font-family: var(--f-ui);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--warm);
  }

  .bp-article {
    border: 1px solid var(--rule);
    border-radius: 0;
    overflow: hidden;
  }

  .bp-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.9fr);
    border-bottom: 1px solid var(--rule);
  }

  .bp-hero__left {
    padding: clamp(2.5rem, 4vw, 4rem) clamp(1.5rem, 3vw, 3rem);
    border-right: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2rem;
  }

  .bp-hero__meta-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    opacity: 0;
    animation: bpUp 0.6s 0.15s forwards;
  }

  .bp-hero__category {
    font-family: var(--f-ui);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--warm);
  }

  .bp-hero__sep {
    font-family: var(--f-display);
    font-style: italic;
    color: var(--ink-30);
  }

  .bp-hero__date {
    font-family: var(--f-ui);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-30);
  }

  .bp-hero__title {
    font-family: var(--f-display);
    font-size: clamp(2.8rem, 5.5vw, 5.5rem);
    font-weight: 300;
    line-height: 0.92;
    letter-spacing: -0.02em;
    color: var(--ink);
    max-width: 14ch;
    text-wrap: balance;
    margin: 0;
    opacity: 0;
    animation: bpUp 0.9s 0.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .bp-hero__dek {
    font-size: clamp(1rem, 1.2vw, 1.1rem);
    line-height: 1.78;
    color: var(--ink-60);
    max-width: 46ch;
    margin: 0;
    opacity: 0;
    animation: bpUp 0.7s 0.32s forwards;
  }

  .bp-hero__stats {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    opacity: 0;
    animation: bpUp 0.6s 0.42s forwards;
  }

  .bp-stat {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .bp-stat__value {
    font-family: var(--f-display);
    font-size: 1.6rem;
    font-weight: 300;
    line-height: 1;
    color: var(--ink);
  }

  .bp-stat__label {
    font-family: var(--f-ui);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-30);
  }

  .bp-stat__div {
    width: 1px;
    height: 2rem;
    background: var(--rule);
    flex-shrink: 0;
  }

  .bp-hero__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    opacity: 0;
    animation: bpUp 0.6s 0.5s forwards;
  }

  .bp-tag {
    padding: 0.3rem 0.65rem;
    border: 1px solid var(--rule);
    border-radius: 999px;
    font-family: var(--f-ui);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-60);
    transition:
      border-color 200ms,
      color 200ms;
  }

  .bp-tag:hover {
    border-color: var(--ink-30);
    color: var(--ink);
  }

  .bp-hero__image-wrap {
    overflow: hidden;
    background: var(--paper);
    opacity: 0;
    animation: bpFade 1s 0.3s forwards;
  }

  .bp-hero__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .bp-hero__image-wrap:hover .bp-hero__image {
    transform: scale(1.03);
  }

  .bp-rule {
    height: 1px;
    background: var(--rule);
  }

  .bp-body {
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr);
    align-items: start;
  }

  .bp-toc {
    position: sticky;
    top: calc(64px + 2rem);
    align-self: start;
    padding: 2rem 1.5rem;
    border-right: 1px solid var(--rule);
    min-height: 100%;
  }

  .bp-toc__title {
    font-family: var(--f-ui);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-30);
    margin: 0 0 1.25rem;
  }

  .bp-toc nav {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .bp-toc__link {
    display: block;
    padding: 0.5rem 0;
    border-bottom: 1px solid transparent;
    font-family: var(--f-body);
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--ink-60);
    text-decoration: none;
    transition:
      color 200ms,
      padding-left 200ms;
  }

  .bp-toc__link:hover {
    color: var(--ink);
    padding-left: 0.4rem;
  }
  .bp-toc__link[data-depth="3"] {
    padding-left: 1rem;
    font-size: 0.78rem;
    color: var(--ink-30);
  }
  .bp-toc__link[data-depth="3"]:hover {
    padding-left: 1.4rem;
    color: var(--ink-60);
  }
  .bp-toc__link.is-active {
    color: var(--ink);
    font-weight: 500;
  }

  .bp-prose {
    padding: clamp(2rem, 3vw, 3.5rem) clamp(1.5rem, 3vw, 3rem);
    min-width: 0;
  }

  :global(.bp-prose h2),
  :global(.bp-prose h3) {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: -0.01em;
    scroll-margin-top: calc(64px + 1.5rem);
    color: #0d0d0b;
  }

  :global(.bp-prose h2) {
    margin: 3rem 0 1rem;
    font-size: clamp(1.9rem, 3vw, 2.8rem);
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(13, 13, 11, 0.1);
  }

  :global(.bp-prose h3) {
    margin: 2rem 0 0.75rem;
    font-size: clamp(1.4rem, 2vw, 1.9rem);
    font-style: italic;
  }

  :global(.bp-prose p),
  :global(.bp-prose li) {
    font-family: "DM Sans", sans-serif;
    font-size: clamp(1rem, 1.05vw, 1.06rem);
    line-height: 1.88;
    color: rgba(13, 13, 11, 0.76);
  }

  :global(.bp-prose p) {
    margin: 0 0 1.25rem;
  }

  :global(.bp-prose ul),
  :global(.bp-prose ol) {
    margin: 0 0 1.25rem;
    padding-left: 1.4rem;
  }

  :global(.bp-prose li) {
    margin-bottom: 0.4rem;
  }

  :global(.bp-prose a) {
    color: #0d6f92;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
    transition: color 200ms;
  }

  :global(.bp-prose a:hover) {
    color: #0d0d0b;
  }

  :global(.bp-prose strong) {
    color: #0d0d0b;
    font-weight: 600;
  }

  :global(.bp-prose em) {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: 1.08em;
    font-style: italic;
    color: rgba(13, 13, 11, 0.88);
  }

  :global(.bp-prose blockquote) {
    margin: 2rem 0;
    padding: 1.5rem 1.75rem;
    border-left: 2px solid #b8936a;
    background: #f4f2ee;
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: clamp(1.2rem, 1.6vw, 1.5rem);
    font-style: italic;
    font-weight: 300;
    line-height: 1.55;
    color: rgba(13, 13, 11, 0.8);
  }

  :global(.bp-prose blockquote p) {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: inherit;
    line-height: inherit;
    color: inherit;
    margin: 0;
  }

  :global(.bp-prose code) {
    padding: 0.12rem 0.38rem;
    border-radius: 4px;
