---
export const prerender = true;

import BaseLayout from "../../layouts/BaseLayout.astro";
import LightRays from "../../components/ui/LightRays";
import {
  formatBlogDate,
  getAllBlogPosts,
  getPostUrl,
  getReadingTime,
} from "../../lib/blog";
import { SITE } from "../../lib/site";

const posts = await getAllBlogPosts();
const [featuredPost, ...otherPosts] = posts;
const siteOrigin = Astro.site?.origin ?? Astro.url.origin;
const blogUrl = new URL("/blog/", siteOrigin).toString();
const keywords = [
  ...SITE.keywords,
  "Astro blog",
  "engineering notes",
  "frontend performance",
  "AI product engineering",
];
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Blog",
    name: SITE.blogTitle,
    description: SITE.blogDescription,
    url: blogUrl,
    inLanguage: "en",
    author: {
      "@type": "Person",
      name: SITE.author,
      url: siteOrigin,
    },
    blogPost: posts.map((post) => ({
      "@type": "BlogPosting",
      headline: post.data.title,
      description: post.data.description,
      datePublished: post.data.publishDate.toISOString(),
      dateModified: (
        post.data.updatedDate ?? post.data.publishDate
      ).toISOString(),
      url: new URL(getPostUrl(post.id), siteOrigin).toString(),
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: siteOrigin },
      { "@type": "ListItem", position: 2, name: "Blog", item: blogUrl },
    ],
  },
];

const marqueeTopics = [
  "Astro & Islands Architecture",
  "Frontend Performance",
  "AI Product Engineering",
  "Core Web Vitals",
  "Design Systems",
  "SSR Patterns",
  "SEO at Scale",
];
---

<BaseLayout
  title={`Engineering Blog by ${SITE.author} | Astro, AI & Full-Stack`}
  description={SITE.blogDescription}
  image={featuredPost?.data.heroImage ?? SITE.socialImage}
  imageAlt={featuredPost?.data.heroImageAlt ?? SITE.blogTitle}
  keywords={keywords}
  schemaType="CollectionPage"
  structuredData={structuredData}
  themeColor="#ffffff"
  colorScheme="light"
>
  <Fragment slot="head">
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE.blogTitle} RSS feed`}
      href="/rss.xml"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;1,9..40,300&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div class="bi-cursor" id="biCursor" aria-hidden="true"></div>
  <div class="bi-scroll-line" id="biScrollLine" aria-hidden="true"></div>

  <main class="bi" id="main-content">
    <header class="bi-hero">
      <div class="bi-hero__banner" data-nav-contrast="dark">
        <div class="bi-hero__banner-bg" aria-hidden="true">
          <LightRays
            client:idle
            raysOrigin="top-center"
            raysColor="#f8f5ef"
            raysSpeed={0.55}
            lightSpread={0.42}
            rayLength={1.9}
            followMouse={true}
            mouseInfluence={0.035}
            noiseAmount={0}
            distortion={0.05}
            className="bi-hero__rays"
            pulsating={false}
            fadeDistance={0.9}
            saturation={0.7}
          />
        </div>
        <div class="bi-hero__eyebrow" aria-hidden="true">
          <div class="bi-hero__eyebrow-line"></div>
          <span>Markdown blog</span>
        </div>
        <h1 class="bi-hero__title">Latest Writing.</h1>
        <div class="bi-hero__actions">
          <a href="/">Back to portfolio</a>
          <a href="/rss.xml">Subscribe via RSS</a>
        </div>
      </div>

      {
        featuredPost && (
          <article class="bi-featured" aria-label="Featured post">
            <div class="bi-featured__meta-col">
              <div class="bi-featured__label">
                <div class="bi-featured__label-dot" />
                <span>Featured post</span>
              </div>
              <div class="bi-featured__number" aria-hidden="true">
                01
              </div>
              <div class="bi-featured__tags">
                {featuredPost.data.tags.map((tag) => (
                  <span class="bi-featured__tag">{tag}</span>
                ))}
              </div>
            </div>
            <div class="bi-featured__content-col">
              <a
                href={getPostUrl(featuredPost.id)}
                class="bi-featured__heading"
              >
                {featuredPost.data.title}
              </a>
              <p class="bi-featured__desc">{featuredPost.data.description}</p>
              <div class="bi-featured__footer">
                <span class="bi-featured__byline">
                  {formatBlogDate(featuredPost.data.publishDate)}
                  &nbsp;·&nbsp;
                  {getReadingTime(featuredPost.body)} min read
                </span>
                <a
                  href={getPostUrl(featuredPost.id)}
                  class="bi-featured__cta"
                  tabindex="-1"
                  aria-hidden="true"
                >
                  Read article
                  <span class="bi-featured__cta-arrow" aria-hidden="true">
                    →
                  </span>
                </a>
              </div>
            </div>
          </article>
        )
      }
    </header>

    <div class="bi-marquee" aria-hidden="true">
      <div class="bi-marquee__track">
        {
          [...marqueeTopics, ...marqueeTopics].map((topic) => (
            <span class="bi-marquee__item">{topic}</span>
          ))
        }
      </div>
    </div>

    <section class="bi-grid-section" aria-label="All blog posts">
      <div class="bi-grid-section__header">
        <span class="bi-grid-section__title">All posts</span>
        <span class="bi-grid-section__count"
          >{otherPosts.length + 1} articles</span
        >
      </div>

      <div class="bi-grid">
        {
          otherPosts.map((post, i) => (
            <article class="bi-card" style={`--stagger: ${i}`}>
              <div class="bi-card__index" aria-hidden="true">
                {String(i + 2).padStart(2, "0")}
              </div>
              <span class="bi-card__category">{post.data.category}</span>
              <h2 class="bi-card__title">
                <a href={getPostUrl(post.id)}>{post.data.title}</a>
              </h2>
              <p class="bi-card__desc">{post.data.description}</p>
              <div class="bi-card__footer">
                <span class="bi-card__meta">
                  {formatBlogDate(post.data.publishDate)}
                  &nbsp;·&nbsp;
                  {getReadingTime(post.body)} min
                </span>
                <div class="bi-card__tags">
                  {post.data.tags.slice(0, 2).map((tag) => (
                    <span class="bi-card__tag">{tag}</span>
                  ))}
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <footer class="bi-footer">
      <span class="bi-footer__copy">{SITE.name}</span>
      <div class="bi-footer__socials">
        <a href="https://x.com/silknye" target="_blank" rel="noreferrer"
          >Twitter</a
        >
        <a href="https://instagram.com/silknye" target="_blank" rel="noreferrer"
          >Instagram</a
        >
        <a
          href="https://github.com/dilukshann7"
          target="_blank"
          rel="noreferrer">GitHub</a
        >
        <a
          href="https://linkedin.com/in/dilukshann7"
          target="_blank"
          rel="noreferrer">LinkedIn</a
        >
      </div>
    </footer>
  </main>
</BaseLayout>

<style>
  .bi *,
  .bi *::before,
  .bi *::after {
    box-sizing: border-box;
  }

  .bi {
    --bg: #f5f5f7;
    --bg-1: #ffffff;
    --bg-2: #f0f0f2;
    --bg-hover: #f8f8fa;

    --border: rgba(0, 0, 0, 0.07);
    --border-md: rgba(0, 0, 0, 0.1);
    --border-strong: rgba(0, 0, 0, 0.16);

    --silver: #8e8e93;
    --silver-light: #aeaeb2;
    --silver-dim: rgba(142, 142, 147, 0.5);
    --silver-faint: rgba(142, 142, 147, 0.1);

    --glass-bg: rgba(255, 255, 255, 0.62);
    --glass-border: rgba(255, 255, 255, 0.75);

    --text-primary: #1a1a1e;
    --text-secondary: rgba(26, 26, 30, 0.52);
    --text-tertiary: rgba(26, 26, 30, 0.32);
    --text-disabled: rgba(26, 26, 30, 0.18);

    --f-display: "Inter", system-ui, sans-serif;
    --f-ui: "Inter", system-ui, sans-serif;
    --f-mono: "JetBrains Mono", "Fira Code", monospace;
    --f-body: "Inter", system-ui, sans-serif;

    --radius-xs: 4px;
    --radius-sm: 8px;
    --radius: 12px;
    --radius-lg: 16px;

    --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
    --ease-standard: cubic-bezier(0.4, 0, 0.2, 1);

    --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.06), 0 1px 2px rgba(0, 0, 0, 0.04);
    --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.07), 0 1px 4px rgba(0, 0, 0, 0.05);
    --shadow-lg: 0 12px 40px rgba(0, 0, 0, 0.09), 0 2px 8px rgba(0, 0, 0, 0.05);

    background: var(--bg);
    color: var(--text-primary);
    font-family: var(--f-body);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
    min-height: 100vh;
  }

  .bi-cursor {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--text-primary);
    position: fixed;
    pointer-events: none;
    z-index: 9999;
    mix-blend-mode: multiply;
    transform: translate(-50%, -50%);
    transition:
      transform 120ms ease,
      opacity 200ms;
  }

  .bi-scroll-line {
    position: fixed;
    top: 64px;
    left: 0;
    height: 1px;
    background: var(--silver);
    z-index: 9998;
    width: 0%;
    transition: width 60ms linear;
  }

  .bi-hero {
    border-bottom: 1px solid var(--border-md);
  }

  .bi-hero__banner {
    position: relative;
    padding: clamp(5rem, 8vw, 8rem) clamp(1.5rem, 4vw, 3.5rem)
      clamp(3rem, 5vw, 5rem);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto 1fr auto;
    gap: 0;
    isolation: isolate;
    background: #080808;
  }

  .bi-hero__banner > :not(.bi-hero__banner-bg) {
    position: relative;
    z-index: 1;
  }

  .bi-hero__banner-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }

  .bi-hero__banner-bg::before {
    content: "";
    position: absolute;
    inset: -24% -6% 28%;
    background: radial-gradient(
      circle at 50% 0%,
      rgba(200, 200, 210, 0.18),
      rgba(180, 180, 200, 0.06) 38%,
      transparent 70%
    );
    mix-blend-mode: screen;
    z-index: 1;
  }

  .bi-hero__banner-bg::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 45%;
    background: linear-gradient(to bottom, transparent, #080808);
    z-index: 2;
  }

  .bi-hero__banner-bg :global(.bi-hero__rays) {
    width: 100%;
    height: 100%;
    opacity: 0.82;
  }

  .bi-hero__eyebrow {
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
    opacity: 0;
    animation: biUp 0.7s 0.1s forwards;
  }

  .bi-hero__eyebrow span {
    font-family: var(--f-mono);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.38);
  }

  .bi-hero__eyebrow-line {
    width: 20px;
    height: 1px;
    background: rgba(255, 255, 255, 0.18);
    flex-shrink: 0;
  }

  .bi-hero__title {
    grid-column: 1;
    font-family: var(--f-display);
    font-size: clamp(3.5rem, 9vw, 8rem);
    font-weight: 700;
    line-height: 0.94;
    letter-spacing: -0.04em;
    color: rgba(255, 255, 255, 0.96);
    opacity: 0;
    animation: biUp 0.9s 0.2s var(--ease-out-expo) forwards;
  }

  .bi-hero__actions {
    grid-column: 1 / -1;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 2.5rem;
    opacity: 0;
    animation: biUp 0.7s 0.35s forwards;
  }

  .bi-hero__actions a {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 1.1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-sm);
    font-family: var(--f-body);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.6);
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition:
      border-color 140ms,
      color 140ms,
      background 140ms;
  }

  .bi-hero__actions a:hover {
    border-color: rgba(255, 255, 255, 0.22);
    color: rgba(255, 255, 255, 0.9);
    background: rgba(255, 255, 255, 0.1);
  }

  .bi-featured {
    display: grid;
    grid-template-columns: minmax(0, 0.42fr) minmax(0, 0.58fr);
    background: var(--bg-1);
  }

  .bi-featured__meta-col {
    padding: clamp(2.5rem, 4vw, 4rem) clamp(1.5rem, 4vw, 3.5rem);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2rem;
    opacity: 0;
    animation: biUp 0.8s 0.45s forwards;
  }

  .bi-featured__label {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .bi-featured__label-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--silver);
    flex-shrink: 0;
  }

  .bi-featured__label span {
    font-family: var(--f-mono);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .bi-featured__number {
    font-family: var(--f-display);
    font-size: clamp(5rem, 12vw, 11rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.05em;
    color: var(--bg-2);
    user-select: none;
  }

  .bi-featured__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .bi-featured__tag {
    padding: 0.22rem 0.6rem;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: var(--radius-xs);
    font-family: var(--f-mono);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    box-shadow: var(--shadow-sm);
  }

  .bi-featured__content-col {
    padding: clamp(2.5rem, 4vw, 4rem) clamp(1.5rem, 4vw, 3.5rem);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2rem;
    opacity: 0;
    animation: biUp 0.8s 0.55s forwards;
    background: var(--bg-1);
  }

  .bi-featured__heading {
    font-family: var(--f-display);
    font-size: clamp(1.7rem, 2.8vw, 2.8rem);
    font-weight: 660;
    line-height: 1.06;
    letter-spacing: -0.035em;
    color: var(--text-primary);
    text-decoration: none;
    display: block;
    transition: color 150ms;
  }

  .bi-featured__heading:hover {
    color: var(--silver);
  }

  .bi-featured__desc {
    font-size: 0.92rem;
    line-height: 1.78;
    color: var(--text-secondary);
    max-width: 52ch;
    margin: 0;
    letter-spacing: -0.005em;
  }

  .bi-featured__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
  }

  .bi-featured__byline {
    font-family: var(--f-mono);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .bi-featured__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--f-mono);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--text-secondary);
    transition:
      color 140ms,
      gap 140ms;
  }

  .bi-featured__cta:hover {
    color: var(--silver);
    gap: 0.75rem;
  }

  .bi-featured__cta-arrow {
    transition: transform 200ms var(--ease-out-expo);
  }

  .bi-featured__cta:hover .bi-featured__cta-arrow {
    transform: translateX(3px);
  }

  .bi-marquee {
    overflow: hidden;
    background: var(--bg-1);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 0.85rem 0;
  }

  .bi-marquee__track {
    display: flex;
    white-space: nowrap;
    animation: biMarquee 28s linear infinite;
  }

  .bi-marquee__item {
    display: inline-flex;
    align-items: center;
    padding: 0 2rem;
    font-family: var(--f-mono);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .bi-marquee__item::after {
    content: "·";
    font-size: 1rem;
    color: var(--silver-dim);
    margin-left: 2rem;
    line-height: 1;
  }

  .bi-grid-section {
    padding: clamp(2.5rem, 4vw, 4rem) clamp(1.5rem, 4vw, 3.5rem);
  }

  .bi-grid-section__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-md);
  }

  .bi-grid-section__title {
    font-family: var(--f-mono);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .bi-grid-section__count {
    font-family: var(--f-mono);
    font-size: 0.62rem;
    font-weight: 500;
    color: var(--silver-dim);
    letter-spacing: 0.04em;
  }

  .bi-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  .bi-card {
    padding: clamp(1.5rem, 2.2vw, 2rem);
    position: relative;
    overflow: hidden;
    opacity: 0;
    animation: biUp 0.6s calc(0.55s + var(--stagger) * 0.08s) forwards;
    background: var(--glass-bg);
    backdrop-filter: blur(16px) saturate(1.5);
    -webkit-backdrop-filter: blur(16px) saturate(1.5);
    border: 1px solid rgba(255, 255, 255, 0.7);
    border-radius: var(--radius-lg);
    box-shadow:
      var(--shadow-md),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
    transition:
      border-color 200ms var(--ease-standard),
      background 200ms var(--ease-standard),
      box-shadow 200ms var(--ease-standard),
      transform 200ms var(--ease-out-expo);
  }

  .bi-card:hover {
    background: rgba(255, 255, 255, 0.82);
    border-color: rgba(255, 255, 255, 0.9);
    box-shadow:
      var(--shadow-lg),
      inset 0 1px 0 rgba(255, 255, 255, 0.95);
    transform: translateY(-2px);
  }

  .bi-card > * {
    position: relative;
    z-index: 1;
  }

  .bi-card__index {
    font-family: var(--f-mono);
    font-size: 0.6rem;
    font-weight: 500;
    color: var(--silver-dim);
    margin-bottom: 1rem;
    display: block;
    letter-spacing: 0.04em;
  }

  .bi-card__category {
    display: inline-block;
    margin-bottom: 0.55rem;
    font-family: var(--f-mono);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--silver);
    background: var(--silver-faint);
    border: 1px solid rgba(142, 142, 147, 0.15);
    padding: 0.18rem 0.5rem;
    border-radius: var(--radius-xs);
  }

  .bi-card__title {
    font-family: var(--f-display);
    font-size: clamp(1.1rem, 1.6vw, 1.5rem);
    font-weight: 640;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin: 0 0 0.7rem;
  }

  .bi-card__title a {
    text-decoration: none;
    color: var(--text-primary);
    transition: color 150ms;
  }

  .bi-card__title a:hover {
    color: var(--silver);
  }

  .bi-card__desc {
    font-size: 0.84rem;
    line-height: 1.72;
    color: var(--text-secondary);
    margin: 0 0 1.25rem;
    letter-spacing: -0.005em;
  }

  .bi-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .bi-card__meta {
    font-family: var(--f-mono);
    font-size: 0.58rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .bi-card__tags {
    display: flex;
    gap: 0.35rem;
  }

  .bi-card__tag {
