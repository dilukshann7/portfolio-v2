---
export const prerender = true;

import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  formatBlogDate,
  getAllBlogPosts,
  getPostUrl,
  getReadingTime,
} from "../../lib/blog";
import { SITE } from "../../lib/site";

const posts = await getAllBlogPosts();
const [featuredPost, ...otherPosts] = posts;
const siteOrigin = Astro.site?.origin ?? Astro.url.origin;
const blogUrl = new URL("/blog/", siteOrigin).toString();
const keywords = [
  ...SITE.keywords,
  "Astro blog",
  "engineering notes",
  "frontend performance",
  "AI product engineering",
];
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Blog",
    name: SITE.blogTitle,
    description: SITE.blogDescription,
    url: blogUrl,
    inLanguage: "en",
    author: {
      "@type": "Person",
      name: SITE.author,
      url: siteOrigin,
    },
    blogPost: posts.map((post) => ({
      "@type": "BlogPosting",
      headline: post.data.title,
      description: post.data.description,
      datePublished: post.data.publishDate.toISOString(),
      dateModified: (
        post.data.updatedDate ?? post.data.publishDate
      ).toISOString(),
      url: new URL(getPostUrl(post.id), siteOrigin).toString(),
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: siteOrigin },
      { "@type": "ListItem", position: 2, name: "Blog", item: blogUrl },
    ],
  },
];

const marqueeTopics = [
  "Astro & Islands Architecture",
  "Frontend Performance",
  "AI Product Engineering",
  "Core Web Vitals",
  "Design Systems",
  "SSR Patterns",
  "SEO at Scale",
];
---

<BaseLayout
  title={`${SITE.author} — Journal`}
  description={SITE.blogDescription}
  image={featuredPost?.data.heroImage ?? SITE.socialImage}
  imageAlt={featuredPost?.data.heroImageAlt ?? SITE.blogTitle}
  keywords={keywords}
  structuredData={structuredData}
  themeColor="#ffffff"
  colorScheme="light"
>
  <Fragment slot="head">
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE.blogTitle} RSS feed`}
      href="/rss.xml"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;1,9..40,300&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div class="bi-cursor" id="biCursor" aria-hidden="true"></div>
  <div class="bi-scroll-line" id="biScrollLine" aria-hidden="true"></div>

  <main class="bi">
    <nav class="bi-nav">
      <a href="/" class="bi-nav__logo">{SITE.author}</a>
      <ul class="bi-nav__links">
        <li><a href="/">Work</a></li>
        <li><a href="/blog/">Journal</a></li>
      </ul>
      <a href="/rss.xml" class="bi-nav__pill" aria-label="Subscribe via RSS">
        <svg
          width="10"
          height="10"
          viewBox="0 0 10 10"
          fill="none"
          aria-hidden="true"
        >
          <circle cx="2" cy="8" r="1.5" fill="currentColor"></circle>
          <path
            d="M1 5a4 4 0 014 4"
            stroke="currentColor"
            stroke-width="1.2"
            stroke-linecap="round"
            fill="none"></path>
          <path
            d="M1 2a7 7 0 017 7"
            stroke="currentColor"
            stroke-width="1.2"
            stroke-linecap="round"
            fill="none"></path>
        </svg>
        RSS
      </a>
    </nav>

    <header class="bi-hero">
      <div class="bi-hero__banner">
        <div class="bi-hero__eyebrow" aria-hidden="true">
          <div class="bi-hero__eyebrow-line"></div>
          <span>Markdown blog</span>
          <div class="bi-hero__eyebrow-line"></div>
          <span>Engineering &amp; Product</span>
        </div>
        <h1 class="bi-hero__title">
          Writing that<br />
          <em>connects</em><br />
          product &amp;<br />
          engineering.
        </h1>
        <div class="bi-hero__actions">
          <a href="/">Back to portfolio</a>
          <a href="/rss.xml">Subscribe via RSS</a>
        </div>
      </div>

      {
        featuredPost && (
          <article class="bi-featured" aria-label="Featured post">
            <div class="bi-featured__meta-col">
              <div class="bi-featured__label">
                <div class="bi-featured__label-dot" />
                <span>Featured post</span>
              </div>
              <div class="bi-featured__number" aria-hidden="true">
                01
              </div>
              <div class="bi-featured__tags">
                {featuredPost.data.tags.map((tag) => (
                  <span class="bi-featured__tag">{tag}</span>
                ))}
              </div>
            </div>
            <div class="bi-featured__content-col">
              <a
                href={getPostUrl(featuredPost.id)}
                class="bi-featured__heading"
              >
                {featuredPost.data.title}
              </a>
              <p class="bi-featured__desc">{featuredPost.data.description}</p>
              <div class="bi-featured__footer">
                <span class="bi-featured__byline">
                  {formatBlogDate(featuredPost.data.publishDate)}
                  &nbsp;·&nbsp;
                  {getReadingTime(featuredPost.body)} min read
                </span>
                <a
                  href={getPostUrl(featuredPost.id)}
                  class="bi-featured__cta"
                  tabindex="-1"
                  aria-hidden="true"
                >
                  Read article
                  <span class="bi-featured__cta-arrow" aria-hidden="true">
                    →
                  </span>
                </a>
              </div>
            </div>
          </article>
        )
      }
    </header>
    <div class="bi-marquee" aria-hidden="true">
      <div class="bi-marquee__track">
        {
          [...marqueeTopics, ...marqueeTopics].map((topic) => (
            <span class="bi-marquee__item">{topic}</span>
          ))
        }
      </div>
    </div>

    <section class="bi-grid-section" aria-label="All blog posts">
      <div class="bi-grid-section__header">
        <span class="bi-grid-section__title">All posts</span>
        <span class="bi-grid-section__count"
          >{otherPosts.length + 1} articles</span
        >
      </div>

      <div class="bi-grid">
        {
          otherPosts.map((post, i) => (
            <article class="bi-card" style={`--stagger: ${i}`}>
              <div class="bi-card__index" aria-hidden="true">
                {String(i + 2).padStart(2, "0")}
              </div>
              <span class="bi-card__category">{post.data.category}</span>
              <h2 class="bi-card__title">
                <a href={getPostUrl(post.id)}>{post.data.title}</a>
              </h2>
              <p class="bi-card__desc">{post.data.description}</p>
              <div class="bi-card__footer">
                <span class="bi-card__meta">
                  {formatBlogDate(post.data.publishDate)}
                  &nbsp;·&nbsp;
                  {getReadingTime(post.body)} min
                </span>
                <div class="bi-card__tags">
                  {post.data.tags.slice(0, 2).map((tag) => (
                    <span class="bi-card__tag">{tag}</span>
                  ))}
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <footer class="bi-footer">
      <span class="bi-footer__copy"
        >© {new Date().getFullYear()} {SITE.author} — Built with Astro</span
      >
      <ul class="bi-footer__links">
        <li><a href="/">Portfolio</a></li>
        <li><a href="/rss.xml">RSS feed</a></li>
      </ul>
    </footer>
  </main>
</BaseLayout>

<style>
  .bi *,
  .bi *::before,
  .bi *::after {
    box-sizing: border-box;
  }

  .bi {
    --white: #ffffff;
    --paper: #f4f2ee;
    --ink: #0d0d0b;
    --ink-60: rgba(13, 13, 11, 0.6);
    --ink-30: rgba(13, 13, 11, 0.3);
    --ink-10: rgba(13, 13, 11, 0.1);
    --ink-06: rgba(13, 13, 11, 0.06);
    --warm: #b8936a;
    --rule: rgba(13, 13, 11, 0.12);
    --f-display: "Cormorant Garamond", Georgia, serif;
    --f-ui: "Syne", sans-serif;
    --f-body: "DM Sans", sans-serif;

    background: var(--white);
    color: var(--ink);
    font-family: var(--f-body);
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
    min-height: 100vh;
  }

  .bi-cursor {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--ink);
    position: fixed;
    pointer-events: none;
    z-index: 9999;
    mix-blend-mode: difference;
    transform: translate(-50%, -50%);
    transition:
      transform 120ms ease,
      opacity 200ms;
  }

  .bi-scroll-line {
    position: fixed;
    top: 64px;
    left: 0;
    height: 2px;
    background: var(--ink);
    z-index: 9998;
    width: 0%;
    transition: width 60ms linear;
  }

  .bi-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 clamp(1.5rem, 4vw, 3.5rem);
    height: 64px;
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(20px) saturate(1.4);
    border-bottom: 1px solid var(--rule);
  }

  .bi-nav__logo {
    font-family: var(--f-ui);
    font-weight: 700;
    font-size: 0.82rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--ink);
  }

  .bi-nav__links {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .bi-nav__links a {
    font-family: var(--f-ui);
    font-size: 0.76rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--ink-60);
    transition: color 200ms;
  }

  .bi-nav__links a:hover,
  .bi-nav__links a[aria-current="page"] {
    color: var(--ink);
  }

  .bi-nav__pill {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.42rem 0.9rem;
    border: 1px solid var(--ink);
    border-radius: 999px;
    font-family: var(--f-ui);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    transition:
      background 200ms,
      color 200ms;
  }

  .bi-nav__pill:hover {
    background: var(--ink);
    color: var(--white);
  }

  .bi-hero {
    padding-top: 64px;
    border-bottom: 1px solid var(--rule);
  }

  .bi-hero__banner {
    padding: clamp(5rem, 8vw, 8rem) clamp(1.5rem, 4vw, 3.5rem)
      clamp(3rem, 5vw, 5rem);
    border-bottom: 1px solid var(--rule);
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto 1fr auto;
    gap: 0;
  }

  .bi-hero__eyebrow {
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
    opacity: 0;
    animation: biUp 0.7s 0.1s forwards;
  }

  .bi-hero__eyebrow span {
    font-family: var(--f-ui);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-60);
  }

  .bi-hero__eyebrow-line {
    width: 36px;
    height: 1px;
    background: var(--ink-30);
    flex-shrink: 0;
  }

  .bi-hero__title {
    grid-column: 1;
    font-family: var(--f-display);
    font-size: clamp(4.5rem, 11vw, 10.5rem);
    font-weight: 300;
    line-height: 0.88;
    letter-spacing: -0.02em;
    color: var(--ink);
    opacity: 0;
    animation: biUp 0.9s 0.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .bi-hero__title em {
    font-style: italic;
    font-weight: 300;
    color: var(--ink-60);
  }

  .bi-hero__actions {
    grid-column: 1 / -1;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2.5rem;
    opacity: 0;
    animation: biUp 0.7s 0.35s forwards;
  }

  .bi-hero__actions a {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.2rem;
    border: 1px solid var(--rule);
    border-radius: 999px;
    font-family: var(--f-ui);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--ink-60);
    background: transparent;
    transition:
      border-color 200ms,
      color 200ms,
      background 200ms;
  }

  .bi-hero__actions a:hover {
    border-color: var(--ink);
    color: var(--ink);
  }

  .bi-featured {
    display: grid;
    grid-template-columns: minmax(0, 0.42fr) minmax(0, 0.58fr);
  }

  .bi-featured__meta-col {
    padding: clamp(2.5rem, 4vw, 4rem) clamp(1.5rem, 4vw, 3.5rem);
    border-right: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2rem;
    opacity: 0;
    animation: biUp 0.8s 0.45s forwards;
  }

  .bi-featured__label {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .bi-featured__label-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--warm);
    flex-shrink: 0;
  }

  .bi-featured__label span {
    font-family: var(--f-ui);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-60);
  }

  .bi-featured__number {
    font-family: var(--f-display);
    font-size: clamp(5rem, 12vw, 11rem);
    font-weight: 300;
    line-height: 1;
    color: var(--paper);
    letter-spacing: -0.04em;
    user-select: none;
  }

  .bi-featured__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .bi-featured__tag {
    padding: 0.32rem 0.7rem;
    border: 1px solid var(--rule);
    border-radius: 999px;
    font-family: var(--f-ui);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-60);
  }

  .bi-featured__content-col {
    padding: clamp(2.5rem, 4vw, 4rem) clamp(1.5rem, 4vw, 3.5rem);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2rem;
    opacity: 0;
    animation: biUp 0.8s 0.55s forwards;
  }

  .bi-featured__heading {
    font-family: var(--f-display);
    font-size: clamp(1.9rem, 3vw, 3.2rem);
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: -0.015em;
    color: var(--ink);
    text-decoration: none;
    display: block;
    transition: color 200ms;
  }

  .bi-featured__heading:hover {
    color: var(--ink-60);
  }

  .bi-featured__desc {
    font-size: 0.95rem;
    line-height: 1.78;
    color: var(--ink-60);
    max-width: 52ch;
    margin: 0;
  }

  .bi-featured__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
  }

  .bi-featured__byline {
    font-family: var(--f-ui);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-30);
  }

  .bi-featured__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--f-ui);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--ink);
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
    transition:
      gap 200ms,
      opacity 200ms;
  }

  .bi-featured__cta:hover {
    gap: 1rem;
    opacity: 0.55;
  }

  .bi-featured__cta-arrow {
    transition: transform 200ms;
  }
  .bi-featured__cta:hover .bi-featured__cta-arrow {
    transform: translateX(4px);
  }

  .bi-marquee {
    overflow: hidden;
    background: var(--ink);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding: 1.1rem 0;
  }

  .bi-marquee__track {
    display: flex;
    white-space: nowrap;
    animation: biMarquee 24s linear infinite;
  }

  .bi-marquee__item {
    display: inline-flex;
    align-items: center;
    gap: 0;
    padding: 0 2.5rem;
    font-family: var(--f-display);
    font-size: 1rem;
    font-style: italic;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 0.02em;
  }

  .bi-marquee__item::after {
    content: "◆";
    font-size: 0.35rem;
    color: var(--warm);
    vertical-align: middle;
    margin-left: 2.5rem;
  }

  .bi-grid-section {
    padding: clamp(3rem, 5vw, 5rem) clamp(1.5rem, 4vw, 3.5rem);
  }

  .bi-grid-section__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 3rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--rule);
  }

  .bi-grid-section__title {
    font-family: var(--f-ui);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-60);
  }

  .bi-grid-section__count {
    font-family: var(--f-display);
    font-size: 0.88rem;
    font-style: italic;
    color: var(--ink-30);
  }

  .bi-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .bi-card {
    padding: clamp(1.75rem, 2.5vw, 2.5rem);
    border-right: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    position: relative;
    overflow: hidden;
    opacity: 0;
    animation: biUp 0.6s calc(0.55s + var(--stagger) * 0.1s) forwards;
  }

  .bi-card:nth-child(3n) {
    border-right: none;
  }

  .bi-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--paper);
    transform: translateY(102%);
    transition: transform 380ms cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 0;
  }

  .bi-card:hover::before {
    transform: translateY(0);
  }

  .bi-card > * {
    position: relative;
    z-index: 1;
  }

  .bi-card__index {
    font-family: var(--f-display);
    font-size: 0.82rem;
    font-style: italic;
    color: var(--ink-30);
    margin-bottom: 1.25rem;
    display: block;
  }

  .bi-card__category {
    display: inline-block;
    margin-bottom: 0.6rem;
    font-family: var(--f-ui);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--warm);
  }

  .bi-card__title {
    font-family: var(--f-display);
    font-size: clamp(1.25rem, 1.8vw, 1.85rem);
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -0.01em;
    margin: 0 0 0.9rem;
  }

  .bi-card__title a {
    text-decoration: none;
    color: var(--ink);
    transition: color 200ms;
  }

  .bi-card__title a:hover {
    color: var(--ink-60);
  }

  .bi-card__desc {
    font-size: 0.87rem;
    line-height: 1.72;
    color: var(--ink-60);
    margin: 0 0 1.5rem;
  }

  .bi-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.25rem;
    border-top: 1px solid var(--rule);
  }

  .bi-card__meta {
    font-family: var(--f-ui);
    font-size: 0.66rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-30);
  }

  .bi-card__tags {
    display: flex;
    gap: 0.35rem;
  }

  .bi-card__tag {
    padding: 0.18rem 0.5rem;
    background: var(--ink-06);
    border-radius: 4px;
    font-family: var(--f-ui);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-60);
  }

  .bi-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 2rem clamp(1.5rem, 4vw, 3.5rem);
    border-top: 1px solid var(--rule);
    flex-wrap: wrap;
    gap: 1rem;
  }

  .bi-footer__copy {
    font-family: var(--f-ui);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-30);
  }

  .bi-footer__links {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .bi-footer__links a {
    font-family: var(--f-ui);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--ink-30);
    transition: color 200ms;
  }

  .bi-footer__links a:hover {
    color: var(--ink);
  }

  @keyframes biUp {
    from {
      opacity: 0;
      transform: translateY(22px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes biMarquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (max-width: 960px) {
    .bi-featured {
      grid-template-columns: 1fr;
    }
    .bi-featured__meta-col {
      border-right: none;
      border-bottom: 1px solid var(--rule);
    }
    .bi-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .bi-card:nth-child(3n) {
      border-right: 1px solid var(--rule);
    }
    .bi-card:nth-child(2n) {
      border-right: none;
    }
  }

  @media (max-width: 600px) {
    .bi-nav__links {
      display: none;
    }
    .bi-hero__banner {
      grid-template-columns: 1fr;
    }
    .bi-grid {
      grid-template-columns: 1fr;
    }
    .bi-card {
      border-right: none;
    }
    .bi-card:nth-child(3n) {
      border-right: none;
    }
    .bi-card:nth-child(2n) {
      border-right: none;
    }
  }
</style>

<script>
  import { runPageScript } from "../../lib/client/spa";

  const initBlogIndexPage = () =>
    runPageScript("blog-index-page", ({ signal }) => {
    const cursor = document.getElementById("biCursor");
    if (cursor && window.matchMedia("(pointer: fine)").matches) {
      document.addEventListener(
        "mousemove",
        (e) => {
          cursor.style.left = e.clientX + "px";
          cursor.style.top = e.clientY + "px";
        },
        { passive: true, signal },
      );

      document.querySelectorAll("a, button, .bi-card").forEach((el) => {
        el.addEventListener(
          "mouseenter",
          () => {
            cursor.style.transform = "translate(-50%,-50%) scale(3.5)";
          },
          { signal },
        );
        el.addEventListener(
          "mouseleave",
          () => {
            cursor.style.transform = "translate(-50%,-50%) scale(1)";
          },
          { signal },
        );
      });
    } else if (cursor) {
      cursor.style.display = "none";
    }

    const line = document.getElementById("biScrollLine");
    if (line) {
      window.addEventListener(
        "scroll",
        () => {
          const pct =
            (window.scrollY /
              (document.body.scrollHeight - window.innerHeight)) *
            100;
          line.style.width = pct + "%";
        },
        { passive: true, signal },
      );
    }
    });

  document.addEventListener("astro:page-load", initBlogIndexPage);
</script>
